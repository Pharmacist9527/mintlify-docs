{
  "openapi": "3.1.0",
  "info": {
    "title": "Interface de variation Midjourney V7",
    "description": "Creer des variantes de style a partir d'images deja generees",
    "license": {
      "name": "MIT"
    },
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://api.evolink.ai",
      "description": "Production"
    }
  ],
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "paths": {
    "/v1/images/generations": {
      "post": {
        "summary": "Interface de variation Midjourney V7",
        "description": "- Basee sur les taches de generation d'images de la serie mj-v7 terminees, genere des variantes de style similaires mais differentes pour une image specifiee\n- Prend en charge un prompt optionnel, s'il est fourni, le contenu est modifie en meme temps que la variation\n- Mode de traitement asynchrone, utilisez l'ID de tache retourne pour [effectuer une requete](/fr/api-manual/task-management/get-task-detail)",
        "operationId": "createMjV7Variation",
        "tags": [
          "Génération d'images"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ImageGenerationRequest"
              },
              "examples": {
                "basic_variation": {
                  "summary": "Variation de base",
                  "value": {
                    "model": "mj-v7-variation",
                    "model_params": {
                      "task_id": "task-unified-xxx",
                      "image_number": 2,
                      "type": "strong"
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Tâche créée avec succès",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ImageGenerationResponse"
                }
              }
            }
          },
          "400": {
            "description": "Paramètres de requête invalides",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "error": {
                    "code": "invalid_request",
                    "message": "Invalid request parameters",
                    "type": "invalid_request_error"
                  }
                }
              }
            }
          },
          "401": {
            "description": "Non authentifié, token invalide ou expiré",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "error": {
                    "code": "unauthorized",
                    "message": "Invalid or expired token",
                    "type": "authentication_error"
                  }
                }
              }
            }
          },
          "402": {
            "description": "Quota insuffisant, veuillez recharger",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "error": {
                    "code": "insufficient_quota",
                    "message": "Insufficient quota. Please top up your account.",
                    "type": "insufficient_quota"
                  }
                }
              }
            }
          },
          "403": {
            "description": "Accès refusé",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "error": {
                    "code": "model_access_denied",
                    "message": "Token does not have access to model: mj-v7-variation",
                    "type": "invalid_request_error"
                  }
                }
              }
            }
          },
          "429": {
            "description": "Limite de débit dépassée",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "error": {
                    "code": "rate_limit_exceeded",
                    "message": "Too many requests, please try again later",
                    "type": "rate_limit_error"
                  }
                }
              }
            }
          },
          "500": {
            "description": "Erreur interne du serveur",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "error": {
                    "code": "internal_error",
                    "message": "Internal server error",
                    "type": "api_error"
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "##Toutes les interfaces necessitent une authentification par Bearer Token##\n\n**Obtenir une cle API :**\n\nVisitez la [page de gestion des cles API](https://evolink.ai/dashboard/keys) pour obtenir votre cle API\n\n**Ajoutez dans l'en-tete de la requete :**\n```\nAuthorization: Bearer YOUR_API_KEY\n```"
      }
    },
    "schemas": {
      "ImageGenerationRequest": {
        "type": "object",
        "required": [
          "model",
          "model_params"
        ],
        "properties": {
          "model": {
            "type": "string",
            "enum": [
              "mj-v7-variation"
            ],
            "default": "mj-v7-variation",
            "description": "Nom du modèle"
          },
          "prompt": {
            "type": "string",
            "description": "Prompt optionnel, s'il est fourni, il sert de prompt de remix pour modifier le contenu lors de la variation",
            "example": "Changer pour une scene de coucher de soleil"
          },
          "model_params": {
            "type": "object",
            "description": "Paramètres du modèle",
            "required": [
              "task_id"
            ],
            "properties": {
              "task_id": {
                "type": "string",
                "description": "ID de la tâche source, doit etre une tache de la serie mj-v7 terminee et doit appartenir à l'utilisateur actuel",
                "example": "task-unified-1757165031-mjv7"
              },
              "image_number": {
                "type": "integer",
                "enum": [
                  0,
                  1,
                  2,
                  3
                ],
                "default": 0,
                "description": "Selectionner l'image parmi les 4 de la tache source (0-3)"
              },
              "type": {
                "type": "string",
                "enum": [
                  "subtle",
                  "strong"
                ],
                "default": "subtle",
                "description": "Intensite de variation\n\n- `subtle` : variation legere\n- `strong` : variation forte"
              },
              "speed": {
                "type": "string",
                "enum": [
                  "fast",
                  "turbo"
                ],
                "default": "fast",
                "description": "Mode de vitesse（effectif uniquement lorsqu'un prompt est fourni）\n\n**Informations sur les couts :** Le mode turbo coûte plus cher"
              }
            }
          },
          "callback_url": {
            "type": "string",
            "description": "Adresse de rappel HTTPS apres l'achevement de la tache\n\n**Moment du rappel :**\n- Declenche lorsque la tache est terminee (completed), echouee (failed) ou annulee (cancelled)\n- Envoye apres la confirmation de facturation\n\n**Restrictions de securite :**\n- Seul le protocole HTTPS est pris en charge\n- Les rappels vers les adresses IP privees sont interdits (127.0.0.1, 10.x.x.x, 172.16-31.x.x, 192.168.x.x, etc.)\n- La longueur de l'URL ne doit pas depasser `2048` caracteres\n\n**Mecanisme de rappel :**\n- Delai d'expiration : `10` secondes\n- Jusqu'a `3` tentatives apres un echec (respectivement `1`s/`2`s/`4`s apres l'echec)\n- Le format du corps de la reponse de rappel est identique a celui de l'interface de requete de tache\n- Un code de statut 2xx de l'adresse de rappel est considere comme un succes, tout autre code de statut declenche une nouvelle tentative",
            "format": "uri",
            "example": "https://your-domain.com/webhooks/image-task-completed"
          }
        }
      },
      "ImageGenerationResponse": {
        "type": "object",
        "properties": {
          "created": {
            "type": "integer",
            "description": "Horodatage de création",
            "example": 1757165031
          },
          "id": {
            "type": "string",
            "description": "ID de la tâche",
            "example": "task-unified-1757165031-mjv7"
          },
          "model": {
            "type": "string",
            "description": "Nom du modèle utilisé",
            "example": "mj-v7-variation"
          },
          "object": {
            "type": "string",
            "enum": [
              "image.generation.task"
            ],
            "description": "Type de tâche"
          },
          "progress": {
            "type": "integer",
            "description": "Pourcentage de progression (0-100)",
            "minimum": 0,
            "maximum": 100,
            "example": 0
          },
          "status": {
            "type": "string",
            "description": "Statut de la tâche",
            "enum": [
              "pending",
              "processing",
              "completed",
              "failed"
            ],
            "example": "pending"
          },
          "task_info": {
            "$ref": "#/components/schemas/TaskInfo",
            "description": "Informations de tâche asynchrone"
          },
          "type": {
            "type": "string",
            "enum": [
              "text",
              "image",
              "audio",
              "video"
            ],
            "description": "Type de sortie",
            "example": "image"
          },
          "usage": {
            "$ref": "#/components/schemas/Usage",
            "description": "Informations d'utilisation et de facturation"
          }
        }
      },
      "TaskInfo": {
        "type": "object",
        "properties": {
          "can_cancel": {
            "type": "boolean",
            "description": "Si la tâche peut être annulée",
            "example": true
          },
          "estimated_time": {
            "type": "integer",
            "description": "Temps d'achèvement estimé (secondes)",
            "minimum": 0,
            "example": 45
          }
        }
      },
      "Usage": {
        "type": "object",
        "description": "Informations d'utilisation et de facturation",
        "properties": {
          "billing_rule": {
            "type": "string",
            "description": "Règle de facturation",
            "enum": [
              "per_call",
              "per_token",
              "per_second"
            ],
            "example": "per_call"
          },
          "credits_reserved": {
            "type": "number",
            "description": "Crédits estimés consommés",
            "minimum": 0,
            "example": 1.8
          },
          "user_group": {
            "type": "string",
            "description": "Groupe d'utilisateurs",
            "example": "default"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "object",
            "properties": {
              "code": {
                "type": "string",
                "description": "Identifiant du code d'erreur"
              },
              "message": {
                "type": "string",
                "description": "Message d'erreur"
              },
              "type": {
                "type": "string",
                "description": "Type d'erreur"
              }
            }
          }
        }
      }
    }
  }
}
