          },
          "input_sensitive_type": {
            "type": "integer",
            "description": "Type de mot sensible déclenché par l'entrée (renvoyé lorsque `input_sensitive` est true) : 1 violation grave ; 2 pornographie ; 3 publicité ; 4 contenu interdit ; 5 langage injurieux ; 6 violence/terrorisme ; 7 autre"
          },
          "output_sensitive": {
            "type": "boolean",
            "description": "Indique si le contenu de sortie a déclenché un filtre de mots sensibles"
