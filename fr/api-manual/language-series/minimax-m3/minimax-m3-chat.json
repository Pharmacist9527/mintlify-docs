{
  "openapi": "3.1.0",
  "info": {
    "title": "Référence complète de l'API MiniMax-M3 (compatible OpenAI)",
    "description": "Référence complète de l'API pour l'interface de conversation MiniMax-M3.\n\n**Capacités du modèle** :\n- Sortie maximale : **524 288 tokens** (512K), recommandé **131 072 tokens** (128K)\n- Mode réflexion : contrôlé via le champ `thinking`, par défaut `adaptive` (le modèle décide de manière adaptative s'il doit engager une réflexion approfondie)\n- Entrée multimodale : prend en charge le texte, les images et la vidéo\n- Appel d'outils : prend en charge le Function Calling\n- Sortie en streaming : prend en charge les réponses en streaming SSE",
    "license": {
      "name": "MIT"
    },
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://direct.evolink.ai",
      "description": "Production (recommandée)"
    },
    {
      "url": "https://api.evolink.ai",
      "description": "URL alternative"
    }
  ],
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "paths": {
    "/v1/chat/completions": {
      "post": {
        "summary": "Interface de conversation MiniMax-M3 (compatible OpenAI)",
        "description": "- Utilisez le protocole OpenAI Chat Completions pour appeler le modèle MiniMax-M3\n- **Conversation multi-tours** : prend en charge le dialogue contextuel sur un ou plusieurs tours\n- **Invites système** : personnalisez le rôle et le comportement de l'IA via des messages `role=system`\n- **Entrée multimodale** : `content` prend en charge un mélange de texte + image / vidéo\n- **Mode réflexion** : contrôlé via `thinking.type` ; le contenu de réflexion est renvoyé via `reasoning_content`\n- **Sortie en streaming** : prend en charge les réponses en streaming SSE\n- **Appel d'outils** : prend en charge le Function Calling",
        "operationId": "createChatCompletionMiniMaxM3",
        "tags": [
          "Génération de conversation"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ChatCompletionRequest"
              },
              "examples": {
                "simple_text": {
                  "summary": "Conversation textuelle sur un seul tour",
                  "value": {
                    "model": "MiniMax-M3",
                    "messages": [
                      {
                        "role": "user",
                        "content": "Veuillez vous présenter"
                      }
                    ]
                  }
                },
                "multi_turn": {
                  "summary": "Conversation multi-tours (compréhension du contexte)",
                  "value": {
                    "model": "MiniMax-M3",
                    "messages": [
                      {
                        "role": "user",
                        "content": "Qu'est-ce que Python ?"
                      },
                      {
                        "role": "assistant",
                        "content": "Python est un langage de programmation de haut niveau..."
                      },
                      {
                        "role": "user",
                        "content": "Quels sont ses avantages ?"
                      }
                    ]
                  }
                },
                "system_prompt": {
                  "summary": "Utilisation des invites système",
                  "value": {
                    "model": "MiniMax-M3",
                    "messages": [
                      {
                        "role": "system",
                        "content": "Vous êtes un assistant de programmation Python professionnel. Répondez aux questions de manière concise."
                      },
                      {
                        "role": "user",
                        "content": "Comment lire un fichier ?"
                      }
                    ]
                  }
                },
                "image_understanding": {
                  "summary": "Compréhension d'images (entrée multimodale)",
                  "value": {
                    "model": "MiniMax-M3",
                    "thinking": {
                      "type": "adaptive"
                    },
                    "messages": [
                      {
                        "role": "user",
                        "content": [
                          {
                            "type": "text",
                            "text": "Qu'y a-t-il dans cette image ?"
                          },
                          {
                            "type": "image_url",
                            "image_url": {
                              "url": "https://example.com/image.jpeg"
                            }
                          }
                        ]
                      }
                    ],
                    "max_completion_tokens": 500
                  }
                },
                "disable_thinking": {
                  "summary": "Désactiver le mode réflexion (réponse directe)",
                  "value": {
                    "model": "MiniMax-M3",
                    "thinking": {
                      "type": "disabled"
                    },
                    "messages": [
                      {
                        "role": "user",
                        "content": "Quelle est la capitale de la France ?"
                      }
                    ]
                  }
                },
                "tool_calling": {
                  "summary": "Function Calling (appel d'outil)",
                  "value": {
                    "model": "MiniMax-M3",
                    "messages": [
                      {
                        "role": "user",
                        "content": "Consulte la météo à Pékin aujourd'hui"
                      }
                    ],
                    "tools": [
                      {
                        "type": "function",
                        "function": {
                          "name": "get_weather",
                          "description": "Interroger les conditions météorologiques d'une ville donnée",
                          "parameters": {
                            "type": "object",
                            "properties": {
                              "location": {
                                "type": "string",
                                "description": "Nom de la ville, par exemple : Pékin"
                              }
                            },
                            "required": [
                              "location"
                            ]
                          }
                        }
                      }
                    ]
                  }
                },
                "streaming": {
                  "summary": "Sortie en streaming",
                  "value": {
                    "model": "MiniMax-M3",
                    "stream": true,
                    "stream_options": {
                      "include_usage": true
                    },
                    "messages": [
                      {
                        "role": "user",
                        "content": "Écris un court poème sur le printemps"
                      }
                    ]
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Génération de conversation réussie",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ChatCompletionResponse"
                },
                "examples": {
                  "default_thinking": {
                    "summary": "Par défaut (réflexion intégrée dans content au sein de balises <think>)",
                    "value": {
                      "id": "066b36619b147e326d17053cccdef70f",
                      "choices": [
                        {
                          "finish_reason": "stop",
                          "index": 0,
                          "message": {
                            "content": "<think>\nL'utilisateur pose une question sur la capitale de la France, ce qui relève d'une connaissance générale. La réponse est Paris.\n</think>\nLa capitale de la France est **Paris**.",
                            "role": "assistant",
                            "name": "MiniMax AI",
                            "audio_content": ""
                          }
                        }
                      ],
                      "created": 1777026807,
                      "model": "MiniMax-M3",
                      "object": "chat.completion",
                      "usage": {
                        "total_tokens": 60,
                        "total_characters": 0,
                        "prompt_tokens": 7,
                        "completion_tokens": 53,
                        "prompt_tokens_details": {
                          "cached_tokens": 0
                        }
                      },
                      "input_sensitive": false,
                      "output_sensitive": false,
                      "input_sensitive_type": 0,
                      "output_sensitive_type": 0,
                      "base_resp": {
                        "status_code": 0,
                        "status_msg": ""
                      }
                    }
                  },
                  "tool_calls": {
                    "summary": "Appel d'outil déclenché (finish_reason=tool_calls)",
                    "value": {
                      "id": "066b13db03518f86c2e3c9b073c04272",
                      "choices": [
                        {
                          "finish_reason": "tool_calls",
                          "index": 0,
                          "message": {
                            "content": "<think>\nL'utilisateur souhaite consulter la météo à Pékin, j'appelle l'outil get_weather.\n</think>\nJe vais consulter la météo actuelle à Pékin pour vous.",
                            "role": "assistant",
                            "name": "MiniMax AI",
                            "tool_calls": [
                              {
                                "id": "call_function_p4iiqtpnh5bj_1",
                                "type": "function",
                                "function": {
                                  "name": "get_weather",
                                  "arguments": "{\"location\": \"Pékin\"}"
                                },
                                "index": 0
                              }
                            ],
                            "audio_content": ""
                          }
                        }
                      ],
                      "created": 1777026900,
                      "model": "MiniMax-M3",
                      "object": "chat.completion",
                      "usage": {
                        "total_tokens": 110,
                        "total_characters": 0,
                        "prompt_tokens": 86,
                        "completion_tokens": 24,
                        "prompt_tokens_details": {
                          "cached_tokens": 0
                        }
                      },
                      "input_sensitive": false,
                      "output_sensitive": false,
                      "input_sensitive_type": 0,
                      "output_sensitive_type": 0,
                      "base_resp": {
                        "status_code": 0,
                        "status_msg": ""
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Paramètres de requête invalides",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "error": {
                    "code": 400,
                    "message": "Invalid request parameters",
                    "type": "invalid_request_error"
                  }
                }
              }
            }
          },
          "401": {
            "description": "Non authentifié, token invalide ou expiré",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "error": {
                    "code": 401,
                    "message": "Invalid or expired token",
                    "type": "authentication_error"
                  }
                }
              }
            }
          },
          "402": {
            "description": "Quota insuffisant, recharge requise",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "error": {
                    "code": 402,
                    "message": "Insufficient quota",
                    "type": "insufficient_quota_error"
                  }
                }
              }
            }
          },
          "403": {
            "description": "Accès refusé pour ce modèle",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "error": {
                    "code": 403,
                    "message": "Access denied for this model",
                    "type": "permission_error",
                    "param": "model"
                  }
                }
              }
            }
          },
          "404": {
            "description": "Ressource introuvable",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "error": {
                    "code": 404,
                    "message": "Specified model not found",
                    "type": "not_found_error",
                    "param": "model"
                  }
                }
              }
            }
          },
          "413": {
            "description": "Corps de requête trop volumineux",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "error": {
                    "code": 413,
                    "message": "Request body too large",
                    "type": "request_too_large_error",
                    "param": "messages"
                  }
                }
              }
            }
          },
          "429": {
            "description": "Limite de fréquence dépassée",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "error": {
                    "code": 429,
                    "message": "Rate limit exceeded",
                    "type": "rate_limit_error"
                  }
                }
              }
            }
          },
          "500": {
            "description": "Erreur interne du serveur",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "error": {
                    "code": 500,
                    "message": "Internal server error",
                    "type": "internal_server_error"
                  }
                }
              }
            }
          },
          "502": {
            "description": "Passerelle incorrecte",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "error": {
                    "code": 502,
                    "message": "Bad gateway",
                    "type": "bad_gateway_error"
                  }
                }
              }
            }
          },
          "503": {
            "description": "Service temporairement indisponible",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "error": {
                    "code": 503,
                    "message": "Service temporarily unavailable",
                    "type": "service_unavailable_error"
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "ChatCompletionRequest": {
        "type": "object",
        "required": [
          "model",
          "messages"
        ],
        "properties": {
          "model": {
            "type": "string",
            "description": "Nom du modèle de conversation",
            "enum": [
              "MiniMax-M3"
            ],
            "example": "MiniMax-M3"
          },
          "messages": {
            "type": "array",
            "description": "Liste des messages de la conversation, prend en charge le dialogue multi-tours\n\nLes messages de rôles différents ont des structures de champs différentes ; sélectionnez le rôle correspondant pour le consulter",
            "items": {
              "oneOf": [
                {
                  "$ref": "#/components/schemas/SystemMessage"
                },
                {
                  "$ref": "#/components/schemas/UserMessage"
                },
                {
                  "$ref": "#/components/schemas/AssistantRequestMessage"
                },
                {
                  "$ref": "#/components/schemas/ToolMessage"
                }
              ],
              "discriminator": {
                "propertyName": "role",
                "mapping": {
                  "system": "#/components/schemas/SystemMessage",
                  "user": "#/components/schemas/UserMessage",
                  "assistant": "#/components/schemas/AssistantRequestMessage",
                  "tool": "#/components/schemas/ToolMessage"
                }
              }
            },
            "minItems": 1
          },
          "thinking": {
            "type": "object",
            "description": "Contrôle la réflexion approfondie\n\n**Remarques** :\n- **Par défaut `adaptive`** : le modèle décide de manière adaptative s'il doit engager une réflexion approfondie en fonction de la difficulté du problème\n- Par défaut, le contenu de réflexion est intégré dans le `content` de la réponse (entouré de balises `<think>...</think>`) ; pour le séparer dans un champ dédié, utilisez `reasoning_split`",
            "properties": {
              "type": {
                "type": "string",
                "description": "Mode de réflexion approfondie\n\n- `adaptive` : le modèle décide de manière autonome si une réflexion est nécessaire (valeur par défaut recommandée)\n- `disabled` : désactive la réflexion, répond directement",
                "enum": [
                  "disabled",
                  "adaptive"
                ],
                "default": "adaptive"
              }
            }
          },
          "reasoning_split": {
            "type": "boolean",
            "description": "Indique s'il faut séparer le contenu de réflexion dans un champ distinct\n\n- `false` (par défaut) : le contenu de réflexion est intégré dans `content`, entouré de balises `<think>...</think>`\n- `true` : le contenu de réflexion est séparé dans `choices[].message.reasoning_content` et `reasoning_details`"
          },
          "temperature": {
            "type": "number",
            "description": "Température d'échantillonnage, contrôle le caractère aléatoire de la sortie\n\n**Remarques** :\n- Valeurs plus basses (par ex. 0.2) : sortie plus déterministe et plus ciblée\n- Valeurs plus élevées (par ex. 1.5) : sortie plus aléatoire et plus créative\n- Plage : `[0, 2]`, par défaut 1",
            "minimum": 0,
            "maximum": 2,
            "default": 1,
            "example": 1
          },
          "top_p": {
            "type": "number",
            "description": "Paramètre d'échantillonnage par noyau (Nucleus Sampling)\n\n**Remarques** :\n- Contrôle l'échantillonnage parmi les tokens en fonction de leur probabilité cumulée\n- Par ex. 0.95 signifie une sélection parmi les tokens atteignant 95 % de probabilité cumulée\n- Plage : `[0, 1]`, MiniMax-M3 par défaut 0.95\n\n**Recommandation** : n'ajustez pas simultanément temperature et top_p",
            "minimum": 0,
            "maximum": 1,
            "default": 0.95,
            "example": 0.95
          },
          "max_completion_tokens": {
            "type": "integer",
            "description": "Limite supérieure de la longueur du contenu généré (en tokens)\n\n**Remarques** :\n- MiniMax-M3 recommandé **131 072** (128K), maximum **524 288** (512K)\n- Les tokens générés par la réflexion comptent également dans cette limite\n- Si la génération est interrompue pour cause de `length`, essayez d'augmenter cette valeur",
            "minimum": 1,
            "maximum": 524288,
            "example": 131072
          },
          "stream": {
            "type": "boolean",
            "description": "Indique s'il faut renvoyer la réponse en mode streaming\n\n- `true` : réponse en streaming, renvoie le contenu en temps réel par blocs via SSE (Server-Sent Events)\n- `false` : attend la réponse complète avant de la renvoyer (par défaut)",
            "default": false,
            "example": false
          },
          "stream_options": {
            "type": "object",
            "description": "Options de réponse en streaming\n\nN'a d'effet que lorsque `stream=true`",
            "properties": {
              "include_usage": {
                "type": "boolean",
                "description": "Renvoie un bloc supplémentaire contenant uniquement les statistiques `usage` à la fin du flux"
              }
            }
          },
          "tools": {
            "type": "array",
            "description": "Liste de définitions d'outils pour le Function Calling\n\nChaque outil requiert un nom, une description et un schéma de paramètres",
            "items": {
              "$ref": "#/components/schemas/Tool"
            }
          },
          "max_tokens": {
            "type": "integer",
            "description": "Ancien paramètre de limite de longueur de génération\n\n**Remarque** : obsolète, veuillez utiliser `max_completion_tokens` à la place",
            "deprecated": true,
            "minimum": 1
          }
        }
      },
      "SystemMessage": {
        "title": "System Message",
        "type": "object",
        "required": [
          "role",
          "content"
        ],
        "properties": {
          "role": {
            "type": "string",
            "enum": [
              "system"
            ],
            "description": "Identifiant de rôle, fixé à `system`"
          },
          "content": {
            "type": "string",
            "description": "Contenu de l'invite système, utilisé pour définir le rôle et le comportement de l'IA"
          },
          "name": {
            "type": "string",
            "description": "Nom du participant, utilisé pour distinguer les différentes sources d'invites système"
          }
        }
      },
      "UserMessage": {
        "title": "User Message",
        "type": "object",
        "required": [
          "role",
          "content"
        ],
        "properties": {
          "role": {
            "type": "string",
            "enum": [
              "user"
            ],
            "description": "Identifiant de rôle, fixé à `user`"
          },
          "content": {
            "description": "Contenu du message utilisateur\n\n**Remarques** :\n- Pour du texte brut, transmettez directement une chaîne\n- Pour le multimodal, transmettez un tableau de parties de contenu prenant en charge `text` / `image_url` (images, vidéo)",
            "oneOf": [
              {
                "type": "string"
              },
              {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/ContentPart"
                }
              }
            ]
          },
          "name": {
            "type": "string",
            "description": "Nom du participant, utilisé pour distinguer les différents utilisateurs"
          }
        }
      },
      "ContentPart": {
        "type": "object",
        "description": "Partie de contenu multimodal. Déclarez le type via `type` et ne renseignez que les champs correspondant à ce type",
        "properties": {
          "type": {
            "type": "string",
            "enum": [
              "text",
              "image_url",
              "video_url"
            ],
            "description": "Type de contenu\n\n- `text` : bloc de texte\n- `image_url` : entrée d'image\n- `video_url` : entrée vidéo"
          },
          "text": {
            "type": "string",
            "description": "Contenu textuel lorsque `type=text`"
          },
          "image_url": {
            "type": "object",
            "description": "Entrée d'image (lorsque `type=image_url`). Maximum 10 Mo par image, prend en charge JPEG / PNG / GIF / WEBP",
            "required": [
              "url"
            ],
            "properties": {
              "url": {
                "type": "string",
                "description": "URL de l'image, ou une data URL base64 commençant par `data:`"
              },
              "detail": {
                "type": "string",
                "description": "Contrôle la résolution d'analyse de l'image\n\n- `low` : faible précision, consomme moins de tokens\n- `default` : précision par défaut\n- `high` : haute précision, reconnaît plus de détails mais consomme plus de tokens",
                "enum": [
                  "low",
                  "default",
                  "high"
                ],
                "default": "default"
              },
              "max_long_side_pixel": {
                "type": "integer",
                "description": "Limite de pixels maximale pour le côté le plus long de l'image",
                "minimum": 1
              }
            }
          },
          "video_url": {
            "type": "object",
            "description": "Entrée vidéo (lorsque `type=video_url`). Maximum 50 Mo pour une vidéo en URL / Base64, prend en charge MP4 / AVI / MOV / MKV",
            "required": [
              "url"
            ],
            "properties": {
              "url": {
                "type": "string",
                "description": "URL de la vidéo, une data URL base64 commençant par `data:`, ou une référence de fichier au format `mm_file://{file_id}`"
              },
              "detail": {
                "type": "string",
                "description": "Contrôle la résolution d'extraction des images de la vidéo",
                "enum": [
                  "low",
                  "default",
                  "high"
                ],
                "default": "default"
              },
              "fps": {
                "type": "number",
                "description": "Fréquence d'extraction des images de la vidéo, par défaut 1, plage [0.2, 5]\n\n- Valeurs plus élevées : plus sensible aux changements visuels, coût en tokens plus élevé et vitesse plus lente\n- Valeurs plus basses : coût en tokens plus faible et vitesse plus rapide, mais moins sensible aux changements visuels",
                "minimum": 0.2,
                "maximum": 5,
                "default": 1
              },
              "max_long_side_pixel": {
                "type": "integer",
                "description": "Limite de pixels maximale pour le côté le plus long des images de la vidéo",
                "minimum": 1
              }
            }
          }
        }
      },
      "AssistantRequestMessage": {
        "title": "Assistant Message",
        "type": "object",
        "required": [
          "role"
        ],
        "properties": {
          "role": {
            "type": "string",
            "enum": [
              "assistant"
            ],
            "description": "Identifiant de rôle, fixé à `assistant`"
          },
          "content": {
            "type": [
              "string",
              "null"
            ],
            "description": "Contenu du message de l'assistant\n\n**Remarques** :\n- Utilisé pour transmettre les réponses historiques de l'assistant dans les conversations multi-tours\n- Peut être `null` lorsque `tool_calls` est présent"
          },
          "name": {
            "type": "string",
            "description": "Nom du participant"
          },
          "tool_calls": {
            "type": "array",
            "description": "Liste des appels d'outils\n\nUtilisée pour transmettre les informations historiques d'appels d'outils dans les conversations multi-tours",
            "items": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "string",
