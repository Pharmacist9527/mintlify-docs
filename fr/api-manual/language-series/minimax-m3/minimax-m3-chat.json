                "type": {
                  "type": "string",
                  "enum": [
                    "function"
                  ]
                },
                "function": {
                  "type": "object",
                  "properties": {
                    "name": {
                      "type": "string",
                      "description": "Nom de la fonction appelée"
                    },
                    "arguments": {
                      "type": "string",
                      "description": "Arguments de la fonction (chaîne JSON)"
