      "ChatCompletionResponse": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Identifiant unique de la complétion de conversation",
            "example": "0668a381bdc3c0ded310e27c9a46d16e7"
          },
          "model": {
            "type": "string",
            "description": "Nom du modèle réellement utilisé",
