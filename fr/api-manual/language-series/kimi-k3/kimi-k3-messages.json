{
  "openapi": "3.1.0",
  "info": {
    "title": "Kimi K3 - API compatible Anthropic",
    "description": "Appelez Kimi K3 via le protocole Anthropic Messages.\n\n**Fonctionnalités confirmées pour la première version** :\n- ID du modèle : `kimi-k3`\n- Point de terminaison : `POST /v1/messages`\n- Authentification avec une clé API EvoLink en Bearer Token\n- Prend en charge les prompts système, les conversations textuelles multi-tours, le streaming SSE et les outils\n- Prend en charge l'entrée multimodale (image) : le contenu user reçoit un bloc de contenu image\n- Les réponses peuvent contenir des blocs `thinking`, `text` et `tool_use`\n\nPour une conversation multi-tour, renvoyez sans modification les blocs assistant complets, y compris thinking, signature et tool_use.",
    "license": {
      "name": "MIT"
    },
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://direct.evolink.ai",
      "description": "Production (Recommandé)"
    },
    {
      "url": "https://api.evolink.ai",
      "description": "URL alternative"
    }
  ],
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "paths": {
    "/v1/messages": {
      "post": {
        "summary": "API Messages Kimi K3 (compatible Anthropic)",
        "description": "Appelez `kimi-k3` via Anthropic Messages. Prend en charge le JSON non diffusé et les flux d'événements Anthropic SSE.",
        "operationId": "createMessageKimiK3",
        "tags": [
          "Messages"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateMessageRequest"
              },
              "examples": {
                "simple": {
                  "summary": "Requête minimale",
                  "value": {
                    "model": "kimi-k3",
                    "max_tokens": 1024,
                    "messages": [
                      {
                        "role": "user",
                        "content": "Présente Kimi K3 en trois phrases."
                      }
                    ]
                  }
                },
                "multimodal": {
                  "summary": "Entrée multimodale (image + texte)",
                  "value": {
                    "model": "kimi-k3",
                    "max_tokens": 1024,
                    "messages": [
                      {
                        "role": "user",
                        "content": [
                          {
                            "type": "image",
                            "source": {
                              "type": "base64",
                              "media_type": "image/jpeg",
                              "data": "/9j/4AAQSkZJRgABAQAA..."
                            }
                          },
                          {
                            "type": "text",
                            "text": "Décris cette image."
                          }
                        ]
                      }
                    ]
                  }
                },
                "system_prompt": {
                  "summary": "Prompt système",
                  "value": {
                    "model": "kimi-k3",
                    "max_tokens": 2048,
                    "system": "Vous êtes un rédacteur technique précis.",
                    "messages": [
                      {
                        "role": "user",
                        "content": "Explique la mise en cache du contexte."
                      }
                    ]
                  }
                },
                "streaming": {
                  "summary": "Sortie SSE en streaming",
                  "value": {
                    "model": "kimi-k3",
                    "max_tokens": 1024,
                    "stream": true,
                    "messages": [
                      {
                        "role": "user",
                        "content": "Écris un court poème sur une nuit d'été."
                      }
                    ]
                  }
                },
                "tool_use": {
                  "summary": "Utilisation d'outil",
                  "value": {
                    "model": "kimi-k3",
                    "max_tokens": 2048,
                    "messages": [
                      {
                        "role": "user",
                        "content": "Consulte la météo du jour à Pékin."
                      }
                    ],
                    "tools": [
                      {
                        "name": "get_weather",
                        "description": "Obtenir la météo d'une ville donnée",
                        "input_schema": {
                          "type": "object",
                          "properties": {
                            "city": {
                              "type": "string",
                              "description": "Nom de la ville"
                            }
                          },
                          "required": [
                            "city"
                          ]
                        }
                      }
                    ],
                    "tool_choice": {
                      "type": "auto"
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Réponse Message ; les requêtes en streaming renvoient un flux d'événements Anthropic SSE",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MessageResponse"
                }
              },
              "text/event-stream": {
                "schema": {
                  "type": "string",
                  "description": "La séquence d'événements comprend généralement message_start, content_block_*, message_delta et message_stop."
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "429": {
            "$ref": "#/components/responses/RateLimited"
          },
          "500": {
            "$ref": "#/components/responses/InternalError"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "CreateMessageRequest": {
        "type": "object",
        "required": [
          "model",
          "max_tokens",
          "messages"
        ],
        "properties": {
          "model": {
            "type": "string",
            "enum": [
              "kimi-k3"
            ],
            "description": "ID du modèle."
          },
          "max_tokens": {
            "type": "integer",
            "minimum": 1,
            "description": "Nombre maximal de tokens autorisés pour cette génération, y compris thinking et le texte final."
          },
          "messages": {
            "type": "array",
            "minItems": 1,
            "description": "Liste de messages Anthropic Messages. Pour une conversation multi-tour, renvoyez les blocs de contenu assistant complets sans modification.",
            "items": {
              "$ref": "#/components/schemas/Message"
            }
          },
          "system": {
            "type": "string",
            "description": "Prompt système. Le protocole Messages utilise un champ system de premier niveau au lieu d'un rôle system."
          },
          "stream": {
            "type": "boolean",
            "default": false,
            "description": "Indique si un flux d'événements Anthropic SSE est renvoyé."
          },
          "tools": {
            "type": "array",
            "description": "Outils que le modèle peut appeler.",
            "items": {
              "$ref": "#/components/schemas/Tool"
            }
          },
          "tool_choice": {
            "$ref": "#/components/schemas/ToolChoice"
          }
        }
      },
      "Message": {
        "type": "object",
        "required": [
          "role",
          "content"
        ],
        "properties": {
          "role": {
            "type": "string",
            "description": "Rôle du message. Seuls user et assistant sont pris en charge.",
            "enum": [
              "user",
              "assistant"
            ]
          },
          "content": {
            "description": "Contenu du message sous forme de texte brut ou de tableau de blocs de contenu Anthropic.",
            "oneOf": [
              {
                "type": "string"
              },
              {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/ContentBlock"
                }
              }
            ]
          }
        }
      },
      "ContentBlock": {
        "description": "Bloc de contenu Anthropic pour le texte, l'image, le raisonnement, l'appel d'outil ou le résultat d'outil.",
        "oneOf": [
          {
            "$ref": "#/components/schemas/TextBlock"
          },
          {
            "$ref": "#/components/schemas/ImageBlock"
          },
          {
            "$ref": "#/components/schemas/ThinkingBlock"
          },
          {
            "$ref": "#/components/schemas/ToolUseBlock"
          },
          {
            "$ref": "#/components/schemas/ToolResultBlock"
          }
        ]
      },
      "TextBlock": {
        "type": "object",
        "required": [
          "type",
          "text"
        ],
        "properties": {
          "type": {
            "type": "string",
            "description": "Type de bloc de contenu. Valeur fixe : text.",
            "enum": [
              "text"
            ]
          },
          "text": {
            "type": "string",
            "description": "Contenu textuel."
          }
        }
      },
      "ImageBlock": {
        "type": "object",
        "required": [
          "type",
          "source"
        ],
        "description": "Bloc de contenu image (entrée multimodale).",
        "properties": {
          "type": {
            "type": "string",
            "enum": [
              "image"
            ],
            "description": "Type de bloc de contenu. Valeur fixe : image."
          },
          "source": {
            "type": "object",
            "required": [
              "type"
            ],
            "description": "Source de l'image.",
            "properties": {
              "type": {
                "type": "string",
                "enum": [
                  "base64",
                  "url"
                ],
                "description": "Type de source : `base64` pour un encodage en ligne, ou `url` pour un lien."
              },
              "media_type": {
                "type": "string",
                "enum": [
                  "image/jpeg",
                  "image/png",
                  "image/gif",
                  "image/webp"
                ],
                "description": "Type MIME de l'image lorsque `type=base64`."
              },
              "data": {
                "type": "string",
                "description": "Données Base64 de l'image lorsque `type=base64` (sans le préfixe `data:`)."
              },
              "url": {
                "type": "string",
                "description": "Adresse de l'image lorsque `type=url` ; prend aussi en charge la référence de fichier Kimi `ms://<file_id>`."
              }
            }
          }
        }
      },
      "ThinkingBlock": {
        "type": "object",
        "required": [
          "type",
          "thinking"
        ],
        "properties": {
          "type": {
            "type": "string",
            "description": "Type de bloc de contenu. Valeur fixe : thinking.",
            "enum": [
              "thinking"
            ]
          },
          "thinking": {
            "type": "string",
            "description": "Contenu de raisonnement du modèle. Renvoyez-le sans modification avec la signature dans les conversations multi-tours."
          },
          "signature": {
            "type": "string",
            "description": "Pour une conversation multi-tour, renvoyez cette valeur sans modification avec le bloc thinking."
          }
        }
      },
      "ToolUseBlock": {
        "type": "object",
        "required": [
          "type",
          "id",
          "name",
          "input"
        ],
        "properties": {
          "type": {
            "type": "string",
            "description": "Type de bloc de contenu. Valeur fixe : tool_use.",
            "enum": [
              "tool_use"
            ]
          },
          "id": {
            "type": "string",
            "description": "ID tool_use référencé lors du renvoi du résultat."
          },
          "name": {
            "type": "string",
            "description": "Nom de l'outil demandé par le modèle."
          },
          "input": {
            "type": "object",
            "additionalProperties": true,
            "description": "Objet d'entrée d'outil généré par le modèle."
          }
        }
      },
      "ToolResultBlock": {
        "type": "object",
        "required": [
          "type",
          "tool_use_id",
          "content"
        ],
        "properties": {
          "type": {
            "type": "string",
            "description": "Type de bloc de contenu. Valeur fixe : tool_result.",
            "enum": [
              "tool_result"
            ]
          },
          "tool_use_id": {
            "type": "string",
            "description": "ID du bloc tool_use correspondant."
          },
          "content": {
            "type": "string",
            "description": "Résultat de l'exécution de l'outil."
          },
          "is_error": {
            "type": "boolean",
            "default": false,
            "description": "Indique si l'exécution de l'outil a échoué."
          }
        }
      },
      "Tool": {
        "type": "object",
        "required": [
          "name",
          "input_schema"
        ],
        "properties": {
          "name": {
            "type": "string",
            "description": "Nom de l'outil."
          },
          "description": {
            "type": "string",
            "description": "Description aidant le modèle à décider quand utiliser l'outil."
          },
          "input_schema": {
            "type": "object",
            "additionalProperties": true,
            "description": "Définition des paramètres de l'outil au format JSON Schema."
          }
        }
      },
      "ToolChoice": {
        "type": "object",
        "required": [
          "type"
        ],
        "properties": {
          "type": {
            "type": "string",
            "description": "Stratégie de sélection : auto laisse le modèle décider, any impose un outil et tool impose l'outil nommé.",
            "enum": [
              "auto",
              "any",
              "tool"
            ]
          },
          "name": {
            "type": "string",
            "description": "Nom de l'outil à appeler lorsque type=tool."
          }
        }
      },
      "MessageResponse": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "type": {
            "type": "string",
            "enum": [
              "message"
            ]
          },
          "role": {
            "type": "string",
            "enum": [
              "assistant"
            ]
          },
          "model": {
            "type": "string",
            "example": "kimi-k3"
          },
          "content": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ContentBlock"
            }
          },
          "stop_reason": {
            "type": "string",
            "enum": [
              "end_turn",
              "max_tokens",
              "tool_use"
            ]
          },
          "stop_sequence": {
            "type": [
              "string",
              "null"
            ]
          },
          "usage": {
            "$ref": "#/components/schemas/MessageUsage"
          }
        }
      },
      "MessageUsage": {
        "type": "object",
        "properties": {
          "input_tokens": {
            "type": "integer",
            "description": "Tokens d'entrée non servis depuis le cache."
          },
          "cache_creation_input_tokens": {
            "type": "integer",
            "description": "Tokens d'entrée écrits dans le cache."
          },
          "cache_read_input_tokens": {
            "type": "integer",
            "description": "Tokens d'entrée servis depuis le cache."
          },
          "output_tokens": {
            "type": "integer",
            "description": "Tokens de sortie, y compris les tokens thinking."
          },
          "output_tokens_details": {
            "type": "object",
            "properties": {
              "thinking_tokens": {
                "type": "integer"
              }
            }
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "enum": [
              "error"
            ]
          },
          "error": {
            "type": "object",
            "properties": {
              "type": {
                "type": "string"
              },
              "message": {
                "type": "string"
              }
            }
          },
          "request_id": {
            "type": "string"
          }
        }
      }
    },
    "responses": {
      "BadRequest": {
        "description": "Paramètres de requête invalides",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          }
        }
      },
      "Unauthorized": {
        "description": "La clé API est absente ou invalide",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          }
        }
      },
      "RateLimited": {
        "description": "Limite de débit dépassée ou quota insuffisant",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          }
        }
      },
      "InternalError": {
        "description": "Erreur interne du service",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          }
        }
      }
    },
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "##Toutes les API nécessitent une authentification par Bearer Token##\n\n**Obtenir une clé API :**\n\nVisitez la [page de gestion des clés API](https://evolink.ai/dashboard/keys) pour obtenir votre clé API\n\n**Ajouter à l'en-tête de requête :**\n```\nAuthorization: Bearer YOUR_API_KEY\n```"
      }
    }
  },
  "tags": [
    {
      "name": "Messages",
      "description": "API compatible Anthropic Messages"
    }
  ]
}
