{
  "openapi": "3.1.0",
  "info": {
    "title": "API de quota de fichiers",
    "description": "Interroger l'utilisation des fichiers et le quota restant de l'utilisateur actuel",
    "license": {
      "name": "MIT"
    },
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://files-api.evolink.ai",
      "description": "Environnement du service de fichiers"
    }
  ],
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "paths": {
    "/api/v1/files/quota": {
      "get": {
        "summary": "Consulter le quota de fichiers",
        "description": "- Interroger l'utilisation des fichiers et le quota restant de l'utilisateur actuel\n- Le groupe d'utilisateurs par défaut autorise jusqu'à `2000` fichiers\n\n**Remarque :**\nL'URL de base pour les API de fichiers est `https://files-api.evolink.ai`",
        "operationId": "getFilesQuota",
        "tags": [
          "Gestion des fichiers"
        ],
        "responses": {
          "200": {
            "description": "Succès",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/QuotaResponse"
                },
                "example": {
                  "success": true,
                  "code": 200,
                  "data": {
                    "user_group": "default",
                    "used_files": 35,
                    "max_files": 2000,
                    "remain_files": 65,
                    "is_custom": false,
                    "quota_reason": ""
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "QuotaResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean",
            "description": "Whether the request was successful",
            "example": true
          },
          "code": {
            "type": "integer",
            "description": "Response status code",
            "example": 200
          },
          "data": {
            "$ref": "#/components/schemas/QuotaData"
          }
        }
      },
      "QuotaData": {
        "type": "object",
        "properties": {
          "user_group": {
            "type": "string",
            "description": "Groupe d'utilisateurs : `default` (2000 fichiers)",
            "example": "default"
          },
          "used_files": {
            "type": "integer",
            "description": "Nombre de fichiers actuellement stockés",
            "example": 35
          },
          "max_files": {
            "type": "integer",
            "description": "Nombre maximum de fichiers autorisés",
            "example": 2000
          },
          "remain_files": {
            "type": "integer",
            "description": "Emplacements d'upload restants",
            "example": 65
          },
          "is_custom": {
            "type": "boolean",
            "description": "Indique si le quota a été défini manuellement par un administrateur",
            "example": false
          },
          "quota_reason": {
            "type": "string",
            "description": "Raison du quota personnalisé (uniquement défini quand `is_custom` est `true`)",
            "example": ""
          }
        }
      }
    },
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "##Toutes les API nécessitent une authentification Bearer Token##\n\n**Obtenir une clé API :**\n\nVisitez la [Page de gestion des clés API](https://evolink.ai/dashboard/keys) pour obtenir votre clé API\n\n**Ajouter à l'en-tête de requête :**\n```\nAuthorization: Bearer YOUR_API_KEY\n```"
      }
    }
  },
  "tags": [
    {
      "name": "Gestion des fichiers",
      "description": "APIs de gestion des fichiers"
    }
  ]
}
