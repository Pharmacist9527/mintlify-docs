{
  "openapi": "3.1.0",
  "info": {
    "title": "API d'obtention des détails de la tâche",
    "description": "Interroger le statut, la progression et les résultats des tâches asynchrones par ID de tâche",
    "license": {
      "name": "MIT"
    },
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://api.evolink.ai",
      "description": "Environnement de production"
    }
  ],
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "paths": {
    "/v1/tasks/{task_id}": {
      "get": {
        "summary": "Interroger le statut de la tâche",
        "description": "Interroger le statut, la progression et les résultats des tâches asynchrones par ID de tâche",
        "operationId": "getTaskDetail",
        "tags": [
          "Gestion des tâches"
        ],
        "parameters": [
          {
            "name": "task_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "ID de la tâche, ignorer {} lors de l'interrogation, ajouter l'id du corps de réponse de la tâche asynchrone à la fin du chemin",
            "example": "task-unified-1756817821-4x3rx6ny"
          }
        ],
        "responses": {
          "200": {
            "description": "Détails du statut de la tâche",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TaskDetailResponse"
                }
              }
            }
          },
          "400": {
            "description": "Erreur de paramètre de requête, erreur de format",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "error": {
                    "code": "invalid_task_id",
                    "message": "Invalid task ID format, must start with 'task-unified-'",
                    "type": "invalid_request_error",
                    "param": "task_id"
                  }
                }
              }
            }
          },
          "401": {
            "description": "Non authentifié, token invalide ou expiré",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "error": {
                    "code": "unauthorized",
                    "message": "Authentication required",
                    "type": "authentication_error"
                  }
                }
              }
            }
          },
          "402": {
            "description": "Quota insuffisant, recharge requise",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "error": {
                    "code": "quota_exceeded",
                    "message": "Insufficient quota. Please top up your account.",
                    "type": "insufficient_quota"
                  }
                }
              }
            }
          },
          "403": {
            "description": "Aucune permission d'accès",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "error": {
                    "code": "permission_denied",
                    "message": "You don't have permission to access this task",
                    "type": "invalid_request_error"
                  }
                }
              }
            }
          },
          "404": {
            "description": "La ressource n'existe pas",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "error": {
                    "code": "task_not_found",
                    "message": "The requested task could not be found",
                    "type": "invalid_request_error"
                  }
                }
              }
            }
          },
          "429": {
            "description": "Limite de débit de requêtes dépassée",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "error": {
                    "message": "Rate limit exceeded",
                    "type": "evo_api_error"
                  }
                }
              }
            }
          },
          "500": {
            "description": "Erreur interne du serveur",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "error": {
                    "code": "internal_error",
                    "message": "Failed to retrieve task status",
                    "type": "api_error"
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "TaskDetailResponse": {
        "type": "object",
        "properties": {
          "created": {
            "type": "integer",
            "description": "Horodatage de création de la tâche",
            "example": 1756817821
          },
          "id": {
            "type": "string",
            "description": "ID de tâche",
            "example": "task-unified-1756817821-4x3rx6ny"
          },
          "model": {
            "type": "string",
            "description": "Modèle utilisé",
            "example": "gemini-3.1-flash-image-preview"
          },
          "object": {
            "type": "string",
            "description": "Type de tâche",
            "enum": [
              "image.generation.task",
              "video.generation.task",
              "audio.generation.task"
            ],
            "example": "image.generation.task"
          },
          "progress": {
            "type": "integer",
            "minimum": 0,
            "maximum": 100,
            "description": "Pourcentage de progression de la tâche",
            "example": 100
          },
          "results": {
            "type": "array",
            "items": {
              "type": "string",
              "format": "uri"
            },
            "description": "Liste des résultats de la tâche (fournie une fois terminée)",
            "example": [
              "http://example.com/image.jpg"
            ]
          },
          "status": {
            "type": "string",
            "description": "Statut de la tâche",
            "enum": [
              "pending",
              "processing",
              "completed",
              "failed"
            ],
            "example": "completed"
          },
          "error": {
            "type": "object",
            "nullable": true,
            "description": "Informations d'erreur en cas d'echec de la tache (uniquement present lorsque status est \"failed\"). Remarque : error.code ici est un code d'erreur metier de type string, different des codes de statut HTTP. Consultez la Reference des Codes d'Erreur pour la liste complete.",
            "properties": {
              "code": {
                "type": "string",
                "description": "Code d'erreur metier (type string)",
                "example": "content_policy_violation"
              },
              "message": {
                "type": "string",
                "description": "Description d'erreur conviviale avec conseils de depannage",
                "example": "Content policy violation.\nYour request was blocked by safety filters."
              },
              "type": {
                "type": "string",
                "description": "Identifiant du type d'erreur, toujours \"task_error\"",
                "example": "task_error"
              }
            }
          },
          "task_info": {
            "type": "object",
            "description": "Informations détaillées de la tâche",
            "properties": {
              "can_cancel": {
                "type": "boolean",
                "description": "Si la tâche peut être annulée",
                "example": false
              }
            }
          },
          "type": {
            "type": "string",
            "description": "Type de tâche",
            "enum": [
              "image",
              "video",
              "audio",
              "text"
            ],
            "example": "image"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "object",
            "properties": {
              "code": {
                "type": "string",
                "description": "Code d'erreur (type string)",
                "example": "invalid_task_id"
              },
              "message": {
                "type": "string",
                "description": "Message de description de l'erreur",
                "example": "Invalid task ID format"
              },
              "type": {
                "type": "string",
                "description": "Type d'erreur",
                "example": "invalid_request_error"
              },
              "param": {
                "type": "string",
                "description": "Nom du paramètre concerné",
                "example": "task_id"
              }
            }
          }
        }
      }
    },
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "##Toutes les API nécessitent une authentification Bearer Token##\n\n**Obtenir une clé API :**\n\nVisitez la [Page de gestion des clés API](https://evolink.ai/dashboard/keys) pour obtenir votre clé API\n\n**Ajouter à l'en-tête de requête :**\n```\nAuthorization: Bearer YOUR_API_KEY\n```"
      }
    }
  },
  "tags": [
    {
      "name": "Gestion des tâches",
      "description": "APIs liées à la gestion des tâches asynchrones"
    }
  ]
}