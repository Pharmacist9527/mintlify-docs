{
  "openapi": "3.1.0",
  "info": {
    "title": "Midjourney V8.1 이미지 생성 인터페이스",
    "description": "Midjourney V8.1 모델을 사용하여 이미지 생성 작업을 생성합니다",
    "license": {
      "name": "MIT"
    },
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://api.evolink.ai",
      "description": "프로덕션"
    }
  ],
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "paths": {
    "/v1/images/generations": {
      "post": {
        "tags": [
          "이미지 생성"
        ],
        "summary": "Midjourney V8.1 이미지 생성 인터페이스",
        "description": "- Midjourney V8.1 모델은 자연어 프롬프트를 통해 고품질 이미지를 생성할 수 있습니다. Fast 모드는 매회 4장을 생성하고, Draft 모드는 단일 실행으로 24장의 경량 0.5K 스케치 이미지를 반환합니다\n- 텍스트-이미지 및 이미지-이미지 생성 지원 (prompt에 이미지 URL 참조)\n- V8.1 특징: 네이티브 HD 출력(`quality=hd`), 이전 세대 대비 약 5배 빠른 생성 속도, 텍스트 렌더링 개선(따옴표로 감싼 텍스트가 더 정확하게 렌더링됨), 더 강력한 프롬프트 준수\n- V7 자산 호환: 스타일 참조(`--sref`)와 오브젝트 참조(`--oref`) 지원, [프롬프트 매개변수 가이드](/ko/api-manual/image-series/midjourney/midjourney-v8-1-prompt-guide) 참고\n- 비동기 처리 모드, 반환된 작업 ID로 [상태 조회](/ko/api-manual/task-management/get-task-detail)\n- 생성된 이미지 링크는 30일간 유효하며, 가능한 빨리 저장하세요\n- 타임아웃: 약 20분\n- 매개변수 안내: 본 인터페이스는 V8.1로 고정되며 niji를 지원하지 않습니다. 속도 모드는 `model_params.speed`로 설정하고, 출력 품질은 최상위 `quality` 매개변수로 설정하세요",
        "operationId": "createMjV81ImageGeneration",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ImageGenerationRequest"
              },
              "examples": {
                "text_to_image": {
                  "summary": "텍스트에서 이미지 생성",
                  "value": {
                    "model": "mj-v8.1",
                    "prompt": "A cinematic shot of a Maine Coon cat on a neon-lit balcony --ar 16:9 --s 500",
                    "quality": "standard",
                    "model_params": {
                      "speed": "fast"
                    }
                  }
                },
                "text_to_image_hd": {
                  "summary": "텍스트에서 이미지 생성 (Fast + HD)",
                  "value": {
                    "model": "mj-v8.1",
                    "prompt": "A cinematic shot of a Maine Coon cat on a neon-lit balcony --ar 16:9 --s 500",
                    "quality": "hd",
                    "model_params": {
                      "speed": "fast"
                    }
                  }
                },
                "image_to_image": {
                  "summary": "이미지에서 이미지 생성",
                  "value": {
                    "model": "mj-v8.1",
                    "prompt": "https://example.com/ref.jpg A sunset landscape in watercolor style --iw 1.5 --ar 16:9",
                    "quality": "standard",
                    "model_params": {
                      "speed": "fast"
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "작업 생성 성공",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ImageGenerationResponse"
                }
              }
            }
          },
          "400": {
            "description": "잘못된 요청 매개변수",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "error": {
                    "code": "invalid_request",
                    "message": "Invalid request parameters",
                    "type": "invalid_request_error"
                  }
                }
              }
            }
          },
          "401": {
            "description": "미인증, 토큰 무효 또는 만료",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "error": {
                    "code": "unauthorized",
                    "message": "Invalid or expired token",
                    "type": "authentication_error"
                  }
                }
              }
            }
          },
          "402": {
            "description": "쿼터 부족, 충전하세요",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "error": {
                    "code": "insufficient_quota",
                    "message": "Insufficient quota. Please top up your account.",
                    "type": "insufficient_quota"
                  }
                }
              }
            }
          },
          "403": {
            "description": "접근 거부",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "error": {
                    "code": "model_access_denied",
                    "message": "Token does not have access to model: mj-v8.1",
                    "type": "invalid_request_error"
                  }
                }
              }
            }
          },
          "429": {
            "description": "요청 속도 제한 초과",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "error": {
                    "code": "rate_limit_exceeded",
                    "message": "Too many requests, please try again later",
                    "type": "rate_limit_error"
                  }
                }
              }
            }
          },
          "500": {
            "description": "내부 서버 오류",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "error": {
                    "code": "internal_error",
                    "message": "Internal server error",
                    "type": "api_error"
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "ImageGenerationRequest": {
        "type": "object",
        "required": [
          "model",
          "prompt"
        ],
        "properties": {
          "model": {
            "type": "string",
            "enum": [
              "mj-v8.1"
            ],
            "default": "mj-v8.1",
            "description": "모델 이름"
          },
          "prompt": {
            "type": "string",
            "description": "프롬프트, Midjourney V8.1의 모든 네이티브 매개변수 구문 지원 (예: --ar 16:9 --s 500).\n\n**이미지에서 이미지:** 프롬프트 시작 부분에 이미지 URL을 배치하세요. 지원 형식: .png, .gif, .webp, .jpg, .jpeg\n\n**이미지에서 이미지 규칙:**\n- 이미지 1장 + 텍스트 없음 = **무효** (오류 반환)\n- 이미지 1장 + 텍스트 설명 = 유효\n- 이미지 2장 이상 + 텍스트 없음 = 유효\n- 이미지 2장 이상 + 텍스트 설명 = 유효",
            "maxLength": 1024,
            "example": "A cinematic shot of a Maine Coon cat on a neon-lit balcony --ar 16:9 --s 500"
          },
          "quality": {
            "type": "string",
            "enum": [
              "standard",
              "hd"
            ],
            "default": "standard",
            "description": "출력 품질\n\n- `standard`: 표준 해상도 (기본값), 1배 배율\n- `hd`: 네이티브 HD 출력, 1.5배 배율. `speed: draft`와 상호 배타적\n\n**비용 안내:** 품질 배율은 `speed` 배율과 상승(곱셈) 관계입니다."
          },
          "model_params": {
            "type": "object",
            "description": "모델 매개변수",
            "properties": {
              "speed": {
                "type": "string",
                "enum": [
                  "draft",
                  "fast"
                ],
                "default": "fast",
                "description": "속도 모드\n\n- `draft`: 스케치 모드. 단일 실행으로 24장의 경량 0.5K 스케치 이미지를 반환합니다(4장이 아님). 구도 아이디어를 빠르게 탐색하는 데 적합합니다. `quality: hd`와 상호 배타적\n- `fast`: 표준 모드 (기본값)\n\n**비용 안내:** `draft`와 `fast`는 동일한 속도 배율(1배)을 공유합니다. 이 속도 배율은 다시 `quality` 배율과 상승(곱셈)됩니다."
              }
            }
          },
          "callback_url": {
            "type": "string",
            "description": "작업 완료 후 HTTPS 콜백 주소\n\n**콜백 시점:**\n- 작업 완료(completed), 실패(failed) 또는 취소(cancelled) 시 트리거\n- 과금 확인 완료 후 전송\n\n**보안 제한:**\n- HTTPS 프로토콜만 지원\n- 내부 네트워크 IP 주소로의 콜백 금지 (127.0.0.1, 10.x.x.x, 172.16-31.x.x, 192.168.x.x 등)\n- URL 길이 최대 `2048`자\n\n**콜백 메커니즘:**\n- 타임아웃: `10`초\n- 실패 후 최대 `3`회 재시도 (실패 후 `1`초/`2`초/`4`초에 각각 재시도)\n- 콜백 응답 형식은 작업 조회 인터페이스 반환 형식과 동일\n- 콜백 주소가 2xx 상태 코드를 반환하면 성공, 기타 상태 코드는 재시도 트리거",
            "format": "uri",
            "example": "https://your-domain.com/webhooks/image-task-completed"
          }
        }
      },
      "ImageGenerationResponse": {
        "type": "object",
        "properties": {
          "created": {
            "type": "integer",
            "description": "작업 생성 타임스탬프",
            "example": 1757165031
          },
          "id": {
            "type": "string",
            "description": "작업 ID",
            "example": "task-unified-1757165031-mjv81"
          },
          "model": {
            "type": "string",
            "description": "실제 사용된 모델 이름",
            "example": "mj-v8.1"
          },
          "object": {
            "type": "string",
            "enum": [
              "image.generation.task"
            ],
            "description": "작업 유형"
          },
          "progress": {
            "type": "integer",
            "description": "작업 진행률 (0-100)",
            "minimum": 0,
            "maximum": 100,
            "example": 0
          },
          "status": {
            "type": "string",
            "description": "작업 상태",
            "enum": [
              "pending",
              "processing",
              "completed",
              "failed"
            ],
            "example": "pending"
          },
          "task_info": {
            "$ref": "#/components/schemas/TaskInfo",
            "description": "비동기 작업 정보"
          },
          "type": {
            "type": "string",
            "enum": [
              "text",
              "image",
              "audio",
              "video"
            ],
            "description": "작업 출력 유형",
            "example": "image"
          },
          "usage": {
            "$ref": "#/components/schemas/Usage",
            "description": "사용량 및 과금 정보"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "object",
            "properties": {
              "code": {
                "type": "string",
                "description": "오류 코드 식별자"
              },
              "message": {
                "type": "string",
                "description": "오류 메시지"
              },
              "type": {
                "type": "string",
                "description": "오류 유형"
              }
            }
          }
        }
      },
      "TaskInfo": {
        "type": "object",
        "properties": {
          "can_cancel": {
            "type": "boolean",
            "description": "작업 취소 가능 여부",
            "example": true
          },
          "estimated_time": {
            "type": "integer",
            "description": "예상 완료 시간(초)",
            "minimum": 0,
            "example": 45
          }
        }
      },
      "Usage": {
        "type": "object",
        "description": "사용량 및 과금 정보",
        "properties": {
          "billing_rule": {
            "type": "string",
            "description": "과금 규칙",
            "enum": [
              "per_call",
              "per_token",
              "per_second"
            ],
            "example": "per_call"
          },
          "credits_reserved": {
            "type": "number",
            "description": "예상 소비 크레딧",
            "minimum": 0,
            "example": 1.8
          },
          "user_group": {
            "type": "string",
            "description": "사용자 그룹",
            "example": "default"
          }
        }
      }
    },
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "##모든 인터페이스는 Bearer Token 인증이 필요합니다##\n\n**API Key 발급:**\n\n[API Key 관리 페이지](https://evolink.ai/dashboard/keys)에서 API Key를 발급받으세요\n\n**요청 헤더에 다음을 추가하세요:**\n```\nAuthorization: Bearer YOUR_API_KEY\n```"
      }
    }
  }
}
