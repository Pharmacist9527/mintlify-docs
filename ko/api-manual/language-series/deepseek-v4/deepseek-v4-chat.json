                  "error": {
                    "code": 502,
                    "message": "Bad gateway",
                    "type": "bad_gateway_error"
                  }
                }
              }
            }
          },
          "503": {
            "description": "서비스 일시적으로 사용 불가",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
