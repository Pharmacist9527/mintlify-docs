{"openapi":"3.1.0","info":{"title":"Qwen3.5-Plus DashScope 전체 참조","description":"Qwen3.5-Plus DashScope 네이티브 프로토콜 전체 파라미터 참조","license":{"name":"MIT"},"version":"1.0.0"},"servers":[{"url":"https://api.evolink.ai","description":"프로덕션"}],"security":[{"bearerAuth":[]}],"paths":{"/api/v1/services/aigc/multimodal-generation/generation":{"post":{"summary":"Qwen3.5-Plus DashScope 네이티브 프로토콜","description":"- Alibaba Cloud DashScope 네이티브 프로토콜\n- qwen3.5-plus는 멀티모달 모델로 `multimodal-generation` 엔드포인트 사용\n- 파라미터 구조가 OpenAI 형식과 다르며, 요청 파라미터는 `parameters` 필드에 배치\n- 지원 모델: `qwen3.5-plus`, `qwen3.5-plus-2026-02-15`","operationId":"createDashScopeQwen35PlusKo","tags":["채팅 생성"],"requestBody":{"required":true,"content":{"application/json":{"schema":{"$ref":"#/components/schemas/DashScopeRequest"},"examples":{"simple_text":{"summary":"간단한 텍스트 대화","value":{"model":"qwen3.5-plus","input":{"messages":[{"role":"user","content":[{"text":"안녕하세요, 자기소개를 해주세요"}]}]},"parameters":{"result_format":"message"}}},"system_prompt":{"summary":"시스템 프롬프트","value":{"model":"qwen3.5-plus","input":{"messages":[{"role":"system","content":[{"text":"당신은 전문 어시스턴트입니다"}]},{"role":"user","content":[{"text":"안녕하세요"}]}]},"parameters":{"result_format":"message","temperature":0.7}}},"thinking_mode":{"summary":"사고 모드","value":{"model":"qwen3.5-plus","input":{"messages":[{"role":"user","content":[{"text":"1부터 100 사이의 모든 소수를 구하세요"}]}]},"parameters":{"result_format":"message","enable_thinking":true,"thinking_budget":8192}}},"vision":{"summary":"이미지 이해","value":{"model":"qwen3.5-plus","input":{"messages":[{"role":"user","content":[{"image":"https://example.com/image.jpg"},{"text":"이 이미지를 설명해주세요"}]}]},"parameters":{"result_format":"message"}}},"streaming":{"summary":"스트리밍 출력","value":{"model":"qwen3.5-plus","input":{"messages":[{"role":"user","content":[{"text":"봄에 관한 시를 써주세요"}]}]},"parameters":{"result_format":"message","stream":true,"incremental_output":true}}}}}}},"responses":{"200":{"description":"성공","content":{"applicat