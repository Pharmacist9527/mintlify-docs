ts/schemas/DashScopeContentPart"}}}},"DashScopeContentPart":{"type":"object","properties":{"text":{"type":"string","description":"텍스트 내용"},"image":{"type":"string","description":"이미지 URL 또는 Base64 데이터"},"video":{"oneOf":[{"type":"string"},{"type":"array","items":{"type":"string"}}],"description":"동영상 URL 또는 이미지 프레임 목록"},"audio":{"type":"string","description":"오디오 URL(Qwen-Omni/Qwen-Audio만 지원, qwen3.5-plus는 미지원)"},"fps":{"type":"number","description":"비디오 프레임 샘플링 속도(범위 [0.1, 10])"},"max_frames":{"type":"integer","description":"샘플링할 비디오 프레임 최대 개수"},"min_pixels":{"type":"integer","description":"최소 픽셀 임계값"},"max_pixels":{"type":"integer","description":"최대 픽셀 임계값"},"total_pixels":{"type":"integer","description":"비디오 총 픽셀 최대값"},"cache_control":{"$ref":"#/components/schemas/CacheControl"}}},"DashScopeParameters":{"type":"object","properties":{"result_format":{"type":"string","enum":["message","text"],"description":"반환 형식, 권장: message. message: role과 content를 포함한 구조화된 메시지 객체; text: 순수 텍스트 문자열","default":"message"},"stream":{"type":"boolean","description":"스트리밍 출력 활성화 여부, 기본값 false. 헤더 X-DashScope-SSE: enable 필요","default":false},"incremental_output":{"type":"boolean","description":"스트리밍 모드에서 증분 출력 여부, 기본값 false","default":false},"temperature":{"type":"number","description":"샘플링 온도, 텍스트 다양성 제어. 범위: [0, 2). temperature 또는 top_p 중 하나만 설정 권장","minimum":0,"maximum":2,"example":0.7},"top_p":{"type":"number","description":"Nucleus sampling 확률 임계값(0~1). temperature 또는 top_p 중 하나만 설정 권장","minimum":0,"maximum":1,"example":0.9},"top_k":{"type":"integer","description":"샘플링 시 후보 토큰 수. null 또는 >100이면 top_k 비활성화","minimum":0,"example":50},"max_tokens":{"type":"integer","description":"최대 출력 토큰 수. 초과 시 finish_reason이 length가 됨","minimum":1,"example":2048},"seed":{"type":"integer","description":"재현 가능한 결과를 위한 난수 시드. 범위: [0, 2^31-1]"},"stop":{"oneOf":[{"type":"string"},{"type":"array","items":{"type":"string"}}],"description":"정지 단어. 해당 문자열이 나타나면 즉시 생성 중단"},"repetition_penalty":{"type":"number","description":"반복 패널티, 범위 (0, 2], 기본값 1.0. presence_penalty와 동시 사용 불가","minimum":0,"maximum":2,"default":1},"presence_penalty":{"type":"number","description":"콘텐츠 반복 제어. 범위: [-2.0, 2.0]. 양수는 반복 감소","minimum":-2,"maximum":2,"default":0},"response_format":{"type":"object","description":"출력 형식, 예: {\"type\": \"json_object\"}로 JSON 출력 (프롬프트에서 명시적으로 지시 필요)"},"enable_thinking":{"type":"boolean","description":"사고 모드 활성화 여부. 기본값 true. 사고 내용은 reasoning_content로 반환","default":true},"thinking_budget":{"type":"integer","description":"사고 과정의 최대 토큰 수, 범위 [0, 81920]. 0으로 사고 모드 비활성화","minimum":0,"maximum":81920},"enable_search":{"type":"boolean","description":"웹 검색 활성화 여부, 기본값 false","default":false},"search_options":{"$ref":"#/components/schemas/SearchOptions"},"tools":{"type":"array","description":"Function Calling용 도구 정의","items":{"$ref":"#/components/schemas/Tool"}},"tool_choice":{"oneOf":[{"type":"string","enum":["none","auto","required"]},{"type":"object"}],"description":"도구 선택 전략. auto: 모델이 결정; none: 비활성화; required: 강제","default":"auto"},"parallel_tool_calls":{"type":"boolean","description":"병렬 도구 호출 활성화 여부, 기본값 false","default":false},"enable_code_interpreter":{"type":"boolean","description":"코드 인터프리터 활성화 여부, 기본값 false","default":false},"vl_high_resolution_images":{"type":"boolean","description":"이미지 해상도 상한을 16384 토큰으로 높일지 여부, 기본값 false","default":false},"n":{"type":"integer","description":"생성할 응답 수(범위 1-4). qwen3.5-plus는 현재 이 파라미터를 지원하지 않습니다(비사고 모드 Qwen3 모델만 지원).","minimum":1,"maximum":4},"vl_enable_image_hw_output":{"type":"boolean","description":"응답에 원본 이미지 가로/세로를 반환할지 여부입니다. Qwen-VL 모델만 지원하며 qwen3.5-plus는 미지원입니다.","default":false},"logprobs":{"type":"boolean","description":"출력 토큰의 로그 확률 반환 여부입니다. qwen3.5-plus는 현재 이 기능을 지원하지 않습니다.","default":false},"top_logprobs":{"type":"integer","description":"각 단계에서 반환할 상위 후보 토큰 수(범위 [0, 5])입니다. qwen3.5-plus는 현재 이 기능을 지원하지 않습니다.","minimum":0,"maximum":5,"default":0}}},"SearchOptions":{"type":"object","description":"웹 검색 옵션(enable_search=true일 때만 유효).","properties":{"enable_source":{"type":"boolean","description":"응답에 검색 출처 포함","default":false},"enable_citation":{"type":"boolean","description":"응답에 인용 마커 포함","default":false},"citation_format":{"type":"string","enum":["[<number>]","[ref_<number>]"],"description":"인용 형식","default":"[<number>]"},"forced_search":{"type":"boolean","description":"모델이 검색을 생략하더라도 웹 검색을 강제","default":false},"search_strategy":{"type":"string","enum":["turbo","max","agent","agent_max"],"description":"검색 전략: turbo(기본값), max, agent, agent_max","default":"turbo"},"enable_search_extension":{"type":"boolean","description":"도메인 확장 검색 활성화","default":false},"prepend_search_result":{"type":"boolean","description":"스트리밍 모드에서 검색 출처만 담은 첫 패킷을 앞에 붙임","default":false}}},"Tool":{"type":"object","required":["type","function"],"properties":{"type":{"type":"string","enum":["function"]},"function":{"type":"object","required":["name"],"properties":{"name":{"type":"string"},"description":{"type":"string"},"parameters":{"type":"object"}}}}},"DashScopeResponse":{"type":"object","properties":{"request_id":{"type":"string","description":"이 요청의 고유 식별자","example":"req_abc123"},"output":{"type":"object","description":"모델 출력","properties":{"choices":{"type":"array","description":"생성된 응답 목록","items":{"$ref":"#/components/schemas/DashScopeChoice"}}}},"usage":{"$ref":"#/components/schemas/DashScopeUsage","description":"토큰 소비 통계"}}},"DashScopeChoice":{"type":"object","properties":{"finish_reason":{"type":"string","enum":["stop","length","tool_calls"],"description":"생성 중단 이유. stop: 자연 중단; length: max_tokens 도달; tool_calls: 도구 호출 필요","example":"stop"},"message":{"type":"object","description":"생성된 메시지 객체","properties":{"role":{"type":"string","enum":["assistant"]},"content":{"oneOf":[{"type":"string"},{"type":"array","items":{"$ref":"#/components/schemas/DashScopeContentPart"}}],"description":"모델 응답 콘텐츠입니다. finish_reason=tool_calls인 경우 content가 빈 문자열일 수 있습니다.","example":"안녕하세요! 저는 Qwen3.5-Plus입니다..."},"reasoning_content":{"type":"string","description":"사고 연쇄 내용, enable_thinking: true일 때만 반환"},"tool_calls":{"type":"array","description":"function calling 시 도구 호출 목록","items":{"type":"object","properties":{"id":{"type":"string"},"type":{"type":"string","enum":["function"]},"function":{"type":"object","properties":{"name":{"type":"string"},"arguments":{"type":"string"}}}}}}}}}},"DashScopeUsage":{"type":"object","properties":{"input_tokens":{"type":"integer","description":"입력 토큰 수","example":13},"output_tokens":{"type":"integer","description":"출력 토큰 수 (사고 연쇄 토큰 포함)","example":256},"total_tokens":{"type":"integer","description":"총 토큰 소비 수","example":269}}},"ErrorResponse":{"type":"object","properties":{"error":{"type":"object","properties":{"code":{"type":"integer"},"message":{"type":"string"},"type":{"type":"string"},"param":{"type":"string"},"fallback_suggestion":{"type":"string"}}}}},"CacheControl":{"type":"object","description":"명시적 캐시 마커입니다. qwen3.5-plus는 ephemeral 캐시를 지원합니다(스냅샷 모델은 미지원).","required":["type"],"properties":{"type":{"type":"string","enum":["ephemeral"],"default":"ephemeral"}}}},"securitySchemes":{"bearerAuth":{"type":"http","scheme":"bearer","description":"##모든 엔드포인트는 Bearer 토큰 인증이 필요합니다##\n\n**API 키 발급:**\n\n[API 키 관리](https://evolink.ai/dashboard/keys) 방문\n\n**헤더에 추가:**\n```\nAuthorization: Bearer YOUR_API_KEY\n```"}}},"tags":[{"name":"채팅 생성","description":"AI 채팅 생성 엔드포인트"}]}
