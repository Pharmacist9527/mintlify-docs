                "description": "오류 유형"
              },
              "fallback_suggestion": {
                "type": "string",
                "description": "오류 발생 시 제안"
              }
            }
          }
        }
      },
      "BlobData": {
        "type": "object",
        "properties": {
          "mimeType": {
            "type": "string",
