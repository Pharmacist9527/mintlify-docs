      "ContentPart": {
        "type": "object",
        "description": "멀티모달 콘텐츠 조각, `type`으로 유형을 선언하고 해당 유형에 일치하는 필드만 채웁니다",
        "properties": {
          "type": {
            "type": "string",
            "enum": [
              "text",
              "image_url",
              "video_url"
            ],
            "description": "콘텐츠 유형\n\n- `text`: 텍스트 블록\n- `image_url`: 이미지 입력\n- `video_url`: 비디오 입력"
          },
