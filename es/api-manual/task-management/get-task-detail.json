{
  "openapi": "3.1.0",
  "info": {
    "title": "API para obtener detalles de la tarea",
    "description": "Consulta el estado, progreso e información de resultados de tareas asíncronas por ID de tarea",
    "license": {
      "name": "MIT"
    },
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://api.evolink.ai",
      "description": "Entorno de producción"
    }
  ],
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "paths": {
    "/v1/tasks/{task_id}": {
      "get": {
        "summary": "Consultar Estado de Tarea",
        "description": "Consulta el estado, progreso e información de resultados de tareas asíncronas por ID de tarea",
        "operationId": "getTaskDetail",
        "tags": [
          "Gestión de tareas"
        ],
        "parameters": [
          {
            "name": "task_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "ID de tarea, ignora {} al consultar, agrega el id del cuerpo de respuesta de la tarea asíncrona al final de la ruta",
            "example": "task-unified-1756817821-4x3rx6ny"
          }
        ],
        "responses": {
          "200": {
            "description": "Detalles del estado de la tarea",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TaskDetailResponse"
                }
              }
            }
          },
          "400": {
            "description": "Error en parámetros de solicitud, error de formato",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "error": {
                    "code": "invalid_task_id",
                    "message": "Invalid task ID format, must start with 'task-unified-'",
                    "type": "invalid_request_error",
                    "param": "task_id"
                  }
                }
              }
            }
          },
          "401": {
            "description": "No autenticado, token inválido o expirado",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "error": {
                    "code": "unauthorized",
                    "message": "Authentication required",
                    "type": "authentication_error"
                  }
                }
              }
            }
          },
          "402": {
            "description": "Cuota insuficiente, se requiere recarga",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "error": {
                    "code": "quota_exceeded",
                    "message": "Insufficient quota. Please top up your account.",
                    "type": "insufficient_quota"
                  }
                }
              }
            }
          },
          "403": {
            "description": "Sin permiso de acceso",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "error": {
                    "code": "permission_denied",
                    "message": "You don't have permission to access this task",
                    "type": "invalid_request_error"
                  }
                }
              }
            }
          },
          "404": {
            "description": "El recurso no existe",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "error": {
                    "code": "task_not_found",
                    "message": "The requested task could not be found",
                    "type": "invalid_request_error"
                  }
                }
              }
            }
          },
          "429": {
            "description": "Límite de tasa de solicitudes excedido",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "error": {
                    "message": "Rate limit exceeded",
                    "type": "evo_api_error"
                  }
                }
              }
            }
          },
          "500": {
            "description": "Error interno del servidor",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "error": {
                    "code": "internal_error",
                    "message": "Failed to retrieve task status",
                    "type": "api_error"
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "TaskDetailResponse": {
        "type": "object",
        "properties": {
          "created": {
            "type": "integer",
            "description": "Marca de tiempo de creación de la tarea",
            "example": 1756817821
          },
          "id": {
            "type": "string",
            "description": "ID de tarea",
            "example": "task-unified-1756817821-4x3rx6ny"
          },
          "model": {
            "type": "string",
            "description": "Modelo utilizado",
            "example": "gemini-3.1-flash-image-preview"
          },
          "object": {
            "type": "string",
            "description": "Tipo de tarea",
            "enum": [
              "image.generation.task",
              "video.generation.task",
              "audio.generation.task"
            ],
            "example": "image.generation.task"
          },
          "progress": {
            "type": "integer",
            "minimum": 0,
            "maximum": 100,
            "description": "Porcentaje de progreso de la tarea",
            "example": 100
          },
          "results": {
            "type": "array",
            "items": {
              "type": "string",
              "format": "uri"
            },
            "description": "Lista de resultados de la tarea (proporcionada al completarse)",
            "example": [
              "http://example.com/image.jpg"
            ]
          },
          "status": {
            "type": "string",
            "description": "Estado de la tarea",
            "enum": [
              "pending",
              "processing",
              "completed",
              "failed"
            ],
            "example": "completed"
          },
          "error": {
            "type": "object",
            "nullable": true,
            "description": "Informacion de error cuando la tarea falla (solo presente cuando status es \"failed\"). Nota: error.code aqui es un codigo de error de negocio de tipo string, diferente de los codigos de estado HTTP. Consulte la Referencia de Codigos de Error para la lista completa.",
            "properties": {
              "code": {
                "type": "string",
                "description": "Codigo de error de negocio (tipo string)",
                "example": "content_policy_violation"
              },
              "message": {
                "type": "string",
                "description": "Descripcion de error amigable con consejos de solucion",
                "example": "Content policy violation.\nYour request was blocked by safety filters."
              },
              "type": {
                "type": "string",
                "description": "Identificador de tipo de error, siempre \"task_error\"",
                "example": "task_error"
              }
            }
          },
          "task_info": {
            "type": "object",
            "description": "Información detallada de la tarea",
            "properties": {
              "can_cancel": {
                "type": "boolean",
                "description": "Si la tarea puede ser cancelada",
                "example": false
              }
            }
          },
          "type": {
            "type": "string",
            "description": "Tipo de tarea",
            "enum": [
              "image",
              "video",
              "audio",
              "text"
            ],
            "example": "image"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "object",
            "properties": {
              "code": {
                "type": "string",
                "description": "Codigo de error (tipo string)",
                "example": "invalid_task_id"
              },
              "message": {
                "type": "string",
                "description": "Mensaje de descripción del error",
                "example": "Invalid task ID format"
              },
              "type": {
                "type": "string",
                "description": "Tipo de error",
                "example": "invalid_request_error"
              },
              "param": {
                "type": "string",
                "description": "Nombre del parámetro relacionado",
                "example": "task_id"
              }
            }
          }
        }
      }
    },
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "##Todas las APIs requieren autenticación Bearer Token##\n\n**Obtener API Key:**\n\nVisita la [Página de gestión de API Key](https://evolink.ai/dashboard/keys) para obtener tu API Key\n\n**Agregar al encabezado de la solicitud:**\n```\nAuthorization: Bearer YOUR_API_KEY\n```"
      }
    }
  },
  "tags": [
    {
      "name": "Gestión de tareas",
      "description": "APIs relacionadas con la gestión de tareas asíncronas"
    }
  ]
}