{
  "openapi": "3.1.0",
  "info": {
    "title": "Referencia completa de la API de MiniMax-M3 (compatible con OpenAI)",
    "description": "Referencia completa de la API de la interfaz de chat de MiniMax-M3.\n\n**Capacidades del modelo**:\n- Salida máxima: **524,288 tokens** (512K), recomendado **131,072 tokens** (128K)\n- Modo de pensamiento: se controla mediante el campo `thinking`, con valor predeterminado `adaptive` (el modelo decide de forma adaptativa si realiza un pensamiento profundo)\n- Entrada multimodal: admite texto, imágenes y video\n- Llamada a herramientas: admite Function Calling\n- Salida en streaming: admite respuestas en streaming SSE",
    "license": {
      "name": "MIT"
    },
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://direct.evolink.ai",
      "description": "Producción (recomendado)"
    },
    {
      "url": "https://api.evolink.ai",
      "description": "URL alternativa"
    }
  ],
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "paths": {
    "/v1/chat/completions": {
      "post": {
        "summary": "Interfaz de chat de MiniMax-M3 (compatible con OpenAI)",
        "description": "- Utiliza el protocolo OpenAI Chat Completions para llamar al modelo MiniMax-M3\n- **Conversación de múltiples turnos**: admite diálogo contextual de un solo turno o de múltiples turnos\n- **Indicaciones de sistema**: personaliza el rol y el comportamiento de la IA mediante mensajes con `role=system`\n- **Entrada multimodal**: `content` admite texto + imagen / video combinados\n- **Modo de pensamiento**: se controla mediante `thinking.type`; el contenido de pensamiento se devuelve a través de `reasoning_content`\n- **Salida en streaming**: admite respuestas en streaming SSE\n- **Llamada a herramientas**: admite Function Calling",
        "operationId": "createChatCompletionMiniMaxM3",
        "tags": [
          "Generación de chat"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ChatCompletionRequest"
              },
              "examples": {
                "simple_text": {
                  "summary": "Conversación de texto de un solo turno",
                  "value": {
                    "model": "MiniMax-M3",
                    "messages": [
                      {
                        "role": "user",
                        "content": "Preséntate, por favor"
                      }
                    ]
                  }
                },
                "multi_turn": {
                  "summary": "Conversación de múltiples turnos (comprensión del contexto)",
                  "value": {
                    "model": "MiniMax-M3",
                    "messages": [
                      {
                        "role": "user",
                        "content": "¿Qué es Python?"
                      },
                      {
                        "role": "assistant",
                        "content": "Python es un lenguaje de programación de alto nivel..."
                      },
                      {
                        "role": "user",
                        "content": "¿Cuáles son sus ventajas?"
                      }
                    ]
                  }
                },
                "system_prompt": {
                  "summary": "Uso de indicaciones de sistema",
                  "value": {
                    "model": "MiniMax-M3",
                    "messages": [
                      {
                        "role": "system",
                        "content": "Eres un asistente profesional de programación en Python. Responde las preguntas de forma concisa."
                      },
                      {
                        "role": "user",
                        "content": "¿Cómo se lee un archivo?"
                      }
                    ]
                  }
                },
                "image_understanding": {
                  "summary": "Comprensión de imágenes (entrada multimodal)",
                  "value": {
                    "model": "MiniMax-M3",
                    "thinking": {
                      "type": "adaptive"
                    },
                    "messages": [
                      {
                        "role": "user",
                        "content": [
                          {
                            "type": "text",
                            "text": "¿Qué hay en esta imagen?"
                          },
                          {
                            "type": "image_url",
                            "image_url": {
                              "url": "https://example.com/image.jpeg"
                            }
                          }
                        ]
                      }
                    ],
                    "max_completion_tokens": 500
                  }
                },
                "disable_thinking": {
                  "summary": "Desactivar el modo de pensamiento (respuesta directa)",
                  "value": {
                    "model": "MiniMax-M3",
                    "thinking": {
                      "type": "disabled"
                    },
                    "messages": [
                      {
                        "role": "user",
                        "content": "¿Cuál es la capital de Francia?"
                      }
                    ]
                  }
                },
                "tool_calling": {
                  "summary": "Function Calling (invocación de herramientas)",
                  "value": {
                    "model": "MiniMax-M3",
                    "messages": [
                      {
                        "role": "user",
                        "content": "Consulta el clima de hoy en Pekín"
                      }
                    ],
                    "tools": [
                      {
                        "type": "function",
                        "function": {
                          "name": "get_weather",
                          "description": "Consulta las condiciones meteorológicas de una ciudad específica",
                          "parameters": {
                            "type": "object",
                            "properties": {
                              "location": {
                                "type": "string",
                                "description": "Nombre de la ciudad, por ejemplo: Pekín"
                              }
                            },
                            "required": [
                              "location"
                            ]
                          }
                        }
                      }
                    ]
                  }
                },
                "streaming": {
                  "summary": "Salida en streaming",
                  "value": {
                    "model": "MiniMax-M3",
                    "stream": true,
                    "stream_options": {
                      "include_usage": true
                    },
                    "messages": [
                      {
                        "role": "user",
                        "content": "Escribe un poema corto sobre la primavera"
                      }
                    ]
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Generación de chat exitosa",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ChatCompletionResponse"
                },
                "examples": {
                  "default_thinking": {
                    "summary": "Predeterminado (pensamiento integrado en content dentro de etiquetas <think>)",
                    "value": {
                      "id": "066b36619b147e326d17053cccdef70f",
                      "choices": [
                        {
                          "finish_reason": "stop",
                          "index": 0,
                          "message": {
                            "content": "<think>\nEl usuario pregunta por la capital de Francia, que es una pregunta de conocimiento general. La respuesta es París.\n</think>\nLa capital de Francia es **París**.",
                            "role": "assistant",
                            "name": "MiniMax AI",
                            "audio_content": ""
                          }
                        }
                      ],
                      "created": 1777026807,
                      "model": "MiniMax-M3",
                      "object": "chat.completion",
                      "usage": {
                        "total_tokens": 60,
                        "total_characters": 0,
                        "prompt_tokens": 7,
                        "completion_tokens": 53,
                        "prompt_tokens_details": {
                          "cached_tokens": 0
                        }
                      },
                      "input_sensitive": false,
                      "output_sensitive": false,
                      "input_sensitive_type": 0,
                      "output_sensitive_type": 0,
                      "base_resp": {
                        "status_code": 0,
                        "status_msg": ""
                      }
                    }
                  },
                  "tool_calls": {
                    "summary": "Llamada a herramienta activada (finish_reason=tool_calls)",
                    "value": {
                      "id": "066b13db03518f86c2e3c9b073c04272",
                      "choices": [
                        {
                          "finish_reason": "tool_calls",
                          "index": 0,
                          "message": {
                            "content": "<think>\nEl usuario quiere consultar el clima en Pekín, se llama a la herramienta get_weather.\n</think>\nVoy a consultar el clima actual en Pekín para ti.",
                            "role": "assistant",
                            "name": "MiniMax AI",
                            "tool_calls": [
                              {
                                "id": "call_function_p4iiqtpnh5bj_1",
                                "type": "function",
                                "function": {
                                  "name": "get_weather",
                                  "arguments": "{\"location\": \"Pekín\"}"
                                },
                                "index": 0
                              }
                            ],
                            "audio_content": ""
                          }
                        }
                      ],
                      "created": 1777026900,
                      "model": "MiniMax-M3",
                      "object": "chat.completion",
                      "usage": {
                        "total_tokens": 110,
                        "total_characters": 0,
                        "prompt_tokens": 86,
                        "completion_tokens": 24,
                        "prompt_tokens_details": {
                          "cached_tokens": 0
                        }
                      },
                      "input_sensitive": false,
                      "output_sensitive": false,
                      "input_sensitive_type": 0,
                      "output_sensitive_type": 0,
                      "base_resp": {
                        "status_code": 0,
                        "status_msg": ""
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Parámetros de solicitud no válidos",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "error": {
                    "code": 400,
                    "message": "Invalid request parameters",
                    "type": "invalid_request_error"
                  }
                }
              }
            }
          },
          "401": {
            "description": "Sin autenticar, token no válido o caducado",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "error": {
                    "code": 401,
                    "message": "Invalid or expired token",
                    "type": "authentication_error"
                  }
                }
              }
            }
          },
          "402": {
            "description": "Cuota insuficiente, se requiere recarga",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "error": {
                    "code": 402,
                    "message": "Insufficient quota",
                    "type": "insufficient_quota_error"
                  }
                }
              }
            }
          },
          "403": {
            "description": "Acceso denegado a este modelo",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "error": {
                    "code": 403,
                    "message": "Access denied for this model",
                    "type": "permission_error",
                    "param": "model"
                  }
                }
              }
            }
          },
          "404": {
            "description": "Recurso no encontrado",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "error": {
                    "code": 404,
                    "message": "Specified model not found",
                    "type": "not_found_error",
                    "param": "model"
                  }
                }
              }
            }
          },
          "413": {
            "description": "Cuerpo de la solicitud demasiado grande",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "error": {
                    "code": 413,
                    "message": "Request body too large",
                    "type": "request_too_large_error",
                    "param": "messages"
                  }
                }
              }
            }
          },
          "429": {
            "description": "Límite de frecuencia superado",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "error": {
                    "code": 429,
                    "message": "Rate limit exceeded",
                    "type": "rate_limit_error"
                  }
                }
              }
            }
          },
          "500": {
            "description": "Error interno del servidor",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "error": {
                    "code": 500,
                    "message": "Internal server error",
                    "type": "internal_server_error"
                  }
                }
              }
            }
          },
          "502": {
            "description": "Puerta de enlace no válida",
            "content": {
              "application/json": {
                "schema": {
