                "minLength": 1,
                "maxLength": 64,
                "pattern": "^[a-zA-Z0-9_-]+$"
              },
              "description": {
                "type": "string",
                "description": "函数功能的描述，供模型选择何时以及如何调用函数"
              },
              "parameters": {
                "type": "object",
                "description": "函数的输入参数，以 JSON Schema 对象描述"
              }
            }
          }
        }
      },
      "RetrievalTool": {
        "title": "Retrieval 工具（知识库检索）",
