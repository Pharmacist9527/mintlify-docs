      "FunctionTool": {
        "title": "Function 工具",
        "type": "object",
        "required": [
          "type",
          "function"
        ],
        "additionalProperties": false,
        "properties": {
          "type": {
            "type": "string",
            "enum": [
              "function"
            ],
            "default": "function",
            "description": "工具类型，固定为 `function`"
          },
          "function": {
            "type": "object",
