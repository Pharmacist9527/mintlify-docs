                  "type": "object",
                  "properties": {
                    "name": {
                      "type": "string",
                      "description": "调用的函数名称"
                    },
                    "arguments": {
                      "type": "string",
                      "description": "函数参数（JSON 字符串）"
                    }
                  }
                }
              }
            }
          }
        }
      },
