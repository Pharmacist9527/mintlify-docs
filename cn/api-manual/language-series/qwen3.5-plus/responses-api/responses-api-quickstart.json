{
  "openapi": "3.1.0",
  "info": { "title": "Qwen3.5-Plus Responses API 快速开始", "description": "5分钟快速接入 Qwen3.5-Plus Responses API", "license": { "name": "MIT" }, "version": "1.0.0" },
  "servers": [{ "url": "https://api.evolink.ai", "description": "Production" }],
  "security": [{ "bearerAuth": [] }],
  "paths": {
    "/v1/responses": {
      "post": {
        "summary": "Qwen3.5-Plus Responses API 快速调用",
        "description": "- 使用 OpenAI Responses API 格式调用 Qwen3.5-Plus\n- 支持内置工具（联网搜索、代码解释器等）\n- 支持 `previous_response_id` 简化多轮对话\n- 支持模型：`qwen3.5-plus`, `qwen3.5-plus-2026-02-15`\n- 💡 更多功能？查看 [完整 API 参考](./responses-api-reference)",
        "operationId": "createResponsesQuickQwen35PlusCn",
        "tags": ["对话生成"],
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ResponsesQuickRequest" } } } },
        "responses": {
          "200": { "description": "成功", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ResponsesResponse" } } } },
          "400": { "description": "请求参数错误", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" }, "example": { "error": { "code": 400, "message": "Invalid request parameters", "type": "invalid_request_error" } } } } },
          "401": { "description": "未授权", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" }, "example": { "error": { "code": 401, "message": "Invalid or expired token", "type": "authentication_error" } } } } },
          "402": { "description": "额度不足", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" }, "example": { "error": { "code": 402, "message": "Insufficient quota", "type": "insufficient_quota_error", "fallback_suggestion": "https://evolink.ai/dashboard/billing" } } } } },
          "429": { "description": "请求频率超限", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" }, "example": { "error": { "code": 429, "message": "Rate limit exceeded", "type": "rate_limit_error" } } } } },
          "500": { "description": "服务器内部错误", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" }, "example": { "error": { "code": 500, "message": "Internal server error", "type": "internal_server_error" } } } } }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "ResponsesQuickRequest": {
        "type": "object", "required": ["model", "input"],
        "properties": {
          "model": { "type": "string", "description": "模型名称", "enum": ["qwen3.5-plus", "qwen3.5-plus-2026-02-15"], "default": "qwen3.5-plus", "example": "qwen3.5-plus" },
          "input": { "oneOf": [{ "type": "string" }, { "type": "array", "items": { "$ref": "#/components/schemas/MessageSimple" } }], "description": "输入内容，支持字符串或消息数组", "example": "你好，请介绍一下你自己" }
        }
      },
      "MessageSimple": { "type": "object", "required": ["role", "content"], "properties": { "role": { "type": "string", "enum": ["user", "assistant", "system"] }, "content": { "type": "string" } } },
      "ResponsesResponse": { "type": "object", "properties": { "id": { "type": "string", "example": "resp_abc123" }, "model": { "type": "string", "example": "qwen3.5-plus" }, "status": { "type": "string", "enum": ["completed", "in_progress", "failed"], "example": "completed" }, "created_at": { "type": "integer", "example": 1760032810 }, "output": { "type": "array", "items": { "$ref": "#/components/schemas/OutputItem" } }, "output_text": { "type": "string", "description": "便捷字段，直接返回文本输出", "example": "你好！我是 Qwen3.5-Plus..." }, "usage": { "$ref": "#/components/schemas/ResponsesUsage" } } },
      "OutputItem": { "type": "object", "properties": { "type": { "type": "string", "enum": ["message", "reasoning", "function_call", "web_search_call"], "example": "message" }, "content": { "type": "array", "items": { "type": "object", "properties": { "type": { "type": "string", "enum": ["output_text"] }, "text": { "type": "string" } } } }, "summary": { "type": "array", "items": { "type": "object", "properties": { "text": { "type": "string", "description": "思维链摘要" } } } } } },
      "ResponsesUsage": { "type": "object", "properties": { "input_tokens": { "type": "integer", "example": 13 }, "output_tokens": { "type": "integer", "example": 256 }, "total_tokens": { "type": "integer", "example": 269 } } },
      "ErrorResponse": { "type": "object", "properties": { "error": { "type": "object", "properties": { "code": { "type": "integer" }, "message": { "type": "string" }, "type": { "type": "string" }, "param": { "type": "string" }, "fallback_suggestion": { "type": "string" } } } } }
    },
    "securitySchemes": { "bearerAuth": { "type": "http", "scheme": "bearer", "description": "##所有接口均需 Bearer Token 认证##\n\n**获取 API Key：**\n\n访问 [API Key 管理](https://evolink.ai/dashboard/keys)\n\n**添加到请求头：**\n```\nAuthorization: Bearer YOUR_API_KEY\n```" } }
  },
  "tags": [{ "name": "对话生成", "description": "AI 对话生成接口" }]
}
