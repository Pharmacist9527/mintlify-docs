{
  "openapi": "3.1.0",
  "info": { "title": "Qwen3.5-Plus DashScope 快速开始", "description": "5分钟快速接入 Qwen3.5-Plus DashScope 原生协议", "license": { "name": "MIT" }, "version": "1.0.0" },
  "servers": [{ "url": "https://api.evolink.ai", "description": "Production" }],
  "security": [{ "bearerAuth": [] }],
  "paths": {
    "/api/v1/services/aigc/multimodal-generation/generation": {
      "post": {
        "summary": "Qwen3.5-Plus DashScope 快速调用",
        "description": "- 使用阿里云 DashScope 原生协议调用 Qwen3.5-Plus\n- qwen3.5-plus 为多模态模型，使用 `multimodal-generation` 端点\n- 请求体结构与 OpenAI 格式不同，参数放在 `parameters` 字段\n- 支持模型：`qwen3.5-plus`, `qwen3.5-plus-2026-02-15`\n- 💡 更多功能？查看 [完整 API 参考](./dashscope-reference)",
        "operationId": "createDashScopeQuickQwen35PlusCn",
        "tags": ["对话生成"],
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/DashScopeQuickRequest" } } } },
        "responses": {
          "200": { "description": "成功", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/DashScopeResponse" } } } },
          "400": { "description": "请求参数错误", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" }, "example": { "error": { "code": 400, "message": "Invalid request parameters", "type": "invalid_request_error" } } } } },
          "401": { "description": "未授权", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" }, "example": { "error": { "code": 401, "message": "Invalid or expired token", "type": "authentication_error" } } } } },
          "402": { "description": "额度不足", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" }, "example": { "error": { "code": 402, "message": "Insufficient quota", "type": "insufficient_quota_error", "fallback_suggestion": "https://evolink.ai/dashboard/billing" } } } } },
          "429": { "description": "请求频率超限", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" }, "example": { "error": { "code": 429, "message": "Rate limit exceeded", "type": "rate_limit_error" } } } } },
          "500": { "description": "服务器内部错误", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" }, "example": { "error": { "code": 500, "message": "Internal server error", "type": "internal_server_error" } } } } }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "DashScopeQuickRequest": {
        "type": "object", "required": ["model", "input"],
        "properties": {
          "model": { "type": "string", "description": "模型名称", "enum": ["qwen3.5-plus", "qwen3.5-plus-2026-02-15"], "default": "qwen3.5-plus", "example": "qwen3.5-plus" },
          "input": { "type": "object", "required": ["messages"], "description": "输入内容", "properties": { "messages": { "type": "array", "description": "消息列表，content 为对象数组格式", "items": { "$ref": "#/components/schemas/DashScopeMessage" }, "example": [{ "role": "user", "content": [{ "text": "你好，请介绍一下你自己" }] }] } } }
        }
      },
      "DashScopeMessage": { "type": "object", "required": ["role", "content"], "properties": { "role": { "type": "string", "enum": ["user", "assistant", "system"] }, "content": { "type": "array", "items": { "type": "object", "properties": { "text": { "type": "string" } } } } } },
      "DashScopeResponse": { "type": "object", "properties": { "request_id": { "type": "string", "example": "req_abc123" }, "output": { "type": "object", "properties": { "choices": { "type": "array", "items": { "$ref": "#/components/schemas/DashScopeChoice" } } } }, "usage": { "$ref": "#/components/schemas/DashScopeUsage" } } },
      "DashScopeChoice": { "type": "object", "properties": { "finish_reason": { "type": "string", "enum": ["stop", "length", "tool_calls"], "example": "stop" }, "message": { "type": "object", "properties": { "role": { "type": "string", "enum": ["assistant"] }, "content": { "type": "string", "example": "你好！我是 Qwen3.5-Plus..." }, "reasoning_content": { "type": "string", "description": "思维链内容（思考模式下）" } } } } },
      "DashScopeUsage": { "type": "object", "properties": { "input_tokens": { "type": "integer", "example": 13 }, "output_tokens": { "type": "integer", "example": 256 }, "total_tokens": { "type": "integer", "example": 269 } } },
      "ErrorResponse": { "type": "object", "properties": { "error": { "type": "object", "properties": { "code": { "type": "integer" }, "message": { "type": "string" }, "type": { "type": "string" }, "param": { "type": "string" }, "fallback_suggestion": { "type": "string" } } } } }
    },
    "securitySchemes": { "bearerAuth": { "type": "http", "scheme": "bearer", "description": "##所有接口均需 Bearer Token 认证##\n\n**获取 API Key：**\n\n访问 [API Key 管理](https://evolink.ai/dashboard/keys)\n\n**添加到请求头：**\n```\nAuthorization: Bearer YOUR_API_KEY\n```" } }
  },
  "tags": [{ "name": "对话生成", "description": "AI 对话生成接口" }]
}
