{
  "openapi": "3.1.0",
  "info": {
    "title": "Seedance Asset Upload 接口",
    "description": "Seedance 素材上传接口，将图片/视频/音频素材上传到私域素材库，返回 asset:// URI 供视频生成使用",
    "license": {
      "name": "MIT"
    },
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://api.evolink.ai",
      "description": "生产环境"
    }
  ],
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "paths": {
    "/v1/videos/generations": {
      "post": {
        "summary": "Seedance Asset Upload 素材上传",
        "description": "- 将图片/视频/音频素材上传到私域素材库，经审核处理后返回 `asset://` URI\n- 返回的 `asset://` URI 可在视频生成的 `image_urls`、`video_urls`、`audio_urls` 中直接使用\n- 典型场景：上传虚拟人像素材，避免视频生成时被人脸审核拦截\n- 异步处理模式，使用返回的任务ID [进行查询](/cn/api-manual/task-management/get-task-detail)\n- 每次请求只处理一个 URL（取数组第一个元素），如需上传多个素材请分多次请求",
        "operationId": "createSeedanceAssetUpload",
        "tags": [
          "素材上传"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AssetUploadRequest"
              },
              "examples": {
                "upload_image": {
                  "summary": "上传图片素材",
                  "value": {
                    "model": "seedance-asset-upload",
                    "image_urls": [
                      "https://example.com/virtual_person_face.jpg"
                    ]
                  }
                },
                "upload_video": {
                  "summary": "上传视频素材（手动指定类型）",
                  "value": {
                    "model": "seedance-asset-upload",
                    "video_urls": [
                      "https://cdn.example.com/reference_clip.mp4"
                    ],
                    "model_params": {
                      "asset_type": "Video"
                    }
                  }
                },
                "upload_audio": {
                  "summary": "上传音频素材",
                  "value": {
                    "model": "seedance-asset-upload",
                    "audio_urls": [
                      "https://example.com/bgm.mp3"
                    ]
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "素材上传任务创建成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AssetUploadResponse"
                }
              }
            }
          },
          "400": {
            "description": "请求参数错误",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "error": {
                    "code": "invalid_request",
                    "message": "Invalid request parameters",
                    "type": "invalid_request_error"
                  }
                }
              }
            }
          },
          "401": {
            "description": "未认证、Token无效或过期",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "error": {
                    "code": "unauthorized",
                    "message": "Invalid or expired token",
                    "type": "authentication_error"
                  }
                }
              }
            }
          },
          "402": {
            "description": "配额不足、需要充值",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "error": {
                    "code": "insufficient_quota",
                    "message": "Insufficient quota. Please top up your account.",
                    "type": "insufficient_quota"
                  }
                }
              }
            }
          },
          "403": {
            "description": "无权限访问",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "error": {
                    "code": "model_access_denied",
                    "message": "Token does not have access to model: seedance-asset-upload",
                    "type": "invalid_request_error"
                  }
                }
              }
            }
          },
          "429": {
            "description": "请求频率超限",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "error": {
                    "code": "rate_limit_exceeded",
                    "message": "Too many requests, please try again later",
                    "type": "rate_limit_error"
                  }
                }
              }
            }
          },
          "500": {
            "description": "服务器内部错误",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "error": {
                    "code": "internal_error",
                    "message": "Internal server error",
                    "type": "api_error"
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "AssetUploadRequest": {
        "type": "object",
        "required": [
          "model"
        ],
        "properties": {
          "model": {
            "type": "string",
            "description": "模型名称",
            "enum": [
              "seedance-asset-upload"
            ],
            "default": "seedance-asset-upload",
            "example": "seedance-asset-upload"
          },
          "image_urls": {
            "type": "array",
            "description": "上传图片素材 URL 数组（与 `video_urls`、`audio_urls` 三选一）\n\n**每次请求只处理第一个 URL**，如需上传多个素材请分多次请求\n\n**图片要求：**\n- 支持格式：`.jpeg`、`.png`、`.webp`、`.bmp`、`.tiff`、`.gif`、`.heic`、`.heif`\n- 宽高比（宽/高）：`0.4` ~ `2.5`\n- 宽高像素：`300` ~ `6000` px\n- 单张大小：不超过 `30MB`\n- 不支持 Base64 编码，URL 需要服务器能直接访问\n\n**自动类型检测：** 根据 URL 扩展名自动识别为 Image 类型。如 URL 无扩展名（如预签名 URL），请通过 `model_params.asset_type` 手动指定\n\n**使用说明：** 上传完成后返回的 `asset://` URI，在视频生成时需放入 `image_urls` 参数中使用",
            "items": {
              "type": "string",
              "format": "uri"
            },
            "maxItems": 1,
            "example": [
              "https://example.com/virtual_person_face.jpg"
            ]
          },
          "video_urls": {
            "type": "array",
            "description": "上传视频素材 URL 数组（与 `image_urls`、`audio_urls` 三选一）\n\n**每次请求只处理第一个 URL**，如需上传多个素材请分多次请求\n\n**视频要求：**\n- 支持格式：`.mp4`、`.mov`\n- 分辨率：480p、720p\n- 时长：`2` ~ `15` 秒\n- 单个大小：不超过 `50MB`\n- 不支持 Base64 编码，URL 需要服务器能直接访问\n\n**自动类型检测：** 根据 URL 扩展名自动识别为 Video 类型。如 URL 无扩展名，请通过 `model_params.asset_type` 手动指定\n\n**使用说明：** 上传完成后返回的 `asset://` URI，在视频生成时需放入 `video_urls` 参数中使用",
            "items": {
              "type": "string",
              "format": "uri"
            },
            "maxItems": 1,
            "example": [
              "https://cdn.example.com/reference_clip.mp4"
            ]
          },
          "audio_urls": {
            "type": "array",
            "description": "上传音频素材 URL 数组（与 `image_urls`、`video_urls` 三选一）\n\n**每次请求只处理第一个 URL**，如需上传多个素材请分多次请求\n\n**音频要求：**\n- 支持格式：`.wav`、`.mp3`\n- 时长：`2` ~ `15` 秒\n- 单个大小：不超过 `15MB`\n- 不支持 Base64 编码，URL 需要服务器能直接访问\n\n**自动类型检测：** 根据 URL 扩展名自动识别为 Audio 类型。如 URL 无扩展名，请通过 `model_params.asset_type` 手动指定\n\n**使用说明：** 上传完成后返回的 `asset://` URI，在视频生成时需放入 `audio_urls` 参数中使用",
            "items": {
              "type": "string",
              "format": "uri"
            },
            "maxItems": 1,
            "example": [
              "https://example.com/bgm.mp3"
            ]
          },
          "model_params": {
            "type": "object",
            "description": "模型扩展参数",
            "properties": {
              "asset_type": {
                "type": "string",
                "description": "手动指定素材类型。不传则根据 URL 扩展名自动检测\n\n**可选值：**\n- `Image`：图片素材\n- `Video`：视频素材\n- `Audio`：音频素材\n\n**何时需要手动指定：** 当 URL 没有扩展名时（如预签名 URL、CDN 链接等），系统无法自动识别类型，需通过此参数手动指定",
                "enum": [
                  "Image",
                  "Video",
                  "Audio"
                ],
                "example": "Image"
              }
            }
          }
        }
      },
      "AssetUploadResponse": {
        "type": "object",
        "properties": {
          "created": {
            "type": "integer",
            "description": "任务创建时间戳",
            "example": 1761313744
          },
          "id": {
            "type": "string",
            "description": "任务ID",
            "example": "task-unified-1774857405-abc123"
          },
          "model": {
            "type": "string",
            "description": "实际使用的模型名称",
            "example": "seedance-asset-upload"
          },
          "object": {
            "type": "string",
            "enum": [
              "video.generation.task"
            ],
            "description": "任务的具体类型"
          },
          "progress": {
            "type": "integer",
            "description": "任务进度百分比 (0-100)",
            "minimum": 0,
            "maximum": 100,
            "example": 0
          },
          "status": {
            "type": "string",
            "description": "任务状态",
            "enum": [
              "pending",
              "processing",
              "completed",
              "failed"
            ],
            "example": "pending"
          },
          "task_info": {
            "$ref": "#/components/schemas/TaskInfo",
            "description": "任务详细信息"
          },
          "type": {
            "type": "string",
            "enum": [
              "text",
              "image",
              "audio",
              "video"
            ],
            "description": "任务的输出类型",
            "example": "video"
          },
          "usage": {
            "$ref": "#/components/schemas/Usage",
            "description": "使用量和计费信息"
          }
        }
      },
      "TaskInfo": {
        "type": "object",
        "properties": {
          "can_cancel": {
            "type": "boolean",
            "description": "任务是否可以取消",
            "example": true
          },
          "estimated_time": {
            "type": "integer",
            "description": "预估完成时间（秒）",
            "minimum": 0,
            "example": 30
          }
        }
      },
      "Usage": {
        "type": "object",
        "description": "使用量和计费信息",
        "properties": {
          "billing_rule": {
            "type": "string",
            "description": "计费规则",
            "enum": [
              "per_call",
              "per_token",
              "per_second"
            ],
            "example": "per_call"
          },
          "credits_reserved": {
            "type": "number",
            "description": "预估消耗积分数（素材上传当前不收费）",
            "minimum": 0,
            "example": 0
          },
          "user_group": {
            "type": "string",
            "description": "用户组类别",
            "example": "default"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "object",
            "properties": {
              "code": {
                "type": "string",
                "description": "错误代码标识符"
              },
              "message": {
                "type": "string",
                "description": "错误描述信息"
              },
              "type": {
                "type": "string",
                "description": "错误类型"
              }
            }
          }
        }
      }
    },
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "##所有接口均需要使用Bearer Token进行认证##\n\n**获取 API Key：**\n\n访问 [API Key 管理页面](https://evolink.ai/dashboard/keys) 获取您的 API Key\n\n**使用时在请求头中添加：**\n```\nAuthorization: Bearer YOUR_API_KEY\n```"
      }
    }
  },
  "tags": [
    {
      "name": "素材上传",
      "description": "Seedance 私域素材上传接口"
    }
  ]
}
