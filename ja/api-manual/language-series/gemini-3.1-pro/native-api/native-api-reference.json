              "OUTCOME_UNSPECIFIED",
              "OUTCOME_OK",
              "OUTCOME_FAILED",
              "OUTCOME_DEADLINE_EXCEEDED"
            ],
            "example": "OUTCOME_OK"
          },
          "output": {
            "type": "string",
            "description": "Standard output, error output, or other description"
          }
