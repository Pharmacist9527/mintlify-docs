                    "type": "service_unavailable_error"
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "ChatCompletionRequest": {
        "type": "object",
        "required": [
          "model",
          "messages"
        ],
        "properties": {
          "model": {
            "type": "string",
            "description": "会話モデル名\n\n- `deepseek-v4-flash`：高速汎用モデル、1M コンテキスト\n- `deepseek-v4-pro`：深度推論モデル、数学、プログラミング、複雑なロジックが得意\n\n**ヒント**：両モデルは **`thinking` がデフォルトで有効** であり、レスポンスには `reasoning_content` が含まれます。`thinking.type=\"disabled\"` で無効化すると出力 token コストを削減できます。両モデルのパラメータは完全に同一です。",
            "enum": [
              "deepseek-v4-flash",
              "deepseek-v4-pro"
            ],
            "default": "deepseek-v4-flash",
            "example": "deepseek-v4-flash"
          },
          "messages": {
            "type": "array",
            "description": "会話メッセージリスト、マルチターン会話をサポート\n\n役割ごとにメッセージのフィールド構造が異なるため、該当する役割を選択して確認してください",
            "items": {
              "oneOf": [
                {
                  "$ref": "#/components/schemas/SystemMessage"
                },
                {
                  "$ref": "#/components/schemas/UserMessage"
                },
                {
                  "$ref": "#/components/schemas/AssistantRequestMessage"
                },
                {
                  "$ref": "#/components/schemas/ToolMessage"
                }
              ],
              "discriminator": {
                "propertyName": "role",
                "mapping": {
                  "system": "#/components/schemas/SystemMessage",
                  "user": "#/components/schemas/UserMessage",
                  "assistant": "#/components/schemas/AssistantRequestMessage",
                  "tool": "#/components/schemas/ToolMessage"
                }
              }
            },
            "minItems": 1
          },
          "thinking": {
            "type": "object",
            "description": "思考モード制御（V4 新機能）\n\n**説明**：\n- 深度思考（Chain of Thought）機能を制御するために使用\n- **両モデルともデフォルトで有効**（`type=enabled`）\n- 有効時、推論過程は `choices[].message.reasoning_content` で返され、出力 token として課金されます\n\n⚠️ **マルチターン会話 / ツール呼び出しの注意**：本ターンのレスポンスに `reasoning_content` が含まれている場合、**次のリクエストの `messages` 履歴の該当 assistant メッセージでこのフィールドをそのまま返送する必要があります**。さもないと API は 400 `The reasoning_content in the thinking mode must be passed back to the API` を返します。処理したくない場合は、セッション全体で明示的に `thinking.type=\"disabled\"` を指定できます。",
            "properties": {
              "type": {
                "type": "string",
                "description": "思考モードスイッチ\n\n- `enabled`：深度思考を有効化（デフォルト）\n- `disabled`：深度思考を無効化、モデルは直接回答",
                "enum": [
                  "enabled",
                  "disabled"
                ],
                "default": "enabled"
              },
              "reasoning_effort": {
                "type": "string",
                "description": "推論努力度\n\n- `low`：低努力、レスポンスがより高速、reasoning_tokens がより少ない\n- `medium`：中程度の努力（デフォルト）\n- `high`：高努力、より徹底的な思考過程、より多くの reasoning_tokens を消費",
                "enum": [
                  "low",
                  "medium",
                  "high"
                ],
                "default": "medium"
              }
            }
          },
          "temperature": {
            "type": "number",
            "description": "サンプリング温度、出力のランダム性を制御\n\n**説明**：\n- 低い値（例：0.2）：より確定的で集中した出力\n- 高い値（例：1.5）：よりランダムで創造的な出力\n- デフォルト値：1",
            "minimum": 0,
            "maximum": 2,
            "default": 1,
            "example": 1
          },
          "top_p": {
            "type": "number",
            "description": "核サンプリング（Nucleus Sampling）パラメータ\n\n**説明**：\n- 累積確率の上位何％の token からサンプリングするかを制御\n- 例：0.9 は累積確率が 90% に達する token から選択\n- デフォルト値：1.0（すべての token を考慮）\n\n**推奨**：temperature と top_p を同時に調整しないでください",
            "minimum": 0,
            "maximum": 1,
            "default": 1,
            "example": 1
          },
          "max_tokens": {
            "type": "integer",
            "description": "生成するコンテンツの最大 token 数を制限\n\n**説明**：\n- V4 シリーズは最大 **384,000 tokens** まで可能\n- thinking 有効時、reasoning_tokens も max_tokens の上限に含まれます\n- 未設定の場合、モデル自身が生成長さを決定",
            "minimum": 1,
            "maximum": 384000,
            "example": 4096
          },
          "frequency_penalty": {
            "type": "number",
            "description": "頻度ペナルティパラメータ、繰り返し内容を減らすため\n\n**説明**：\n- 正の値は、生成済みテキストで出現した token の頻度に基づいてペナルティを与えます\n- 値が大きいほど、既出の内容を繰り返しにくくなります\n- デフォルト値：0（ペナルティなし）",
            "minimum": -2,
            "maximum": 2,
            "default": 0,
            "example": 0
          },
          "presence_penalty": {
            "type": "number",
            "description": "存在ペナルティパラメータ、新しいトピックの生成を促進するため\n\n**説明**：\n- 正の値は、token がテキストに既出かどうかに基づいてペナルティを与えます\n- 値が大きいほど、新しいトピックを議論する傾向が強くなります\n- デフォルト値：0（ペナルティなし）",
            "minimum": -2,
            "maximum": 2,
            "default": 0,
            "example": 0
          },
          "response_format": {
            "type": "object",
            "description": "レスポンスフォーマットを指定\n\n**説明**：\n- `{\"type\": \"json_object\"}` に設定すると JSON モードを有効化\n- JSON モード下、モデルは有効な JSON 形式のコンテンツを出力します\n- 最適な効果を得るため、system または user メッセージで JSON 出力を明示的に要求することを推奨",
            "properties": {
              "type": {
                "type": "string",
                "enum": [
                  "text",
                  "json_object"
                ],
                "description": "レスポンスフォーマットタイプ",
                "default": "text"
              }
            }
          },
          "stop": {
            "description": "停止シーケンス、モデルがこれらの文字列に遭遇すると生成を停止\n\n**説明**：\n- 単一文字列または文字列配列を指定可能\n- 最大 16 個の停止シーケンスをサポート",
            "oneOf": [
              {
                "type": "string"
              },
              {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "maxItems": 16
              }
            ]
          },
          "stream": {
            "type": "boolean",
            "description": "ストリーミング方式でレスポンスを返すかどうか\n\n- `true`：ストリーミング返却、SSE（Server-Sent Events）を通じてチャンクごとにリアルタイムでコンテンツを返す\n- `false`：完全なレスポンスを待ってから一度に返す（デフォルト）",
            "default": false,
            "example": false
          },
          "stream_options": {
            "type": "object",
            "description": "ストリーミングレスポンスオプション\n\n`stream=true` の場合のみ有効",
            "properties": {
              "include_usage": {
                "type": "boolean",
                "description": "ストリーミング終了時に usage 統計情報を返す（キャッシュ分項を含む）"
              }
            }
          },
          "tools": {
            "type": "array",
            "description": "ツール定義リスト、Function Calling に使用\n\n**説明**：\n- 最大 128 個のツール定義をサポート\n- 各ツールには名前、説明、パラメータ schema を定義する必要があります",
            "items": {
              "$ref": "#/components/schemas/Tool"
            },
            "maxItems": 128
          },
          "tool_choice": {
            "description": "ツール呼び出し動作を制御\n\n**選択可能な値**：\n- `none`：いかなるツールも呼び出さない\n- `auto`：モデルが自動的にツール呼び出しを決定（tools 提供時のデフォルト）\n- `required`：モデルに 1 つ以上のツールを強制的に呼び出させる\n- オブジェクト形式 `{\"type\":\"function\",\"function\":{\"name\":\"xxx\"}}`：特定のツール呼び出しを指定\n\n**デフォルト値**：tools を提供しない場合は `none`、提供する場合は `auto`",
            "oneOf": [
              {
                "type": "string",
                "enum": [
                  "none",
                  "auto",
                  "required"
                ]
              },
              {
                "type": "object",
                "description": "特定のツール呼び出しを指定",
                "properties": {
                  "type": {
                    "type": "string",
                    "enum": [
                      "function"
                    ]
                  },
                  "function": {
                    "type": "object",
                    "properties": {
                      "name": {
                        "type": "string",
                        "description": "呼び出す関数名"
                      }
                    },
                    "required": [
                      "name"
                    ]
                  }
                }
              }
            ]
          },
          "logprobs": {
            "type": "boolean",
            "description": "token の対数確率を返すかどうか\n\n**説明**：\n- `true` に設定すると、レスポンスに各 token の対数確率情報が含まれます",
            "default": false
          },
          "top_logprobs": {
            "type": "integer",
            "description": "確率の最も高い上位 N 個の token の対数確率を返す\n\n**説明**：\n- `logprobs` を `true` に設定する必要があります\n- 値の範囲：`[0, 20]`",
            "minimum": 0,
            "maximum": 20
          },
          "logit_bias": {
            "type": "object",
            "description": "Token バイアスマッピング\n\n**説明**：\n- キーは tokenizer 中の token ID、値は -100 から 100 の間のバイアス値\n- -100 はその token を完全に禁止、100 は強制生成\n- 典型的な値の範囲 -1 から 1 でも観測可能な影響を及ぼします",
            "additionalProperties": {
              "type": "number",
              "minimum": -100,
              "maximum": 100
            }
          },
          "n": {
            "type": "integer",
            "description": "各入力メッセージに対して生成するチャット補完オプションの数\n\n**説明**：\n- デフォルト 1；N に設定すると N 個の候補が返されます（N × output_tokens で課金）",
            "minimum": 1,
            "maximum": 8,
            "default": 1,
            "example": 1
          },
          "seed": {
            "type": "integer",
            "description": "ランダムシード（Beta）\n\n**説明**：\n- 指定するとモデルは確定的サンプリングを試みます\n- 同じ seed + 同じ他のパラメータ → 同じ出力（100% の保証ではない）"
          },
          "user": {
            "type": "string",
            "description": "エンドユーザーを表す一意の識別子\n\n**説明**：\n- プラットフォームの悪用監視と検出に役立ちます\n- ハッシュ化されたユーザー ID の使用を推奨"
          }
        }
      },
