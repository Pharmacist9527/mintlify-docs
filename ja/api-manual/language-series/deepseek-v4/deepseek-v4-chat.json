                  "type": "string",
                  "enum": [
                    "function"
                  ]
                },
                "function": {
                  "type": "object",
                  "properties": {
                    "name": {
                      "type": "string",
                      "description": "呼び出す関数名"
                    },
                    "arguments": {
                      "type": "string",
                      "description": "関数パラメータ（JSON 文字列）"
                    }
                  }
                }
              }
            }
          }
        }
      },
