            "enum": [
              "severe_violation",
              "violence"
            ]
          }
        }
      },
      "AssistantMessage": {
        "type": "object",
        "properties": {
          "role": {
            "type": "string",
            "description": "コンテンツ出力のロール、assistantに固定",
            "enum": [
              "assistant"
