            "$ref": "#/components/schemas/AssistantMessage"
          },
          "finish_reason": {
            "type": "string",
            "description": "モデルがトークン生成を停止した理由\n\n- `stop`: モデル出力が自然に終了、またはstopパラメータで指定されたフィールドにヒットして切り捨てられました\n- `length`: モデル出力がmax_tokens / max_completion_tokens / コンテキスト長制限に達したため切り捨てられました\n- `content_filter`: モデル出力がコンテンツ審査によりブロック\n- `tool_calls`: モデルがツールを呼び出しました",
            "enum": [
              "stop",
              "length",
              "content_filter",
              "tool_calls"
            ],
            "example": "stop"
          },
          "logprobs": {
            "type": "object",
            "nullable": true,
            "description": "現在のコンテンツの対数確率情報",
            "properties": {
              "content": {
                "type": "array",
                "nullable": true,
                "description": "各content要素のトークン対数確率情報",
                "items": {
                  "$ref": "#/components/schemas/LogprobContent"
                }
              }
            }
          },
          "moderation_hit_type": {
            "type": "string",
            "nullable": true,
