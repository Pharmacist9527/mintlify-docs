{
  "openapi": "3.1.0",
  "info": {
    "title": "wan2.7-reference-video API",
    "description": "WAN2.7モデルを使用して、参照画像、参照動画およびオーディオをアップロードして参照動画から新しい動画を生成します",
    "license": {
      "name": "MIT"
    },
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://api.evolink.ai",
      "description": "本番環境"
    }
  ],
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "paths": {
    "/v1/videos/generations": {
      "post": {
        "summary": "wan2.7-reference-video API",
        "description": "- WAN2.7（wan2.7-reference-video）モデルは参照動画から動画への生成をサポートしています\n- 先頭フレーム画像、複数の参照画像、複数の参照動画および参照オーディオのアップロードをサポートしています\n- 少なくとも1つの参照画像（`image_urls`）または参照動画（`video_urls`）を提供する**必要があります**。`image_start`のみではこの要件を満たしません\n- 非同期処理モード、返されたタスクIDを使用して[ステータスを照会](/ja/api-manual/task-management/get-task-detail)してください\n- 生成された動画リンクは24時間有効です。速やかに保存してください\n- **課金説明**：「入力動画の長さ + 出力動画の長さ」の合算課金を採用しています。動画の生成が成功した場合のみ課金され、失敗した場合は課金されません",
        "operationId": "createWan27ReferenceVideoGeneration",
        "tags": [
          "動画生成"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/Wan27ReferenceVideoRequest"
              },
              "examples": {
                "reference_video": {
                  "summary": "参照動画から動画生成",
                  "value": {
                    "model": "wan2.7-reference-video",
                    "prompt": "A cat playing piano",
                    "video_urls": [
                      "https://example.com/reference.mp4"
                    ]
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "動画タスクが正常に作成されました",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/VideoGenerationResponse"
                }
              }
            }
          },
          "400": {
            "description": "リクエストパラメータが不正です",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "error": {
                    "code": "invalid_request",
                    "message": "Invalid request parameters",
                    "type": "invalid_request_error"
                  }
                }
              }
            }
          },
          "401": {
            "description": "未認証、トークンが無効または期限切れです",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "error": {
                    "code": "unauthorized",
                    "message": "Invalid or expired token",
                    "type": "authentication_error"
                  }
                }
              }
            }
          },
          "402": {
            "description": "クォータ不足のため、チャージが必要です",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "error": {
                    "code": "insufficient_quota",
                    "message": "Insufficient quota. Please top up your account.",
                    "type": "insufficient_quota"
                  }
                }
              }
            }
          },
          "403": {
            "description": "アクセスが拒否されました",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "error": {
                    "code": "model_access_denied",
                    "message": "Token does not have access to model: wan2.7-reference-video",
                    "type": "invalid_request_error"
                  }
                }
              }
            }
          },
          "429": {
            "description": "レート制限を超えました",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "error": {
                    "code": "rate_limit_exceeded",
                    "message": "Too many requests, please try again later",
                    "type": "rate_limit_error"
                  }
                }
              }
            }
          },
          "500": {
            "description": "サーバー内部エラー",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "error": {
                    "code": "internal_error",
                    "message": "Internal server error",
                    "type": "api_error"
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Wan27ReferenceVideoRequest": {
        "required": [
          "model",
          "prompt"
        ],
        "type": "object",
        "properties": {
          "model": {
            "type": "string",
            "description": "モデル名、`wan2.7-reference-video`固定",
            "enum": [
              "wan2.7-reference-video"
            ],
            "example": "wan2.7-reference-video"
          },
          "prompt": {
            "type": "string",
            "description": "動画生成のテキストプロンプト",
            "example": "A cat playing piano"
          },
          "negative_prompt": {
            "type": "string",
            "description": "ネガティブプロンプト、動画に表示したくない内容を記述します、最大500文字",
            "maxLength": 500,
            "example": "Blurry, low quality"
          },
          "image_start": {
            "type": "string",
            "format": "uri",
            "description": "先頭フレーム画像URL、動画の開始画面として使用されます。image_urls + video_urlsの5つの参照メディア制限にはカウントされません\n\n**画像制限：**\n- 形式：JPEG、JPG、PNG（透明チャンネル非対応）、BMP、WEBP\n- 解像度：幅と高さの範囲は`[240, 8000]`ピクセル\n- アスペクト比：1:8〜8:1\n- ファイルサイズ：最大`20MB`",
            "example": "https://example.com/first_frame.jpg"
          },
          "image_urls": {
            "type": "array",
            "items": {
              "type": "string",
              "format": "uri"
            },
            "description": "参照画像URL配列（reference_image）、image_urls + video_urlsの合計は5つ以下\n\n**画像制限：**\n- 形式：JPEG、JPG、PNG（透明チャンネル非対応）、BMP、WEBP\n- 解像度：幅と高さの範囲は`[240, 8000]`ピクセル\n- アスペクト比：1:8〜8:1\n- ファイルサイズ：最大`20MB`",
            "example": ["https://example.com/ref1.jpg", "https://example.com/ref2.jpg"]
          },
          "video_urls": {
            "type": "array",
            "items": {
              "type": "string",
              "format": "uri"
            },
            "description": "参照動画URL配列（reference_video）、image_urls + video_urlsの合計は5つ以下\n\n**動画制限：**\n- 形式：mp4、mov\n- 長さ：`2〜10`秒\n- 解像度：幅と高さの範囲は`[240, 4096]`ピクセル\n- アスペクト比：1:8〜8:1\n- ファイルサイズ：最大`100MB`",
            "example": ["https://example.com/reference.mp4"]
          },
          "audio_urls": {
            "type": "array",
            "items": {
              "type": "string",
              "format": "uri"
            },
            "maxItems": 5,
            "description": "参照音声URL配列（reference_voice）、各音声は参照メディア（image_urls/video_urls）に順番に対応づけられます。1つ目の音声は1つ目の参照メディアに、2つ目は2つ目に対応します。参照動画に含まれるオーディオより優先されます。最大 5 要素です。\n\n**互換性：** `audio_url`（単一の文字列）も単一音声の代替として利用できます\n\n**形式要件：**\n- サポートされる形式：`wav`、`mp3`\n- 長さ：`2〜30`秒\n- ファイルサイズ：最大`15MB`",
            "example": ["https://example.com/voice1.mp3", "https://example.com/voice2.mp3"]
          },
          "quality": {
            "type": "string",
            "description": "動画の画質、デフォルトは`720p`\n\n**説明：**\n- `720p`：標準画質、標準価格、これがデフォルトです\n- `1080p`：高画質、価格が上がります",
            "enum": [
              "720p",
              "1080p"
            ],
            "default": "720p",
            "example": "720p"
          },
          "aspect_ratio": {
            "type": "string",
            "description": "動画のアスペクト比、デフォルトは`16:9`\n\n**説明：**\n- `720p`：`16:9`（横向き）、`9:16`（縦向き）、`1:1`（正方形）、`4:3`、`3:4`をサポート\n- `1080p`：`16:9`（横向き）、`9:16`（縦向き）、`1:1`（正方形）、`4:3`、`3:4`をサポート",
            "enum": [
              "16:9",
              "9:16",
              "1:1",
              "4:3",
              "3:4"
            ],
            "default": "16:9",
            "example": "16:9"
          },
          "duration": {
            "type": "number",
            "description": "動画の長さ（秒）。有効範囲は 2-15 です。参照動画モードでは、各参照動画の長さは最大 10 秒です。`duration` に基づいて事前課金され、最終的な請求は生成された動画の実際の秒数に基づきます。",
            "minimum": 2,
            "maximum": 15,
            "example": 5
          },
          "seed": {
            "type": "integer",
            "description": "ランダムシード、生成結果の再現に使用します",
            "example": 42
          },
          "prompt_extend": {
            "type": "boolean",
            "description": "インテリジェントプロンプト書き換えを有効にするかどうか。有効にすると、大規模モデルがプロンプトを最適化し、シンプルまたは説明が不十分なプロンプトの結果を大幅に改善します。デフォルトは`true`",
            "default": true,
            "example": true
          },
          "callback_url": {
            "type": "string",
            "description": "タスク完了時のHTTPSコールバックURL\n\n**コールバックのタイミング：**\n- タスクが完了（completed）、失敗（failed）、またはキャンセル（cancelled）された時にトリガーされます\n- 課金確認後に送信されます\n\n**セキュリティ制限：**\n- HTTPSプロトコルのみサポートされています\n- 内部IPアドレスへのコールバックは禁止されています（127.0.0.1、10.x.x.x、172.16-31.x.x、192.168.x.x など）\n- URLの長さは`2048`文字を超えてはなりません\n\n**コールバックメカニズム：**\n- タイムアウト：`10`秒\n- 失敗後最大`3`回リトライ（失敗後`1`/`2`/`4`秒でリトライ）\n- コールバックのレスポンス形式はタスク照会APIのレスポンスと同一です\n- 2xxステータスコードは成功とみなされ、その他のステータスコードはリトライをトリガーします",
            "format": "uri",
            "example": "https://your-domain.com/webhooks/video-task-completed"
          }
        }
      },
      "VideoGenerationResponse": {
        "type": "object",
        "properties": {
          "created": {
            "type": "integer",
            "description": "タスク作成タイムスタンプ",
            "example": 1757169743
          },
          "id": {
            "type": "string",
            "description": "タスクID",
            "example": "task-unified-1757169743-7cvnl5zw"
          },
          "model": {
            "type": "string",
            "description": "使用された実際のモデル名",
            "example": "wan2.7-reference-video"
          },
          "object": {
            "type": "string",
            "enum": [
              "video.generation.task"
            ],
            "description": "タスクタイプ"
          },
          "progress": {
            "type": "integer",
            "description": "タスク進捗率（0-100）",
            "minimum": 0,
            "maximum": 100,
            "example": 0
          },
          "status": {
            "type": "string",
            "description": "タスクステータス",
            "enum": [
              "pending",
              "processing",
              "completed",
              "failed"
            ],
            "example": "pending"
          },
          "task_info": {
            "$ref": "#/components/schemas/VideoTaskInfo",
            "description": "動画タスクの詳細"
          },
          "type": {
            "type": "string",
            "enum": [
              "text",
              "image",
              "audio",
              "video"
            ],
            "description": "タスク出力タイプ",
            "example": "video"
          },
          "usage": {
            "$ref": "#/components/schemas/Usage",
            "description": "使用量と課金情報"
          }
        }
      },
      "VideoTaskInfo": {
        "type": "object",
        "properties": {
          "can_cancel": {
            "type": "boolean",
            "description": "タスクをキャンセルできるかどうか",
            "example": true
          },
          "estimated_time": {
            "type": "integer",
            "description": "推定完了時間（秒）",
            "minimum": 0,
            "example": 120
          }
        }
      },
      "Usage": {
        "type": "object",
        "description": "使用量と課金情報",
        "properties": {
          "billing_rule": {
            "type": "string",
            "description": "課金ルール",
            "enum": [
              "per_call",
              "per_token",
              "per_second"
            ],
            "example": "per_call"
          },
          "credits_reserved": {
            "type": "number",
            "description": "推定消費クレジット数",
            "minimum": 0,
            "example": 5
          },
          "user_group": {
            "type": "string",
            "description": "ユーザーグループカテゴリ",
            "enum": [
              "default",
              "vip"
            ],
            "example": "default"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "object",
            "properties": {
              "code": {
                "type": "string",
                "description": "エラーコード識別子"
              },
              "message": {
                "type": "string",
                "description": "エラーの説明"
              },
              "type": {
                "type": "string",
                "description": "エラータイプ"
              }
            }
          }
        }
      }
    },
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "## すべてのAPIにBearer Token認証が必要です ##\n\n**APIキーの取得：**\n\n[APIキー管理ページ](https://evolink.ai/dashboard/keys)にアクセスしてAPIキーを取得してください\n\n**リクエストヘッダーに追加：**\n```\nAuthorization: Bearer YOUR_API_KEY\n```"
      }
    }
  }
}
