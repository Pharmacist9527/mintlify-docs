{
  "openapi": "3.1.0",
  "info": {
    "title": "wan2.7-image-to-video API",
    "description": "WAN2.7モデルを使用して、先頭フレーム/末尾フレーム画像、参照動画クリップおよびオーディオ駆動による画像から動画を生成します",
    "license": {
      "name": "MIT"
    },
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://api.evolink.ai",
      "description": "本番環境"
    }
  ],
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "paths": {
    "/v1/videos/generations": {
      "post": {
        "summary": "wan2.7-image-to-video API",
        "description": "- WAN2.7（wan2.7-image-to-video）モデルは画像から動画への生成をサポートしています\n- 以下の6種類の素材の組み合わせをサポートしています。不正な組み合わせはエラーになります：\n  1. 先頭フレーム画像（`image_start`）\n  2. 先頭フレーム画像 + オーディオ（`image_start` + `audio_url`）\n  3. 先頭フレーム画像 + 末尾フレーム画像（`image_start` + `image_end`）\n  4. 先頭フレーム画像 + 末尾フレーム画像 + オーディオ（`image_start` + `image_end` + `audio_url`）\n  5. 動画続行（`video_urls`）\n  6. 動画続行 + 末尾フレーム画像（`video_urls` + `image_end`）\n- 注意：`image_start`と`video_urls`は排他的です。`video_urls`は`audio_url`と同時に使用できません\n- 非同期処理モード、返されたタスクIDを使用して[ステータスを照会](/ja/api-manual/task-management/get-task-detail)してください\n- 生成された動画リンクは24時間有効です。速やかに保存してください",
        "operationId": "createWan27ImageToVideoGeneration",
        "tags": [
          "動画生成"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/Wan27ImageToVideoRequest"
              },
              "examples": {
                "image_to_video": {
                  "summary": "先頭フレーム画像から動画生成",
                  "value": {
                    "model": "wan2.7-image-to-video",
                    "prompt": "A cat playing piano",
                    "image_start": "https://example.com/first_frame.jpg"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "動画タスクが正常に作成されました",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/VideoGenerationResponse"
                }
              }
            }
          },
          "400": {
            "description": "リクエストパラメータが不正です",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "error": {
                    "code": "invalid_request",
                    "message": "Invalid request parameters",
                    "type": "invalid_request_error"
                  }
                }
              }
            }
          },
          "401": {
            "description": "未認証、トークンが無効または期限切れです",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "error": {
                    "code": "unauthorized",
                    "message": "Invalid or expired token",
                    "type": "authentication_error"
                  }
                }
              }
            }
          },
          "402": {
            "description": "クォータ不足のため、チャージが必要です",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "error": {
                    "code": "insufficient_quota",
                    "message": "Insufficient quota. Please top up your account.",
                    "type": "insufficient_quota"
                  }
                }
              }
            }
          },
          "403": {
            "description": "アクセスが拒否されました",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "error": {
                    "code": "model_access_denied",
                    "message": "Token does not have access to model: wan2.7-image-to-video",
                    "type": "invalid_request_error"
                  }
                }
              }
            }
          },
          "429": {
            "description": "レート制限を超えました",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "error": {
                    "code": "rate_limit_exceeded",
                    "message": "Too many requests, please try again later",
                    "type": "rate_limit_error"
                  }
                }
              }
            }
          },
          "500": {
            "description": "サーバー内部エラー",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "error": {
                    "code": "internal_error",
                    "message": "Internal server error",
                    "type": "api_error"
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Wan27ImageToVideoRequest": {
        "required": [
          "model"
        ],
        "type": "object",
        "properties": {
          "model": {
            "type": "string",
            "description": "モデル名、`wan2.7-image-to-video`固定",
            "enum": [
              "wan2.7-image-to-video"
            ],
            "example": "wan2.7-image-to-video"
          },
          "prompt": {
            "type": "string",
            "description": "動画生成のテキストプロンプト、最大5000文字",
            "maxLength": 5000,
            "example": "A cat playing piano"
          },
          "negative_prompt": {
            "type": "string",
            "description": "ネガティブプロンプト、動画に表示したくない内容を記述します、最大500文字",
            "maxLength": 500,
            "example": "Blurry, low quality"
          },
          "image_start": {
            "type": "string",
            "format": "uri",
            "description": "先頭フレーム画像URL（first_frame）、video_urlsと排他的で同時に送信できません\n\n**画像制限：**\n- 形式：JPEG、JPG、PNG（透明チャンネル非対応）、BMP、WEBP\n- 解像度：幅と高さの範囲は`[240, 8000]`ピクセル\n- アスペクト比：1:8〜8:1\n- ファイルサイズ：最大`20MB`",
            "example": "https://example.com/first_frame.jpg"
          },
          "image_end": {
            "type": "string",
            "format": "uri",
            "description": "末尾フレーム画像URL（last_frame）、image_startまたはvideo_urlsと組み合わせて使用でき、単独では送信できません\n\n**画像制限：**\n- 形式：JPEG、JPG、PNG（透明チャンネル非対応）、BMP、WEBP\n- 解像度：幅と高さの範囲は`[240, 8000]`ピクセル\n- アスペクト比：1:8〜8:1\n- ファイルサイズ：最大`20MB`",
            "example": "https://example.com/last_frame.jpg"
          },
          "video_urls": {
            "type": "array",
            "items": {
              "type": "string",
              "format": "uri"
            },
            "description": "動画続行URL配列（first_clip）、video_urls[0]のみ使用。image_startと排他的で、audio_urlと同時に使用できません\n\n**動画制限：**\n- 形式：mp4、mov\n- 長さ：`2〜10`秒\n- 解像度：幅と高さの範囲は`[240, 4096]`ピクセル\n- アスペクト比：1:8〜8:1\n- ファイルサイズ：最大`100MB`\n\n**続行説明：**\n- モデルはこの動画の内容に基づいて続行生成します。続行の長さの上限はdurationパラメータで制御されます\n- 例：duration=15の場合、入力動画が3秒であれば、モデルは12秒を続行生成し、最終出力動画の合計は15秒で、15秒分課金されます",
            "example": ["https://example.com/clip.mp4"]
          },
          "audio_url": {
            "type": "string",
            "format": "uri",
            "description": "音声ファイルURL（driving_audio）、先頭フレーム画像モードでのみ使用可能で、video_urlsと同時に使用できません\n\n**形式要件：**\n- サポートされる形式：`wav`、`mp3`\n- 長さ：`2〜30`秒\n- ファイルサイズ：最大`15MB`\n\n**オーバーフロー処理：**\n- 音声の長さが`duration`値を超える場合、最初のN秒が自動的に抽出され、残りは破棄されます\n- 音声の長さが動画の長さより短い場合、音声の長さを超える部分は無音になります。例えば、音声が3秒で動画の長さが5秒の場合、出力動画は最初の3秒に音声があり、最後の2秒は無音になります",
            "example": "https://example.com/audio.mp3"
          },
          "quality": {
            "type": "string",
            "description": "動画の画質、デフォルトは`720p`\n\n**説明：**\n- `720p`：標準画質、標準価格、これがデフォルトです\n- `1080p`：高画質、価格が上がります",
            "enum": [
              "720p",
              "1080p"
            ],
            "default": "720p",
            "example": "720p"
          },
          "duration": {
            "type": "number",
            "description": "動画の長さ（秒）、範囲 2-15\n\n**注意：**\n- `2〜15`秒の任意の整数値をサポート\n- 各リクエストは`duration`値に基づいて事前請求され、実際の請求は生成された動画の秒数に基づきます",
            "minimum": 2,
            "maximum": 15,
            "default": 5,
            "example": 5
          },
          "seed": {
            "type": "integer",
            "description": "ランダムシード、生成結果の再現に使用します",
            "example": 42
          },
          "prompt_extend": {
            "type": "boolean",
            "description": "インテリジェントプロンプト書き換えを有効にするかどうか。有効にすると、大規模モデルがプロンプトを最適化し、シンプルまたは説明が不十分なプロンプトの結果を大幅に改善します。デフォルトは`true`",
            "default": true,
            "example": true
          },
          "callback_url": {
            "type": "string",
            "description": "タスク完了時のHTTPSコールバックURL\n\n**コールバックのタイミング：**\n- タスクが完了（completed）、失敗（failed）、またはキャンセル（cancelled）された時にトリガーされます\n- 課金確認後に送信されます\n\n**セキュリティ制限：**\n- HTTPSプロトコルのみサポートされています\n- 内部IPアドレスへのコールバックは禁止されています（127.0.0.1、10.x.x.x、172.16-31.x.x、192.168.x.x など）\n- URLの長さは`2048`文字を超えてはなりません\n\n**コールバックメカニズム：**\n- タイムアウト：`10`秒\n- 失敗後最大`3`回リトライ（失敗後`1`/`2`/`4`秒でリトライ）\n- コールバックのレスポンス形式はタスク照会APIのレスポンスと同一です\n- 2xxステータスコードは成功とみなされ、その他のステータスコードはリトライをトリガーします",
            "format": "uri",
            "example": "https://your-domain.com/webhooks/video-task-completed"
          }
        }
      },
      "VideoGenerationResponse": {
        "type": "object",
        "properties": {
          "created": {
            "type": "integer",
            "description": "タスク作成タイムスタンプ",
            "example": 1757169743
          },
          "id": {
            "type": "string",
            "description": "タスクID",
            "example": "task-unified-1757169743-7cvnl5zw"
          },
          "model": {
            "type": "string",
            "description": "使用された実際のモデル名",
            "example": "wan2.7-image-to-video"
          },
          "object": {
            "type": "string",
            "enum": [
              "video.generation.task"
            ],
            "description": "タスクタイプ"
          },
          "progress": {
            "type": "integer",
            "description": "タスク進捗率（0-100）",
            "minimum": 0,
            "maximum": 100,
            "example": 0
          },
          "status": {
            "type": "string",
            "description": "タスクステータス",
            "enum": [
              "pending",
              "processing",
              "completed",
              "failed"
            ],
            "example": "pending"
          },
          "task_info": {
            "$ref": "#/components/schemas/VideoTaskInfo",
            "description": "動画タスクの詳細"
          },
          "type": {
            "type": "string",
            "enum": [
              "text",
              "image",
              "audio",
              "video"
            ],
            "description": "タスク出力タイプ",
            "example": "video"
          },
          "usage": {
            "$ref": "#/components/schemas/Usage",
            "description": "使用量と課金情報"
          }
        }
      },
      "VideoTaskInfo": {
        "type": "object",
        "properties": {
          "can_cancel": {
            "type": "boolean",
            "description": "タスクをキャンセルできるかどうか",
            "example": true
          },
          "estimated_time": {
            "type": "integer",
            "description": "推定完了時間（秒）",
            "minimum": 0,
            "example": 120
          }
        }
      },
      "Usage": {
        "type": "object",
        "description": "使用量と課金情報",
        "properties": {
          "billing_rule": {
            "type": "string",
            "description": "課金ルール",
            "enum": [
              "per_call",
              "per_token",
              "per_second"
            ],
            "example": "per_call"
          },
          "credits_reserved": {
            "type": "number",
            "description": "推定消費クレジット数",
            "minimum": 0,
            "example": 5
          },
          "user_group": {
            "type": "string",
            "description": "ユーザーグループカテゴリ",
            "enum": [
              "default",
              "vip"
            ],
            "example": "default"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "object",
            "properties": {
              "code": {
                "type": "string",
                "description": "エラーコード識別子"
              },
              "message": {
                "type": "string",
                "description": "エラーの説明"
              },
              "type": {
                "type": "string",
                "description": "エラータイプ"
              }
            }
          }
        }
      }
    },
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "## すべてのAPIにBearer Token認証が必要です ##\n\n**APIキーの取得：**\n\n[APIキー管理ページ](https://evolink.ai/dashboard/keys)にアクセスしてAPIキーを取得してください\n\n**リクエストヘッダーに追加：**\n```\nAuthorization: Bearer YOUR_API_KEY\n```"
      }
    }
  }
}
