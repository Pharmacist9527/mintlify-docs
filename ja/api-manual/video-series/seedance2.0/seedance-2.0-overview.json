{
  "openapi": "3.1.0",
  "info": {
    "title": "Seedance 2.0 全モデル API",
    "description": "Seedance 2.0 全シリーズ6モデルの統一API。テキストから動画、画像から動画、マルチモーダル参照から動画の標準版と高速版に対応",
    "license": {
      "name": "MIT"
    },
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://api.evolink.ai",
      "description": "本番環境"
    }
  ],
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "paths": {
    "/v1/videos/generations": {
      "post": {
        "summary": "Seedance 2.0 動画生成（全モデル）",
        "description": "Seedance 2.0 全シリーズ統一API。`model` パラメータで具体的なモデルを選択\n\n**3つの生成モード：**\n- **Text-to-Video**：テキスト記述のみで動画を生成、ウェブ検索による強化に対応\n- **Image-to-Video**：1〜2枚の画像を先頭/末尾フレームとして動画生成を駆動\n- **Reference-to-Video**：画像 + 動画 + 音声のマルチモーダル素材を混合参照\n\n各モードに標準版と高速版があり、合計6モデル\n\n- **AIGCタイプの実写素材に対応**\n- 非同期処理モード。返却されたタスクIDで[タスク詳細を照会](/ja/api-manual/task-management/get-task-detail)\n- 生成された動画リンクの有効期限は24時間です。お早めに保存してください",
        "operationId": "createSeedance20VideoGeneration",
        "tags": [
          "動画生成"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/VideoGenerationRequest"
              },
              "examples": {
                "text_to_video": {
                  "summary": "テキストから動画",
                  "value": {
                    "model": "seedance-2.0-text-to-video",
                    "prompt": "一只猫在钢琴上弹奏月光奏鸣曲，电影感光影，特写镜头",
                    "duration": 8,
                    "quality": "720p",
                    "aspect_ratio": "16:9",
                    "generate_audio": true
                  }
                },
                "image_to_video": {
                  "summary": "画像から動画（先頭フレーム駆動）",
                  "value": {
                    "model": "seedance-2.0-image-to-video",
                    "prompt": "镜头缓缓推进，花瓣随风飘落",
                    "image_urls": [
                      "https://example.com/flower.jpg"
                    ],
                    "duration": 5,
                    "aspect_ratio": "adaptive",
                    "generate_audio": true
                  }
                },
                "reference_to_video": {
                  "summary": "マルチモーダル参照（画像 + 動画 + 音声）",
                  "value": {
                    "model": "seedance-2.0-reference-to-video",
                    "prompt": "全程使用视频1的第一视角构图，全程使用音频1作为背景音乐。第一人称视角果茶宣传广告...",
                    "image_urls": [
                      "https://example.com/ref1.jpg",
                      "https://example.com/ref2.jpg"
                    ],
                    "video_urls": [
                      "https://example.com/reference.mp4"
                    ],
                    "audio_urls": [
                      "https://example.com/bgm.mp3"
                    ],
                    "duration": 10,
                    "quality": "720p",
                    "aspect_ratio": "16:9",
                    "generate_audio": true
                  }
                },
                "fast_text_to_video": {
                  "summary": "高速版テキストから動画",
                  "value": {
                    "model": "seedance-2.0-fast-text-to-video",
                    "prompt": "城市日落延时摄影，金色光线洒满天际线",
                    "duration": 5,
                    "aspect_ratio": "21:9",
                    "generate_audio": true
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "動画生成タスクの作成に成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/VideoGenerationResponse"
                }
              }
            }
          },
          "400": {
            "description": "リクエストパラメータエラー",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "error": {
                    "code": "invalid_request",
                    "message": "Invalid request parameters",
                    "type": "invalid_request_error"
                  }
                }
              }
            }
          },
          "401": {
            "description": "未認証、Tokenが無効または期限切れ",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "error": {
                    "code": "unauthorized",
                    "message": "Invalid or expired token",
                    "type": "authentication_error"
                  }
                }
              }
            }
          },
          "402": {
            "description": "クォータ不足、チャージが必要",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "error": {
                    "code": "insufficient_quota",
                    "message": "Insufficient quota. Please top up your account.",
                    "type": "insufficient_quota"
                  }
                }
              }
            }
          },
          "403": {
            "description": "アクセス権限なし",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "error": {
                    "code": "model_access_denied",
                    "message": "Token does not have access to the specified model",
                    "type": "invalid_request_error"
                  }
                }
              }
            }
          },
          "429": {
            "description": "リクエスト頻度が上限を超過",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "error": {
                    "code": "rate_limit_exceeded",
                    "message": "Too many requests, please try again later",
                    "type": "rate_limit_error"
                  }
                }
              }
            }
          },
          "500": {
            "description": "サーバー内部エラー",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "error": {
                    "code": "internal_error",
                    "message": "Internal server error",
                    "type": "api_error"
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "VideoGenerationRequest": {
        "type": "object",
        "required": [
          "model",
          "prompt"
        ],
        "properties": {
          "model": {
            "type": "string",
            "description": "動画生成モデル名\n\n| モデル ID | モード | 速度 |\n|:--------|:-----|:-----|\n| `seedance-2.0-text-to-video` | テキストから動画 | 標準 |\n| `seedance-2.0-image-to-video` | 画像から動画 | 標準 |\n| `seedance-2.0-reference-to-video` | マルチモーダル参照 | 標準 |\n| `seedance-2.0-fast-text-to-video` | テキストから動画 | 高速 |\n| `seedance-2.0-fast-image-to-video` | 画像から動画 | 高速 |\n| `seedance-2.0-fast-reference-to-video` | マルチモーダル参照 | 高速 |",
            "enum": [
              "seedance-2.0-text-to-video",
              "seedance-2.0-image-to-video",
              "seedance-2.0-reference-to-video",
              "seedance-2.0-fast-text-to-video",
              "seedance-2.0-fast-image-to-video",
              "seedance-2.0-fast-reference-to-video"
            ],
            "example": "seedance-2.0-text-to-video"
          },
          "prompt": {
            "type": "string",
            "description": "生成したい動画を説明するテキストプロンプト。中国語・英語に対応。中国語は500文字以内、英語は1000語以内を推奨\n\n**モデル別の prompt 使い方：**\n- **Text-to-Video**：テキスト記述のみ。prompt 内での `image_urls`、`video_urls`、`audio_urls` の使用は不可\n- **Image-to-Video**：テキスト記述のみ。prompt 内での `video_urls`、`audio_urls` の使用は不可\n- **Reference-to-Video**：自然言語で各素材の用途を指定可能。例：「先頭フレームは画像1」「動画1のカメラワークを全編で使用」「音声1をBGMとして使用」",
            "example": "一只猫在钢琴上弹奏月光奏鸣曲，电影感光影，特写镜头"
          },
          "image_urls": {
            "type": "array",
            "description": "画像 URL 配列\n\n**対応モデルと枚数制限：**\n- **Text-to-Video**：非対応\n- **Image-to-Video**：必須、**1〜2 枚**\n- **Reference-to-Video**：任意、**0〜9 枚**\n\n**Image-to-Video の画像動作：**\n\n| 画像枚数 | 動作 | 役割 |\n|:--------:|------|------|\n| 1 枚 | 先頭フレーム画像から動画 | 自動的に `first_frame` に設定 |\n| 2 枚 | 先頭・末尾フレーム画像から動画 | 1枚目 → `first_frame`、2枚目 → `last_frame` |\n\n**Reference-to-Video の画像役割：**\n- スタイル参照、商品画像、人物イメージ、先頭/末尾フレーム（promptで指定）\n\n**画像要件：**\n- 対応フォーマット：`.jpeg`、`.png`、`.webp`\n- アスペクト比（幅/高さ）：`0.4` 〜 `2.5`\n- 幅・高さピクセル：`300` 〜 `6000` px\n- 1枚あたりのサイズ：`30MB` 以内\n- リクエストボディの合計サイズは `64MB` 以内\n- 先頭・末尾フレームを入力する場合、2枚の画像は同一でも可。アスペクト比が一致しない場合は先頭フレームを基準とし、末尾フレームは自動的にトリミング・適応されます\n- 画像URLはサーバーから直接アクセス可能である必要があります",
            "items": {
              "type": "string",
              "format": "uri"
            },
            "maxItems": 9,
            "example": [
              "https://example.com/image1.jpg"
            ]
          },
          "video_urls": {
            "type": "array",
            "description": "参照動画 URL 配列\n\n**Reference-to-Video モデルのみ対応**、他のモデルではこのパラメータは使用不可\n\n**数量制限：** 0〜3 本\n\n**役割の説明：**\n- カメラワーク参照、動作参照、編集/延長元の動画\n\n**動画要件：**\n- 対応フォーマット：`.mp4`、`.mov`\n- 解像度：480p、720p\n- 1本あたりの動画時間：`2` 〜 `15` 秒、最大3本、全動画の合計時間 ≤ `15` 秒\n- アスペクト比（幅/高さ）：`0.4` 〜 `2.5`\n- 幅・高さピクセル：`300` 〜 `6000` px\n- 画面ピクセル（幅 × 高さ）：`409,600` 〜 `927,408`（例：640×640 〜 834×1112）\n- 1本あたりのサイズ：`50MB` 以内\n- フレームレート：`24` 〜 `60` FPS\n- 動画参照を使用すると追加料金が発生します（入力動画の再生時間が課金に算入）\n- 動画URLはサーバーから直接アクセス可能である必要があります\n\n**注意：** `audio_urls` のみの入力はできません。少なくとも1枚の画像（`image_urls`）または1本の動画（`video_urls`）を含める必要があります",
            "items": {
              "type": "string",
              "format": "uri"
            },
            "maxItems": 3,
            "example": [
              "https://example.com/reference.mp4"
            ]
          },
          "audio_urls": {
            "type": "array",
            "description": "参照音声 URL 配列\n\n**Reference-to-Video モデルのみ対応**、他のモデルではこのパラメータは使用不可\n\n**数量制限：** 0〜3 本\n\n**役割の説明：**\n- BGM、効果音、音声/セリフ参照\n\n**音声要件：**\n- 対応フォーマット：`.wav`、`.mp3`\n- 1本あたりの音声時間：`2` 〜 `15` 秒、最大3本、全音声の合計時間 ≤ `15` 秒\n- 1本あたりのサイズ：`15MB` 以内\n- 音声URLはサーバーから直接アクセス可能である必要があります\n\n**注意：** `audio_urls` のみの入力はできません。少なくとも1枚の画像または1本の動画を含める必要があります",
            "items": {
              "type": "string",
              "format": "uri"
            },
            "maxItems": 3,
            "example": [
              "https://example.com/bgm.mp3"
            ]
          },
          "duration": {
            "type": "integer",
            "description": "出力動画の再生時間（秒）、デフォルトは `5` 秒\n\n- `4`〜`15` 秒の任意の整数値に対応\n- 再生時間は課金に直接影響します\n- 全6モデルに適用",
            "default": 5,
            "minimum": 4,
            "maximum": 15,
            "example": 8
          },
          "quality": {
            "type": "string",
            "description": "動画の解像度、デフォルトは `720p`\n\n**選択可能な値：**\n- `480p`：解像度が低め、料金も低め\n- `720p`：標準解像度、デフォルト値\n- `1080p`：超高解像度、**標準版モデルのみ対応**（Text-to-Video、Image-to-Video、Reference-to-Video）。3つのFastモデルは未対応\n\n`480p` と `720p` は全6モデルに適用",
            "enum": [
              "480p",
              "720p",
              "1080p"
            ],
            "default": "720p",
            "example": "720p"
          },
          "aspect_ratio": {
            "type": "string",
            "description": "動画のアスペクト比、デフォルトは `16:9`\n\n**選択可能な値：**\n- `16:9`（横向き）、`9:16`（縦向き）、`1:1`（正方形）、`4:3`、`3:4`、`21:9`（ウルトラワイド）\n- `adaptive`：最適な比率を自動選択\n\n**`adaptive` のモデル別動作：**\n- **Text-to-Video**：プロンプトの内容に基づいて自動選択\n- **Image-to-Video**：先頭フレーム画像のアスペクト比に基づいて自動適応\n- **Reference-to-Video**：優先順位：動画素材の比率 > 画像素材の比率 > プロンプトからの推測\n\n**各解像度の対応ピクセル値：**\n\n| アスペクト比 | 480p | 720p | 1080p |\n|:------:|:----:|:----:|:-----:|\n| 16:9 | 864×496 | 1280×720 | 1920×1080 |\n| 4:3 | 752×560 | 1112×834 | 1664×1248 |\n| 1:1 | 640×640 | 960×960 | 1440×1440 |\n| 3:4 | 560×752 | 834×1112 | 1248×1664 |\n| 9:16 | 496×864 | 720×1280 | 1080×1920 |\n| 21:9 | 992×432 | 1470×630 | 2206×946 |\n\n*1080pは標準版モデルのみ対応*",
            "enum": [
              "16:9",
              "9:16",
              "1:1",
              "4:3",
              "3:4",
              "21:9",
              "adaptive"
            ],
            "default": "16:9",
            "example": "16:9"
          },
          "generate_audio": {
            "type": "boolean",
            "description": "同期音声を生成するかどうか、デフォルトは `true`\n\n- `true`：動画に同期音声（人声、効果音、BGM）を含む、追加料金なし\n- `false`：無音動画を出力\n\n全6モデルに適用",
            "default": true,
            "example": true
          },
          "model_params": {
            "type": "object",
            "description": "モデル拡張パラメータ\n\n**Text-to-Video モデルのみ対応**（標準版と高速版）",
            "properties": {
              "web_search": {
                "type": "boolean",
                "description": "ウェブ検索、デフォルトは `false`\n\n**Text-to-Video モデルのみ対応**（`seedance-2.0-text-to-video` および `seedance-2.0-fast-text-to-video`）\n\n**説明：**\n- 有効にするとモデルがプロンプトに基づいてインターネットコンテンツ（商品、天気など）を検索するかどうかを自動判断し、即時性が向上します\n- 一定のレイテンシが増加します\n- 実際に検索がトリガーされた場合のみ料金が発生し、有効化後に複数回呼び出される可能性があります",
                "default": false,
                "example": false
              }
            }
          },
          "callback_url": {
            "type": "string",
            "description": "タスク完了後の HTTPS コールバックアドレス\n\n**コールバックタイミング：**\n- タスク完了（completed）、失敗（failed）、またはキャンセル（cancelled）時にトリガー\n- 課金確認完了後に送信\n\n**セキュリティ制限：**\n- HTTPS プロトコルのみ対応\n- プライベートIPアドレスへのコールバックは禁止（127.0.0.1、10.x.x.x、172.16-31.x.x、192.168.x.x など）\n- URL の長さは `2048` 文字以内\n\n**コールバックメカニズム：**\n- タイムアウト：`10` 秒\n- 失敗後最大 `3` 回リトライ（失敗後 `1`/`2`/`4` 秒でそれぞれリトライ）\n- コールバックレスポンスボディのフォーマットはタスク照会APIの返却フォーマットと同一\n- 2xx ステータスコードを成功とみなし、その他のステータスコードでリトライをトリガー\n\n全6モデルに適用",
            "format": "uri",
            "example": "https://your-domain.com/webhooks/video-task-completed"
          }
        }
      },
      "VideoGenerationResponse": {
        "type": "object",
        "properties": {
          "created": {
            "type": "integer",
            "description": "タスク作成タイムスタンプ",
            "example": 1761313744
          },
          "id": {
            "type": "string",
            "description": "タスクID",
            "example": "task-unified-1774857405-abc123"
          },
          "model": {
            "type": "string",
            "description": "実際に使用されたモデル名",
            "example": "seedance-2.0-text-to-video"
          },
          "object": {
            "type": "string",
            "enum": [
              "video.generation.task"
            ],
            "description": "タスクの具体的なタイプ"
          },
          "progress": {
            "type": "integer",
            "description": "タスク進捗パーセンテージ (0-100)",
            "minimum": 0,
            "maximum": 100,
            "example": 0
          },
          "status": {
            "type": "string",
            "description": "タスクステータス",
            "enum": [
              "pending",
              "processing",
              "completed",
              "failed"
            ],
            "example": "pending"
          },
          "task_info": {
            "$ref": "#/components/schemas/VideoTaskInfo",
            "description": "動画タスクの詳細情報"
          },
          "type": {
            "type": "string",
            "enum": [
              "text",
              "image",
              "audio",
              "video"
            ],
            "description": "タスクの出力タイプ",
            "example": "video"
          },
          "usage": {
            "$ref": "#/components/schemas/VideoUsage",
            "description": "使用量と課金情報"
          }
        }
      },
      "VideoTaskInfo": {
        "type": "object",
        "properties": {
          "can_cancel": {
            "type": "boolean",
            "description": "タスクがキャンセル可能かどうか",
            "example": true
          },
          "estimated_time": {
            "type": "integer",
            "description": "推定完了時間（秒）",
            "minimum": 0,
            "example": 165
          },
          "video_duration": {
            "type": "integer",
            "description": "動画の再生時間（秒）",
            "example": 8
          }
        }
      },
      "VideoUsage": {
        "type": "object",
        "description": "使用量と課金情報",
        "properties": {
          "billing_rule": {
            "type": "string",
            "description": "課金ルール",
            "enum": [
              "per_call",
              "per_token",
              "per_second"
            ],
            "example": "per_second"
          },
          "credits_reserved": {
            "type": "number",
            "description": "推定消費クレジット数",
            "minimum": 0,
            "example": 50
          },
          "user_group": {
            "type": "string",
            "description": "ユーザーグループカテゴリ",
            "example": "default"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "object",
            "properties": {
              "code": {
                "type": "string",
                "description": "エラーコード識別子"
              },
              "message": {
                "type": "string",
                "description": "エラー説明情報"
              },
              "type": {
                "type": "string",
                "description": "エラータイプ"
              }
            }
          }
        }
      }
    },
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "##すべてのAPIはBearer Tokenによる認証が必要です##\n\n**APIキーの取得：**\n\n[APIキー管理ページ](https://evolink.ai/dashboard/keys) にアクセスしてAPIキーを取得してください\n\n**リクエストヘッダーに以下を追加：**\n```\nAuthorization: Bearer YOUR_API_KEY\n```"
      }
    }
  },
  "tags": [
