{
  "openapi": "3.1.0",
  "info": {
    "title": "File Quota API",
    "description": "Query current user's file usage and remaining quota",
    "license": {
      "name": "MIT"
    },
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://files-api.evolink.ai",
      "description": "File Service"
    }
  ],
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "paths": {
    "/api/v1/files/quota": {
      "get": {
        "summary": "Get File Quota",
        "description": "- Query current user's file usage and remaining quota\n- Default user group allows up to `2000` files\n\n**Note:**\nThe base URL for file APIs is `https://files-api.evolink.ai`",
        "operationId": "getFilesQuota",
        "tags": [
          "File Management"
        ],
        "responses": {
          "200": {
            "description": "Success",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/QuotaResponse"
                },
                "example": {
                  "success": true,
                  "code": 200,
                  "data": {
                    "user_group": "default",
                    "used_files": 35,
                    "max_files": 2000,
                    "remain_files": 65,
                    "is_custom": false,
                    "quota_reason": ""
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "QuotaResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean",
            "description": "Whether the request was successful",
            "example": true
          },
          "code": {
            "type": "integer",
            "description": "Response status code",
            "example": 200
          },
          "data": {
            "$ref": "#/components/schemas/QuotaData"
          }
        }
      },
      "QuotaData": {
        "type": "object",
        "properties": {
          "user_group": {
            "type": "string",
            "description": "User tier: `default` (2000 files)",
            "example": "default"
          },
          "used_files": {
            "type": "integer",
            "description": "Number of files currently stored",
            "example": 35
          },
          "max_files": {
            "type": "integer",
            "description": "Maximum allowed files",
            "example": 2000
          },
          "remain_files": {
            "type": "integer",
            "description": "Remaining upload slots",
            "example": 65
          },
          "is_custom": {
            "type": "boolean",
            "description": "Whether the quota was manually set by an admin",
            "example": false
          },
          "quota_reason": {
            "type": "string",
            "description": "Reason for custom quota (only set when `is_custom` is `true`)",
            "example": ""
          }
        }
      }
    },
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "##All APIs require Bearer Token authentication##\n\n**Get API Key:**\n\nVisit [API Key Management Page](https://evolink.ai/dashboard/keys) to get your API Key\n\n**Add to request header:**\n```\nAuthorization: Bearer YOUR_API_KEY\n```"
      }
    }
  },
  "tags": [
    {
      "name": "File Management",
      "description": "File management related APIs"
    }
  ]
}
