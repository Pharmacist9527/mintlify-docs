{
  "openapi": "3.1.0",
  "info": { "title": "Qwen3.5-Plus DashScope Full Reference", "description": "Qwen3.5-Plus DashScope native protocol full parameter reference", "license": { "name": "MIT" }, "version": "1.0.0" },
  "servers": [{ "url": "https://api.evolink.ai", "description": "Production" }],
  "security": [{ "bearerAuth": [] }],
  "paths": {
    "/api/v1/services/aigc/multimodal-generation/generation": {
      "post": {
        "summary": "Qwen3.5-Plus DashScope Native Protocol",
        "description": "- Alibaba Cloud DashScope native protocol\n- qwen3.5-plus is a multimodal model using the `multimodal-generation` endpoint\n- Parameter structure differs from OpenAI format: request parameters go in the `parameters` field\n- Supported models: `qwen3.5-plus`, `qwen3.5-plus-2026-02-15`",
        "operationId": "createDashScopeQwen35PlusEn",
        "tags": ["Chat Generation"],
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/DashScopeRequest" }, "examples": {
          "simple_text": { "summary": "Simple text chat", "value": { "model": "qwen3.5-plus", "input": { "messages": [{ "role": "user", "content": [{ "text": "Hello, please introduce yourself" }] }] }, "parameters": { "result_format": "message" } } },
          "system_prompt": { "summary": "System prompt", "value": { "model": "qwen3.5-plus", "input": { "messages": [{ "role": "system", "content": [{ "text": "You are a professional assistant" }] }, { "role": "user", "content": [{ "text": "Hello" }] }] }, "parameters": { "result_format": "message", "temperature": 0.7 } } },
          "thinking_mode": { "summary": "Thinking mode", "value": { "model": "qwen3.5-plus", "input": { "messages": [{ "role": "user", "content": [{ "text": "Find all prime numbers between 1 and 100" }] }] }, "parameters": { "result_format": "message", "enable_thinking": true, "thinking_budget": 8192 } } },
          "vision": { "summary": "Image understanding", "value": { "model": "qwen3.5-plus", "input": { "messages": [{ "role": "user", "content": [{ "image": "https://example.com/image.jpg" }, { "text": "Please describe this image" }] }] }, "parameters": { "result_format": "message" } } },
          "streaming": { "summary": "Streaming output", "value": { "model": "qwen3.5-plus", "input": { "messages": [{ "role": "user", "content": [{ "text": "Write a poem about spring" }] }] }, "parameters": { "result_format": "message", "stream": true, "incremental_output": true } } }
        } } } },
        "responses": {
          "200": { "description": "Success", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/DashScopeResponse" } } } },
          "400": { "description": "Bad Request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" }, "example": { "error": { "code": 400, "message": "Invalid request parameters", "type": "invalid_request_error" } } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" }, "example": { "error": { "code": 401, "message": "Invalid or expired token", "type": "authentication_error" } } } } },
          "402": { "description": "Insufficient Quota", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" }, "example": { "error": { "code": 402, "message": "Insufficient quota", "type": "insufficient_quota_error", "fallback_suggestion": "https://evolink.ai/dashboard/billing" } } } } },
          "429": { "description": "Rate Limit Exceeded", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" }, "example": { "error": { "code": 429, "message": "Rate limit exceeded", "type": "rate_limit_error" } } } } },
          "500": { "description": "Internal Server Error", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" }, "example": { "error": { "code": 500, "message": "Internal server error", "type": "internal_server_error" } } } } }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "DashScopeRequest": {
        "type": "object", "required": ["model", "input"],
        "properties": {
          "model": { "type": "string", "description": "Model name", "enum": ["qwen3.5-plus", "qwen3.5-plus-2026-02-15"], "default": "qwen3.5-plus", "example": "qwen3.5-plus" },
          "input": { "type": "object", "required": ["messages"], "description": "Input content", "properties": { "messages": { "type": "array", "description": "Message list; content is an array of objects", "items": { "$ref": "#/components/schemas/DashScopeMessage" } } } },
          "parameters": { "$ref": "#/components/schemas/DashScopeParameters" }
        }
      },
      "DashScopeMessage": {
        "type": "object", "required": ["role", "content"],
        "properties": {
          "role": { "type": "string", "enum": ["user", "assistant", "system", "tool"] },
          "content": { "type": "array", "description": "Content array; supports text, image, video", "items": { "$ref": "#/components/schemas/DashScopeContentPart" } }
        }
      },
      "DashScopeContentPart": {
        "type": "object",
        "properties": {
          "text": { "type": "string", "description": "Text content" },
          "image": { "type": "string", "description": "Image URL or base64 data" },
          "video": { "oneOf": [{ "type": "string" }, { "type": "array", "items": { "type": "string" } }], "description": "Video URL or list of image frames" }
        }
      },
      "DashScopeParameters": {
        "type": "object",
        "properties": {
          "result_format": { "type": "string", "enum": ["message", "text"], "description": "Response format; message is recommended", "default": "message" },
          "stream": { "type": "boolean", "description": "Whether to enable streaming output", "default": false },
          "incremental_output": { "type": "boolean", "description": "Whether to output incrementally in streaming mode (only new content)", "default": false },
          "temperature": { "type": "number", "description": "Sampling temperature (0~2)", "minimum": 0, "maximum": 2, "example": 0.7 },
          "top_p": { "type": "number", "description": "Nucleus sampling probability threshold (0~1)", "minimum": 0, "maximum": 1, "example": 0.9 },
          "top_k": { "type": "integer", "description": "Candidate set size for sampling", "minimum": 0, "example": 50 },
          "max_tokens": { "type": "integer", "description": "Maximum number of output tokens", "minimum": 1, "example": 2048 },
          "seed": { "type": "integer", "description": "Random seed for reproducible results" },
          "stop": { "oneOf": [{ "type": "string" }, { "type": "array", "items": { "type": "string" } }], "description": "Stop sequences" },
          "repetition_penalty": { "type": "number", "description": "Repetition penalty (0~2)", "minimum": 0, "maximum": 2, "default": 1 },
          "presence_penalty": { "type": "number", "description": "Content diversity control (-2~2)", "minimum": -2, "maximum": 2, "default": 0 },
          "response_format": { "type": "object", "description": "Output format, e.g. {\"type\": \"json_object\"}" },
          "enable_thinking": { "type": "boolean", "description": "Whether to enable thinking mode (default true for qwen3.5-plus)", "default": true },
          "thinking_budget": { "type": "integer", "description": "Maximum tokens for chain-of-thought (0~81920)", "minimum": 0, "maximum": 81920 },
          "enable_search": { "type": "boolean", "description": "Whether to enable web search", "default": false },
          "search_options": { "$ref": "#/components/schemas/SearchOptions" },
          "tools": { "type": "array", "description": "Tool definitions", "items": { "$ref": "#/components/schemas/Tool" } },
          "tool_choice": { "oneOf": [{ "type": "string", "enum": ["none", "auto", "required"] }, { "type": "object" }], "description": "Tool selection strategy", "default": "auto" },
          "parallel_tool_calls": { "type": "boolean", "description": "Whether to call multiple tools concurrently", "default": false },
          "enable_code_interpreter": { "type": "boolean", "description": "Whether to enable code interpreter", "default": false },
          "vl_high_resolution_images": { "type": "boolean", "description": "Whether to increase image pixel limit", "default": false }
        }
      },
      "SearchOptions": { "type": "object", "properties": { "forced_search": { "type": "boolean", "default": false }, "search_strategy": { "type": "string", "enum": ["turbo", "max", "agent", "agent_max"], "default": "turbo" }, "enable_source": { "type": "boolean", "default": true }, "enable_citation": { "type": "boolean", "default": false } } },
      "Tool": { "type": "object", "required": ["type", "function"], "properties": { "type": { "type": "string", "enum": ["function"] }, "function": { "type": "object", "required": ["name"], "properties": { "name": { "type": "string" }, "description": { "type": "string" }, "parameters": { "type": "object" } } } } },
      "DashScopeResponse": {
        "type": "object",
        "properties": {
          "request_id": { "type": "string", "example": "req_abc123" },
          "output": { "type": "object", "properties": { "choices": { "type": "array", "items": { "$ref": "#/components/schemas/DashScopeChoice" } } } },
          "usage": { "$ref": "#/components/schemas/DashScopeUsage" }
        }
      },
      "DashScopeChoice": { "type": "object", "properties": { "finish_reason": { "type": "string", "enum": ["stop", "length", "tool_calls"], "example": "stop" }, "message": { "type": "object", "properties": { "role": { "type": "string", "enum": ["assistant"] }, "content": { "type": "string", "example": "Hello! I'm Qwen3.5-Plus..." }, "reasoning_content": { "type": "string", "description": "Chain-of-thought content (when thinking mode is enabled)" }, "tool_calls": { "type": "array", "items": { "type": "object", "properties": { "id": { "type": "string" }, "type": { "type": "string", "enum": ["function"] }, "function": { "type": "object", "properties": { "name": { "type": "string" }, "arguments": { "type": "string" } } } } } } } } } },
      "DashScopeUsage": { "type": "object", "properties": { "input_tokens": { "type": "integer", "example": 13 }, "output_tokens": { "type": "integer", "example": 256 }, "total_tokens": { "type": "integer", "example": 269 } } },
      "ErrorResponse": { "type": "object", "properties": { "error": { "type": "object", "properties": { "code": { "type": "integer" }, "message": { "type": "string" }, "type": { "type": "string" }, "param": { "type": "string" }, "fallback_suggestion": { "type": "string" } } } } }
    },
    "securitySchemes": { "bearerAuth": { "type": "http", "scheme": "bearer", "description": "##All endpoints require Bearer Token authentication##\n\n**Get your API Key:**\n\nVisit [API Key Management](https://evolink.ai/dashboard/keys)\n\n**Add to header:**\n```\nAuthorization: Bearer YOUR_API_KEY\n```" } }
  },
  "tags": [{ "name": "Chat Generation", "description": "AI chat generation endpoints" }]
}
