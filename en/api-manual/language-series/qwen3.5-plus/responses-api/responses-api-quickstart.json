{
  "openapi": "3.1.0",
  "info": { "title": "Qwen3.5-Plus Responses API Quick Start", "description": "Get started with Qwen3.5-Plus Responses API in 5 minutes", "license": { "name": "MIT" }, "version": "1.0.0" },
  "servers": [{ "url": "https://api.evolink.ai", "description": "Production" }],
  "security": [{ "bearerAuth": [] }],
  "paths": {
    "/v1/responses": {
      "post": {
        "summary": "Qwen3.5-Plus Responses API Quick Call",
        "description": "- Call Qwen3.5-Plus using OpenAI Responses API format\n- Supports built-in tools (web search, code interpreter, etc.)\n- Supports `previous_response_id` to simplify multi-turn conversations\n- Supported models: `qwen3.5-plus`, `qwen3.5-plus-2026-02-15`\n- 💡 Need more features? See [Full API Reference](./responses-api-reference)",
        "operationId": "createResponsesQuickQwen35PlusEn",
        "tags": ["Chat Generation"],
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ResponsesQuickRequest" } } } },
        "responses": {
          "200": { "description": "Success", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ResponsesResponse" } } } },
          "400": { "description": "Bad Request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" }, "example": { "error": { "code": 400, "message": "Invalid request parameters", "type": "invalid_request_error" } } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" }, "example": { "error": { "code": 401, "message": "Invalid or expired token", "type": "authentication_error" } } } } },
          "402": { "description": "Insufficient Quota", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" }, "example": { "error": { "code": 402, "message": "Insufficient quota", "type": "insufficient_quota_error", "fallback_suggestion": "https://evolink.ai/dashboard/billing" } } } } },
          "429": { "description": "Rate Limit Exceeded", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" }, "example": { "error": { "code": 429, "message": "Rate limit exceeded", "type": "rate_limit_error" } } } } },
          "500": { "description": "Internal Server Error", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" }, "example": { "error": { "code": 500, "message": "Internal server error", "type": "internal_server_error" } } } } }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "ResponsesQuickRequest": {
        "type": "object", "required": ["model", "input"],
        "properties": {
          "model": { "type": "string", "description": "Model name", "enum": ["qwen3.5-plus", "qwen3.5-plus-2026-02-15"], "default": "qwen3.5-plus", "example": "qwen3.5-plus" },
          "input": { "oneOf": [{ "type": "string" }, { "type": "array", "items": { "$ref": "#/components/schemas/MessageSimple" } }], "description": "Input content; supports string or message array", "example": "Hello, please introduce yourself" }
        }
      },
      "MessageSimple": { "type": "object", "required": ["role", "content"], "properties": { "role": { "type": "string", "enum": ["user", "assistant", "system"] }, "content": { "type": "string" } } },
      "ResponsesResponse": { "type": "object", "properties": { "id": { "type": "string", "example": "resp_abc123" }, "model": { "type": "string", "example": "qwen3.5-plus" }, "status": { "type": "string", "enum": ["completed", "in_progress", "failed"], "example": "completed" }, "created_at": { "type": "integer", "example": 1760032810 }, "output": { "type": "array", "items": { "$ref": "#/components/schemas/OutputItem" } }, "output_text": { "type": "string", "description": "Convenience field returning text output directly", "example": "Hello! I'm Qwen3.5-Plus..." }, "usage": { "$ref": "#/components/schemas/ResponsesUsage" } } },
      "OutputItem": { "type": "object", "properties": { "type": { "type": "string", "enum": ["message", "reasoning", "function_call", "web_search_call"], "example": "message" }, "content": { "type": "array", "items": { "type": "object", "properties": { "type": { "type": "string", "enum": ["output_text"] }, "text": { "type": "string" } } } }, "summary": { "type": "array", "items": { "type": "object", "properties": { "text": { "type": "string", "description": "Chain-of-thought summary" } } } } } },
      "ResponsesUsage": { "type": "object", "properties": { "input_tokens": { "type": "integer", "example": 13 }, "output_tokens": { "type": "integer", "example": 256 }, "total_tokens": { "type": "integer", "example": 269 } } },
      "ErrorResponse": { "type": "object", "properties": { "error": { "type": "object", "properties": { "code": { "type": "integer" }, "message": { "type": "string" }, "type": { "type": "string" }, "param": { "type": "string" }, "fallback_suggestion": { "type": "string" } } } } }
    },
    "securitySchemes": { "bearerAuth": { "type": "http", "scheme": "bearer", "description": "##All endpoints require Bearer Token authentication##\n\n**Get your API Key:**\n\nVisit [API Key Management](https://evolink.ai/dashboard/keys)\n\n**Add to header:**\n```\nAuthorization: Bearer YOUR_API_KEY\n```" } }
  },
  "tags": [{ "name": "Chat Generation", "description": "AI chat generation endpoints" }]
}
