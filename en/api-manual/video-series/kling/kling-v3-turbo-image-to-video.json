{
  "openapi": "3.1.0",
  "info": {
    "title": "kling-v3-turbo-image-to-video API",
    "description": "Create image-to-video tasks using AI models",
    "license": {
      "name": "MIT"
    },
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://api.evolink.ai",
      "description": "Production"
    }
  ],
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "paths": {
    "/v1/videos/generations": {
      "post": {
        "summary": "kling-v3-turbo-image-to-video API",
        "description": "- Kling-V3 Turbo Image to Video (kling-v3-turbo-image-to-video) model supports image-to-video generation\n- Generates video based on a first-frame image, resolution supports 720P / 1080P (4K not supported), duration 3 ~ 15 seconds\n- The aspect ratio is determined by the first-frame image, **`aspect_ratio` is not accepted**\n- Asynchronous processing mode, use the returned task ID to [query status](/en/api-manual/task-management/get-task-detail)\n- Generated video links are valid for 24 hours, please save them promptly",
        "operationId": "createVideoGeneration",
        "tags": [
          "Video Generation"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/VideoGenerationRequest"
              },
              "examples": {
                "basic": {
                  "summary": "First Frame Image to Video",
                  "value": {
                    "model": "kling-v3-turbo-image-to-video",
                    "image_start": "https://your-cdn.com/start-frame.jpg",
                    "prompt": "A gentle breeze sweeps across the scene, bringing a subtle sense of motion",
                    "quality": "720p",
                    "duration": 5
                  }
                },
                "hd_1080p": {
                  "summary": "1080P Longer Duration",
                  "value": {
                    "model": "kling-v3-turbo-image-to-video",
                    "image_start": "https://your-cdn.com/portrait.png",
                    "prompt": "The person in the scene slowly turns their head and smiles",
                    "quality": "1080p",
                    "duration": 10
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Video generation task created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/VideoGenerationResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request parameters",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "error": {
                    "code": "invalid_request",
                    "message": "Invalid request parameters",
                    "type": "invalid_request_error"
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthenticated, invalid or expired token",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "error": {
                    "code": "unauthorized",
                    "message": "Invalid or expired token",
                    "type": "authentication_error"
                  }
                }
              }
            }
          },
          "402": {
            "description": "Insufficient quota, recharge required",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "error": {
                    "code": "insufficient_quota",
                    "message": "Insufficient quota. Please top up your account.",
                    "type": "insufficient_quota"
                  }
                }
              }
            }
          },
          "403": {
            "description": "Access denied",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "error": {
                    "code": "model_access_denied",
                    "message": "Token does not have access to model: kling-v3-turbo-image-to-video",
                    "type": "invalid_request_error"
                  }
                }
              }
            }
          },
          "429": {
            "description": "Rate limit exceeded",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "error": {
                    "code": "rate_limit_exceeded",
                    "message": "Too many requests, please try again later",
                    "type": "rate_limit_error"
                  }
                }
              }
            }
          },
          "500": {
            "description": "Internal server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "error": {
                    "code": "internal_error",
                    "message": "Internal server error",
                    "type": "api_error"
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "VideoGenerationRequest": {
        "type": "object",
        "required": [
          "model",
          "image_start"
        ],
        "properties": {
          "model": {
            "type": "string",
            "description": "Video generation model name",
            "enum": [
              "kling-v3-turbo-image-to-video"
            ],
            "default": "kling-v3-turbo-image-to-video",
            "example": "kling-v3-turbo-image-to-video"
          },
          "image_start": {
            "type": "string",
            "description": "First-frame image URL, used as the first frame of the video\n\n**Image Requirements:**\n- Formats: `.jpg` / `.jpeg` / `.png`\n- Size: <= `50MB`\n- Dimensions: width and height both >= `300px`\n- Aspect ratio: between `1:2.5` and `2.5:1`\n\nThe video aspect ratio is determined by the first-frame image",
            "format": "uri",
            "example": "https://your-cdn.com/start-frame.jpg"
          },
          "prompt": {
            "type": "string",
            "description": "Text prompt describing the desired motion or changes in the scene (optional)",
            "example": "A gentle breeze sweeps across the scene, bringing a subtle sense of motion",
            "maxLength": 2500
          },
          "quality": {
            "type": "string",
            "description": "Resolution tier\n\n**Options:**\n- `720p`: Standard quality\n- `1080p`: High quality\n- `4k` not supported",
            "enum": [
              "720p",
              "1080p"
            ],
            "default": "720p",
            "example": "720p"
          },
          "duration": {
            "type": "integer",
            "description": "Video duration in seconds, defaults to `5` seconds\n\n**Note:**\n- Range: integer from `3` to `15`\n- Billing is based on the `duration` value, longer duration costs more",
            "minimum": 3,
            "maximum": 15,
            "default": 5,
            "example": 5
          },
          "callback_url": {
            "type": "string",
            "description": "HTTPS callback URL for task completion\n\n**Callback Timing:**\n- Triggered when task is completed, failed, or cancelled\n- Sent after billing confirmation\n\n**Security Restrictions:**\n- HTTPS protocol only\n- Internal IP addresses are prohibited (127.0.0.1, 10.x.x.x, 172.16-31.x.x, 192.168.x.x, etc.)\n- URL length must not exceed `2048` characters\n\n**Callback Mechanism:**\n- Timeout: `10` seconds\n- Maximum `3` retries after failure (at `1`/`2`/`4` seconds after failure)\n- Callback response format is consistent with task query API\n- 2xx status code is considered successful, other codes trigger retry",
            "format": "uri",
            "example": "https://your-domain.com/webhooks/video-task-completed"
          }
        }
      },
      "VideoGenerationResponse": {
        "type": "object",
        "properties": {
          "created": {
            "type": "integer",
            "description": "Task creation timestamp",
            "example": 1757169743
          },
          "id": {
            "type": "string",
            "description": "Task ID",
            "example": "task-unified-1757169743-7cvnl5zw"
          },
          "model": {
            "type": "string",
            "description": "Actual model name used",
            "example": "kling-v3-turbo-image-to-video"
          },
          "object": {
            "type": "string",
            "enum": [
              "video.generation.task"
            ],
            "description": "Task type"
          },
          "progress": {
            "type": "integer",
            "description": "Task progress percentage (0-100)",
            "minimum": 0,
            "maximum": 100,
            "example": 0
          },
          "status": {
            "type": "string",
            "description": "Task status",
            "enum": [
              "pending",
              "processing",
              "completed",
              "failed"
            ],
            "example": "pending"
          },
          "task_info": {
            "$ref": "#/components/schemas/VideoTaskInfo",
            "description": "Video task details"
          },
          "type": {
            "type": "string",
            "enum": [
              "text",
              "image",
              "audio",
              "video"
            ],
            "description": "Task output type",
            "example": "video"
          },
          "usage": {
            "$ref": "#/components/schemas/VideoUsage",
            "description": "Usage and billing information"
          }
        }
      },
      "VideoTaskInfo": {
        "type": "object",
        "properties": {
          "can_cancel": {
            "type": "boolean",
            "description": "Whether the task can be cancelled",
            "example": true
          },
          "estimated_time": {
            "type": "integer",
            "description": "Estimated completion time (seconds)",
            "minimum": 0,
            "example": 300
          },
          "video_duration": {
            "type": "integer",
            "description": "Video duration (seconds)",
            "example": 5
          }
        }
      },
      "VideoUsage": {
        "type": "object",
        "description": "Usage and billing information",
        "properties": {
          "billing_rule": {
            "type": "string",
            "description": "Billing rule",
            "enum": [
              "per_call",
              "per_token",
              "per_second"
            ],
            "example": "per_second"
          },
          "credits_reserved": {
            "type": "number",
            "description": "Estimated credits consumed",
            "minimum": 0,
            "example": 270000
          },
          "user_group": {
            "type": "string",
            "description": "User group category",
            "example": "default"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "object",
            "properties": {
              "code": {
                "type": "string",
                "description": "Error code identifier"
              },
              "message": {
                "type": "string",
                "description": "Error description"
              },
              "type": {
                "type": "string",
                "description": "Error type"
              }
            }
          }
        }
      }
    },
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "## All APIs require Bearer Token authentication ##\n\n**Get API Key:**\n\nVisit [API Key Management Page](https://evolink.ai/dashboard/keys) to get your API Key\n\n**Add to request header:**\n```\nAuthorization: Bearer YOUR_API_KEY\n```"
      }
    }
  },
  "tags": [
    {
      "name": "Video Generation",
      "description": "AI video generation APIs"
    }
  ]
}
