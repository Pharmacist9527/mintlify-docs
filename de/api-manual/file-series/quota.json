{
  "openapi": "3.1.0",
  "info": {
    "title": "Dateikontingent-API",
    "description": "Aktuellen Dateiverbrauch und verbleibendes Kontingent des Benutzers abfragen",
    "license": {
      "name": "MIT"
    },
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://files-api.evolink.ai",
      "description": "Dateidienst-Umgebung"
    }
  ],
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "paths": {
    "/api/v1/files/quota": {
      "get": {
        "summary": "Dateikontingent abfragen",
        "description": "- Aktuellen Dateiverbrauch und verbleibendes Kontingent des Benutzers abfragen\n- Die Standard-Benutzergruppe erlaubt bis zu `2000` Dateien\n\n**Hinweis:**\nDie Basis-URL für Datei-APIs lautet `https://files-api.evolink.ai`",
        "operationId": "getFilesQuota",
        "tags": [
          "Dateiverwaltung"
        ],
        "responses": {
          "200": {
            "description": "Erfolgreich",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/QuotaResponse"
                },
                "example": {
                  "success": true,
                  "code": 200,
                  "data": {
                    "user_group": "default",
                    "used_files": 35,
                    "max_files": 2000,
                    "remain_files": 65,
                    "is_custom": false,
                    "quota_reason": ""
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "QuotaResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean",
            "description": "Whether the request was successful",
            "example": true
          },
          "code": {
            "type": "integer",
            "description": "Response status code",
            "example": 200
          },
          "data": {
            "$ref": "#/components/schemas/QuotaData"
          }
        }
      },
      "QuotaData": {
        "type": "object",
        "properties": {
          "user_group": {
            "type": "string",
            "description": "Benutzergruppe: `default` (2000 Dateien)",
            "example": "default"
          },
          "used_files": {
            "type": "integer",
            "description": "Anzahl der aktuell gespeicherten Dateien",
            "example": 35
          },
          "max_files": {
            "type": "integer",
            "description": "Maximal erlaubte Dateien",
            "example": 2000
          },
          "remain_files": {
            "type": "integer",
            "description": "Verbleibende Upload-Slots",
            "example": 65
          },
          "is_custom": {
            "type": "boolean",
            "description": "Ob das Kontingent manuell von einem Administrator festgelegt wurde",
            "example": false
          },
          "quota_reason": {
            "type": "string",
            "description": "Grund für das benutzerdefinierte Kontingent (nur gesetzt wenn `is_custom` `true` ist)",
            "example": ""
          }
        }
      }
    },
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "##Alle APIs erfordern Bearer-Token-Authentifizierung##\n\n**API-Schlüssel erhalten:**\n\nBesuchen Sie die [API-Schlüsselverwaltungsseite](https://evolink.ai/dashboard/keys), um Ihren API-Schlüssel zu erhalten\n\n**Zum Anfrage-Header hinzufügen:**\n```\nAuthorization: Bearer YOUR_API_KEY\n```"
      }
    }
  },
  "tags": [
    {
      "name": "Dateiverwaltung",
      "description": "Dateiverwaltungs-APIs"
    }
  ]
}
