{
  "openapi": "3.1.0",
  "info": {
    "title": "HappyHorse 1.0 Image-to-Video API",
    "description": "HappyHorse 1.0 Image-to-Video-API, generiert Videos aus einem einzelnen Startbild",
    "license": {
      "name": "MIT"
    },
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://api.evolink.ai",
      "description": "Produktionsumgebung"
    }
  ],
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "paths": {
    "/v1/videos/generations": {
      "post": {
        "summary": "HappyHorse 1.0 Image-to-Video",
        "description": "- HappyHorse 1.0 Image-to-Video, generiert ein Video aus einem einzelnen Startbild\n- `prompt` ist optional (wenn weggelassen, treibt das Startbild die freie Interpretation)\n- Das Ausgabe-Seitenverhältnis wird automatisch vom Startbild bestimmt; **`aspect_ratio` wird nicht unterstützt**\n- Asynchroner Verarbeitungsmodus, verwenden Sie die zurückgegebene Aufgaben-ID [zur Statusabfrage](/de/api-manual/task-management/get-task-detail)\n- Generierte Video-Links sind 24 Stunden gültig, bitte rechtzeitig speichern",
        "operationId": "createHappyHorse10ImageToVideo",
        "tags": [
          "Videogenerierung"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/VideoGenerationRequest"
              },
              "examples": {
                "basic": {
                  "summary": "Einfaches Image-to-Video",
                  "value": {
                    "model": "happyhorse-1.0-image-to-video",
                    "prompt": "Make the cat in the picture run on the grass",
                    "image_urls": [
                      "https://cdn.example.com/cat.png"
                    ],
                    "quality": "720p",
                    "duration": 5
                  }
                },
                "no_prompt": {
                  "summary": "Freie Interpretation aus Startbild (ohne Prompt)",
                  "value": {
                    "model": "happyhorse-1.0-image-to-video",
                    "image_urls": [
                      "https://cdn.example.com/landscape.jpg"
                    ],
                    "quality": "1080p",
                    "duration": 5,
                    "seed": 12345
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Videogenerierungsaufgabe erfolgreich erstellt",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/VideoGenerationResponse"
                }
              }
            }
          },
          "400": {
            "description": "Ungültige Anfrageparameter",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "error": {
                    "code": "invalid_request",
                    "message": "Invalid request parameters",
                    "type": "invalid_request_error"
                  }
                }
              }
            }
          },
          "401": {
            "description": "Nicht authentifiziert, Token ungültig oder abgelaufen",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "error": {
                    "code": "unauthorized",
                    "message": "Invalid or expired token",
                    "type": "authentication_error"
                  }
                }
              }
            }
          },
          "402": {
            "description": "Unzureichendes Guthaben, Aufladung erforderlich",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "error": {
                    "code": "insufficient_quota",
                    "message": "Insufficient quota. Please top up your account.",
                    "type": "insufficient_quota"
                  }
                }
              }
            }
          },
          "403": {
            "description": "Zugriff verweigert",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "error": {
                    "code": "model_access_denied",
                    "message": "Token does not have access to model: happyhorse-1.0-image-to-video",
                    "type": "invalid_request_error"
                  }
                }
              }
            }
          },
          "429": {
            "description": "Anfragelimit überschritten",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "error": {
                    "code": "rate_limit_exceeded",
                    "message": "Too many requests, please try again later",
                    "type": "rate_limit_error"
                  }
                }
              }
            }
          },
          "500": {
            "description": "Interner Serverfehler",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "error": {
                    "code": "internal_error",
                    "message": "Internal server error",
                    "type": "api_error"
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "VideoGenerationRequest": {
        "type": "object",
        "required": [
          "model",
          "image_urls"
        ],
        "properties": {
          "model": {
            "type": "string",
            "description": "Name des Videogenerierungsmodells",
            "enum": [
              "happyhorse-1.0-image-to-video"
            ],
            "default": "happyhorse-1.0-image-to-video",
            "example": "happyhorse-1.0-image-to-video"
          },
          "prompt": {
            "type": "string",
            "description": "Textprompt, **optional** (wenn weggelassen, treibt das Startbild die freie Interpretation)\n\n**Längengrenzen:**\n- Chinesisch: bis zu `2500` Zeichen\n- Nicht-Chinesisch: bis zu `5000` Zeichen\n- Überschüssiger Inhalt wird automatisch abgeschnitten",
            "example": "Make the cat in the picture run on the grass"
          },
          "image_urls": {
            "type": "array",
            "description": "Startbild-URL, **erforderlich** (das erste Element des Arrays wird als Startbild verwendet)\n\n**Bildanforderungen:**\n- Unterstützte Formate: JPEG, JPG, PNG, WEBP\n- Auflösung: Breite und Höhe ≥ `300` px\n- Seitenverhältnis: `1:2.5` ~ `2.5:1`\n- Dateigröße: ≤ `10MB`\n- Bild-URLs müssen **öffentlich zugänglich (HTTP oder HTTPS)** sein; private OSS-, Intranet- oder authentifizierte Links werden nicht unterstützt",
            "items": {
              "type": "string",
              "format": "uri"
            },
            "minItems": 1,
            "maxItems": 1,
            "example": [
              "https://cdn.example.com/cat.png"
            ]
          },
          "quality": {
            "type": "string",
            "description": "Videoauflösungsstufe, Standard ist `720p`\n\n**Optionen:**\n- `720p`: Standardauflösung, dies ist der Standardwert\n- `1080p`: HD-Auflösung\n\n**Abrechnungshinweis:** Die Auflösungsstufe wirkt sich direkt auf die Abrechnung aus",
            "enum": [
              "720p",
              "1080p"
            ],
            "default": "720p",
            "example": "720p"
          },
          "duration": {
            "type": "integer",
            "description": "Videodauer (Sekunden), Standard ist `5` Sekunden\n\n**Bereich:**\n- Ganzzahl `3` ~ `15`\n- Die Dauer wirkt sich direkt auf die Abrechnung aus",
            "default": 5,
            "minimum": 3,
            "maximum": 15,
            "example": 5
          },
          "seed": {
            "type": "integer",
            "description": "Zufalls-Seed, Standard ist zufällig\n\n**Details:**\n- Bereich: `0` ~ `2147483647`\n- Ein fester Seed reduziert parameterbedingte Variationen beim Iterieren über Prompts und verbessert die Reproduzierbarkeit",
            "minimum": 0,
            "maximum": 2147483647,
            "example": 42
          },
          "callback_url": {
            "type": "string",
            "description": "HTTPS-Callback-URL nach Aufgabenabschluss\n\n**Callback-Zeitpunkt:**\n- Wird ausgelöst, wenn die Aufgabe abgeschlossen, fehlgeschlagen oder abgebrochen ist\n- Wird nach Abschluss der Abrechnungsbestätigung gesendet\n\n**Sicherheitseinschränkungen:**\n- Nur HTTPS-Protokoll wird unterstützt\n- Callbacks an private IP-Adressen sind verboten (127.0.0.1, 10.x.x.x, 172.16-31.x.x, 192.168.x.x usw.)\n- URL-Länge darf `2048` Zeichen nicht überschreiten\n\n**Callback-Mechanismus:**\n- Timeout: `10` Sekunden\n- Bis zu `3` Wiederholungsversuche nach Fehler (jeweils nach `1`/`2`/`4` Sekunden)\n- Format des Callback-Antwort-Bodys entspricht dem Antwortformat der Task-Query-API\n- Ein 2xx-Statuscode gilt als Erfolg; andere Statuscodes lösen Wiederholungsversuche aus",
            "format": "uri",
            "example": "https://your-domain.com/webhooks/video-task-completed"
          }
        }
      },
      "VideoGenerationResponse": {
        "type": "object",
        "properties": {
          "created": {
            "type": "integer",
            "description": "Zeitstempel der Aufgabenerstellung",
            "example": 1761313744
          },
          "id": {
            "type": "string",
            "description": "Aufgaben-ID",
            "example": "task-happyhorse-1745726400000000000-aBcDeFgH-happyhorse-1.0-i2v"
          },
          "model": {
            "type": "string",
            "description": "Tatsächlich verwendeter Modellname",
            "example": "happyhorse-1.0-image-to-video"
          },
          "object": {
            "type": "string",
            "enum": [
              "video.generation.task"
            ],
            "description": "Spezifischer Aufgabentyp"
          },
          "progress": {
            "type": "integer",
            "description": "Aufgabenfortschritt in Prozent (0-100)",
            "minimum": 0,
            "maximum": 100,
            "example": 0
          },
          "status": {
            "type": "string",
            "description": "Aufgabenstatus",
            "enum": [
              "pending",
              "processing",
              "completed",
              "failed",
              "cancelled"
            ],
            "example": "pending"
          },
          "task_info": {
            "$ref": "#/components/schemas/VideoTaskInfo",
            "description": "Detaillierte Informationen zur Videoaufgabe"
          },
          "type": {
            "type": "string",
            "enum": [
              "text",
              "image",
              "audio",
              "video"
            ],
            "description": "Ausgabetyp der Aufgabe",
            "example": "video"
          },
          "usage": {
            "$ref": "#/components/schemas/VideoUsage",
            "description": "Nutzungs- und Abrechnungsinformationen"
          }
        }
      },
      "VideoTaskInfo": {
        "type": "object",
        "properties": {
          "can_cancel": {
            "type": "boolean",
            "description": "Ob die Aufgabe abgebrochen werden kann",
            "example": true
          },
          "estimated_time": {
            "type": "integer",
            "description": "Geschätzte Fertigstellungszeit (Sekunden)",
            "minimum": 0,
            "example": 2400
          },
          "video_duration": {
            "type": "integer",
            "description": "Videodauer (Sekunden)",
            "example": 5
          }
        }
      },
      "VideoUsage": {
        "type": "object",
        "description": "Nutzungs- und Abrechnungsinformationen",
        "properties": {
          "billing_rule": {
            "type": "string",
            "description": "Abrechnungsregel",
            "enum": [
              "per_call",
              "per_token",
              "per_second"
            ],
            "example": "per_second"
          },
          "credits_reserved": {
            "type": "number",
            "description": "Geschätzter Credit-Verbrauch",
            "minimum": 0,
            "example": 607500
          },
          "user_group": {
            "type": "string",
            "description": "Benutzergruppenkategorie",
            "example": "default"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "object",
            "properties": {
              "code": {
                "type": "string",
                "description": "Fehlercode-Kennung"
              },
              "message": {
                "type": "string",
                "description": "Fehlerbeschreibungsnachricht"
              },
              "type": {
                "type": "string",
                "description": "Fehlertyp"
              }
            }
          }
        }
      }
    },
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "##Alle Schnittstellen erfordern eine Authentifizierung mit Bearer Token##\n\n**API Key erhalten:**\n\nBesuchen Sie die [API-Key-Verwaltungsseite](https://evolink.ai/dashboard/keys), um Ihren API Key zu erhalten\n\n**Im Anfrage-Header hinzufügen:**\n```\nAuthorization: Bearer YOUR_API_KEY\n```"
      }
    }
  },
  "tags": [
    {
      "name": "Videogenerierung",
      "description": "API-Schnittstellen für KI-Videogenerierung"
    }
  ]
}
