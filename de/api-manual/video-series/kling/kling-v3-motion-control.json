{
  "openapi": "3.1.0",
  "info": {
    "title": "kling-v3-motion-control API",
    "description": "Erstellen Sie Bewegungssteuerungs-Videoaufgaben mit KI-Modellen",
    "license": {
      "name": "MIT"
    },
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://api.evolink.ai",
      "description": "Produktion"
    }
  ],
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "paths": {
    "/v1/videos/generations": {
      "post": {
        "summary": "kling-v3-motion-control API",
        "description": "- Kling-V3 Motion Control (kling-v3-motion-control) Modell unterstützt die Bewegungsgenerierung durch **Referenzbild + Referenzvideo**\n- Das System extrahiert Bewegungstrajektorien aus dem Referenzvideo und wendet sie auf die Figur/das Objekt im Referenzbild an, um ein neues Video mit der gleichen Bewegung wie im Referenzvideo zu erzeugen\n- Die Dauer des generierten Videos entspricht der des Referenzvideos (3–30 Sekunden)\n- Asynchroner Verarbeitungsmodus, verwenden Sie die zurückgegebene Aufgaben-ID [zur Abfrage](/de/api-manual/task-management/get-task-detail)\n- Der Link zum generierten Video ist 24 Stunden gültig, bitte speichern Sie ihn rechtzeitig",
        "operationId": "createVideoGeneration",
        "tags": [
          "Videogenerierung"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/VideoGenerationRequest"
              },
              "examples": {
                "basic": {
                  "summary": "Grundlegende Bewegungssteuerung",
                  "value": {
                    "model": "kling-v3-motion-control",
                    "prompt": "A girl dancing gracefully",
                    "image_urls": [
                      "https://example.com/character.jpg"
                    ],
                    "video_urls": [
                      "https://example.com/dance-reference.mp4"
                    ],
                    "quality": "720p",
                    "model_params": {
                      "character_orientation": "image"
                    }
                  }
                },
                "hd_no_sound": {
                  "summary": "HD + Originalton nicht beibehalten",
                  "value": {
                    "model": "kling-v3-motion-control",
                    "prompt": "A robot performing martial arts",
                    "image_urls": [
                      "https://example.com/robot.png"
                    ],
                    "video_urls": [
                      "https://example.com/martial-arts.mp4"
                    ],
                    "quality": "1080p",
                    "model_params": {
                      "character_orientation": "video",
                      "keep_sound": false
                    }
                  }
                },
                "with_element": {
                  "summary": "Mit Subjektelement-Steuerung",
                  "value": {
                    "model": "kling-v3-motion-control",
                    "image_urls": [
                      "https://example.com/person.jpg"
                    ],
                    "video_urls": [
                      "https://example.com/walking.mp4"
                    ],
                    "model_params": {
                      "character_orientation": "image",
                      "element_list": [
                        {
                          "element_id": 123456789
                        }
                      ]
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Videogenerierungsaufgabe erfolgreich erstellt",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/VideoGenerationResponse"
                }
              }
            }
          },
          "400": {
            "description": "Ungültige Anfrageparameter",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "error": {
                    "code": "invalid_request",
                    "message": "Invalid request parameters",
                    "type": "invalid_request_error"
                  }
                }
              }
            }
          },
          "401": {
            "description": "Nicht authentifiziert, Token ungültig oder abgelaufen",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "error": {
                    "code": "unauthorized",
                    "message": "Invalid or expired token",
                    "type": "authentication_error"
                  }
                }
              }
            }
          },
          "402": {
            "description": "Kontingent erschöpft, Aufladung erforderlich",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "error": {
                    "code": "insufficient_quota",
                    "message": "Insufficient quota. Please top up your account.",
                    "type": "insufficient_quota"
                  }
                }
              }
            }
          },
          "403": {
            "description": "Kein Zugriff erlaubt",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "error": {
                    "code": "model_access_denied",
                    "message": "Token does not have access to model: kling-v3-motion-control",
                    "type": "invalid_request_error"
                  }
                }
              }
            }
          },
          "429": {
            "description": "Anfragelimit überschritten",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "error": {
                    "code": "rate_limit_exceeded",
                    "message": "Too many requests, please try again later",
                    "type": "rate_limit_error"
                  }
                }
              }
            }
          },
          "500": {
            "description": "Interner Serverfehler",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "error": {
                    "code": "internal_error",
                    "message": "Internal server error",
                    "type": "api_error"
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "VideoGenerationRequest": {
        "type": "object",
        "required": [
          "model",
          "image_urls",
          "video_urls",
          "model_params"
        ],
        "properties": {
          "model": {
            "type": "string",
            "description": "Name des Videogenerierungsmodells",
            "enum": [
              "kling-v3-motion-control"
            ],
            "default": "kling-v3-motion-control",
            "example": "kling-v3-motion-control"
          },
          "image_urls": {
            "type": "array",
            "items": {
              "type": "string",
              "format": "uri"
            },
            "description": "Array von Referenzbild-URLs, um das Erscheinungsbild der Figur/des Objekts bereitzustellen\n\n**Hinweis:**\n- Ein Referenzbild übergeben\n- Bildgröße: maximal `10MB`\n- Unterstützte Dateiformate: `.jpg`, `.jpeg`, `.png`\n- Bildabmessungen: Breite und Höhe ≥ `300px`, Seitenverhältnis zwischen `1:2.5` und `2.5:1`\n- Die Bild-URL muss vom Server direkt erreichbar sein",
            "example": [
              "https://example.com/character.jpg"
            ]
          },
          "video_urls": {
            "type": "array",
            "items": {
              "type": "string",
              "format": "uri"
            },
            "description": "Array von Referenzvideo-URLs, um die Bewegungstrajektorie bereitzustellen\n\n**Hinweis:**\n- Ein Referenzvideo übergeben\n- Videodauer: `3` bis `30` Sekunden\n- Die Dauer des generierten Videos entspricht der des Referenzvideos\n- Die Video-URL muss vom Server direkt erreichbar sein",
            "example": [
              "https://example.com/dance-reference.mp4"
            ]
          },
          "prompt": {
            "type": "string",
            "description": "Textprompt (optional), um die Generierung zu steuern\n\n**Hinweis:**\n- Maximal `2500` Zeichen\n- Kann leer gelassen werden, das Modell generiert automatisch basierend auf Referenzbild und -video",
            "example": "A girl dancing gracefully",
            "maxLength": 2500
          },
          "quality": {
            "type": "string",
            "description": "Auflösungsstufe\n\n**Erläuterung:**\n- `720p`: Standardqualität (std)\n- `1080p`: Hohe Qualität (pro)",
            "enum": [
              "720p",
              "1080p"
            ],
            "default": "720p",
            "example": "720p"
          },
          "model_params": {
            "type": "object",
            "required": [
              "character_orientation"
            ],
            "description": "Modellspezifische Parameter (erforderlich), für die Bewegungssteuerungskonfiguration",
            "properties": {
              "character_orientation": {
                "type": "string",
                "description": "Quelle der Figurenausrichtung (**erforderlich**)\n\n**Erläuterung:**\n- `image`: Basierend auf der Figurenausrichtung im Referenzbild\n- `video`: Basierend auf der Figurenausrichtung im Referenzvideo",
                "enum": [
                  "image",
                  "video"
                ],
                "example": "image"
              },
              "element_list": {
                "type": "array",
                "description": "Subjektelementliste, um die zu steuernde Figur/das Objekt anzugeben\n\n**Hinweis:**\n- Maximal `1` Subjektelement (Motion Control-Beschränkung)\n- `element_id`: Subjektelement-ID",
                "items": {
                  "type": "object",
                  "properties": {
                    "element_id": {
                      "type": "integer",
                      "description": "Subjektelement-ID"
                    }
                  },
                  "required": [
                    "element_id"
                  ]
                },
                "maxItems": 1
              },
              "keep_sound": {
                "type": "boolean",
                "description": "Ob der Originalton des Referenzvideos beibehalten werden soll\n\n**Erläuterung:**\n- `true`: Originalton beibehalten (Standard)\n- `false`: Stumm",
                "default": true,
                "example": true
              },
              "watermark_info": {
                "type": "object",
                "description": "Wasserzeichenkonfiguration",
                "properties": {
                  "enabled": {
                    "type": "boolean",
                    "description": "Ob Wasserzeichen aktiviert werden soll"
                  }
                }
              }
            }
          },
          "callback_url": {
            "type": "string",
            "description": "HTTPS-Callback-Adresse nach Aufgabenabschluss\n\n**Callback-Zeitpunkt:**\n- Wird bei Aufgabenabschluss (completed), Fehler (failed) oder Abbruch (cancelled) ausgelöst\n- Wird nach Bestätigung der Abrechnung gesendet\n\n**Sicherheitsbeschränkungen:**\n- Nur HTTPS-Protokoll unterstützt\n- Callback zu internen IP-Adressen ist verboten (127.0.0.1, 10.x.x.x, 172.16-31.x.x, 192.168.x.x usw.)\n- URL-Länge maximal `2048` Zeichen\n\n**Callback-Mechanismus:**\n- Timeout: `10` Sekunden\n- Maximal `3` Wiederholungsversuche nach Fehlschlag (Wiederholung nach `1`/`2`/`4` Sekunden)\n- Das Format des Callback-Antwortkörpers entspricht dem Format der Aufgabenabfrage-Schnittstelle\n- Ein 2xx-Statuscode der Callback-Adresse gilt als Erfolg, andere Statuscodes lösen eine Wiederholung aus",
            "format": "uri",
            "example": "https://your-domain.com/webhooks/video-task-completed"
          }
        }
      },
      "VideoGenerationResponse": {
        "type": "object",
        "properties": {
          "created": {
            "type": "integer",
            "description": "Zeitstempel der Aufgabenerstellung",
            "example": 1757169743
          },
          "id": {
            "type": "string",
            "description": "Aufgaben-ID",
            "example": "task-unified-1757169743-7cvnl5zw"
          },
          "model": {
            "type": "string",
            "description": "Tatsächlich verwendeter Modellname",
            "example": "kling-v3-motion-control"
          },
          "object": {
            "type": "string",
            "enum": [
              "video.generation.task"
            ],
            "description": "Spezifischer Aufgabentyp"
          },
          "progress": {
            "type": "integer",
            "description": "Aufgabenfortschritt in Prozent (0-100)",
            "minimum": 0,
            "maximum": 100,
            "example": 0
          },
          "status": {
            "type": "string",
            "description": "Aufgabenstatus",
            "enum": [
              "pending",
              "processing",
              "completed",
              "failed"
            ],
            "example": "pending"
          },
          "task_info": {
            "$ref": "#/components/schemas/VideoTaskInfo",
            "description": "Detaillierte Videoaufgaben-Informationen"
          },
          "type": {
            "type": "string",
            "enum": [
              "text",
              "image",
              "audio",
              "video"
            ],
            "description": "Ausgabetyp der Aufgabe",
            "example": "video"
          },
          "usage": {
            "$ref": "#/components/schemas/VideoUsage",
            "description": "Nutzungs- und Abrechnungsinformationen"
          }
        }
      },
      "VideoTaskInfo": {
        "type": "object",
        "properties": {
          "can_cancel": {
            "type": "boolean",
            "description": "Ob die Aufgabe abgebrochen werden kann",
            "example": true
          },
          "estimated_time": {
            "type": "integer",
            "description": "Geschätzte Fertigstellungszeit (Sekunden)",
            "minimum": 0,
            "example": 300
          },
          "video_duration": {
            "type": "integer",
            "description": "Videodauer (Sekunden), entspricht der Länge des Referenzvideos",
            "example": 8
          }
        }
      },
      "VideoUsage": {
        "type": "object",
        "description": "Nutzungs- und Abrechnungsinformationen",
        "properties": {
          "billing_rule": {
            "type": "string",
            "description": "Abrechnungsregel",
            "enum": [
              "per_call",
              "per_token",
              "per_second"
            ],
            "example": "per_second"
          },
          "credits_reserved": {
            "type": "number",
            "description": "Geschätzte verbrauchte Credits",
            "minimum": 0,
            "example": 408240
          },
          "user_group": {
            "type": "string",
            "description": "Benutzergruppenkategorie",
            "example": "default"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "object",
            "properties": {
              "code": {
                "type": "string",
                "description": "Fehlercode-Bezeichner"
              },
              "message": {
                "type": "string",
                "description": "Fehlerbeschreibung"
              },
              "type": {
                "type": "string",
                "description": "Fehlertyp"
              }
            }
          }
        }
      }
    },
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "##Alle Schnittstellen erfordern eine Authentifizierung mit Bearer Token##\n\n**API Key erhalten:**\n\nBesuchen Sie die [API Key Verwaltungsseite](https://evolink.ai/dashboard/keys), um Ihren API Key zu erhalten\n\n**Fügen Sie ihn im Anfrage-Header hinzu:**\n```\nAuthorization: Bearer YOUR_API_KEY\n```"
      }
    }
  },
  "tags": [
    {
      "name": "Videogenerierung",
      "description": "KI-Videogenerierung-bezogene Schnittstellen"
    }
  ]
}
