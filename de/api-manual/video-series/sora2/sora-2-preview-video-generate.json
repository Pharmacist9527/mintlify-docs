{
  "openapi": "3.1.0",
  "info": {
    "title": "Sora-2-Preview API",
    "description": "Videogenerierungsaufgaben mit KI-Modellen erstellen, unterstützt Text-zu-Video, Bild-zu-Video und mehr",
    "license": {
      "name": "MIT"
    },
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://api.evolink.ai",
      "description": "Produktion"
    }
  ],
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "tags": [
    {
      "name": "Videogenerierung",
      "description": "APIs zur KI-Videogenerierung"
    }
  ],
  "paths": {
    "/v1/videos/generations": {
      "post": {
        "summary": "Sora-2-Preview API",
        "description": "- Sora 2 Preview (sora-2-preview) unterstützt Text-zu-Video, Bild-zu-Video und mehr\n- Asynchrone Verarbeitung, verwenden Sie die zurückgegebene Aufgaben-ID zum [Statusabfragen](/de/api-manual/task-management/get-task-detail)\n- Generierte Videolinks sind 24 Stunden gültig, bitte umgehend speichern\n\n**Hinweis:**\n- Sora2 hat eine sehr strenge Inhaltsmoderation, Aufgaben können dadurch fehlschlagen\n- Bilder mit echten Personen werden nicht unterstützt",
        "operationId": "createVideoGeneration",
        "tags": [
          "Videogenerierung"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/VideoGenerationRequest"
              },
              "examples": {
                "text_to_video": {
                  "summary": "Text-zu-Video",
                  "value": {
                    "model": "sora-2-preview",
                    "prompt": "A cat playing piano"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Videogenerierungsaufgabe erfolgreich erstellt",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/VideoGenerationResponse"
                }
              }
            }
          },
          "400": {
            "description": "Ungültige Anfrageparameter",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "error": {
                    "code": "invalid_request",
                    "message": "Invalid request parameters",
                    "type": "invalid_request_error"
                  }
                }
              }
            }
          },
          "401": {
            "description": "Nicht autorisiert, ungültiges oder abgelaufenes Token",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "error": {
                    "code": "unauthorized",
                    "message": "Invalid or expired token",
                    "type": "authentication_error"
                  }
                }
              }
            }
          },
          "402": {
            "description": "Unzureichendes Kontingent, Aufladung erforderlich",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "error": {
                    "code": "insufficient_quota",
                    "message": "Insufficient quota. Please top up your account.",
                    "type": "insufficient_quota"
                  }
                }
              }
            }
          },
          "403": {
            "description": "Zugriff verweigert",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "error": {
                    "code": "model_access_denied",
                    "message": "Token does not have access to model: sora-2-preview",
                    "type": "invalid_request_error"
                  }
                }
              }
            }
          },
          "429": {
            "description": "Ratenlimit überschritten",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "error": {
                    "code": "rate_limit_exceeded",
                    "message": "Too many requests, please try again later",
                    "type": "rate_limit_error"
                  }
                }
              }
            }
          },
          "500": {
            "description": "Interner Serverfehler",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "error": {
                    "code": "internal_error",
                    "message": "Internal server error",
                    "type": "api_error"
                  }
                }
              }
            }
          },
          "503": {
            "description": "Dienst vorübergehend nicht verfügbar",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "error": {
                    "code": "service_unavailable",
                    "message": "No available channel for the requested model",
                    "type": "api_error"
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "VideoGenerationRequest": {
        "type": "object",
        "required": [
          "model",
          "prompt"
        ],
        "properties": {
          "model": {
            "type": "string",
            "description": "Name des Videogenerierungsmodells",
            "default": "sora-2-preview",
            "example": "sora-2-preview"
          },
          "prompt": {
            "type": "string",
            "description": "Prompt, der das zu generierende Video beschreibt, maximal 5000 Token",
            "example": "A cat playing piano",
            "maxLength": 5000
          },
          "aspect_ratio": {
            "type": "string",
            "description": "Video-Seitenverhältnis. `1280x720` erzeugt Querformat-Video, `720x1280` erzeugt Hochformat-Video",
            "enum": [
              "1280x720",
              "720x1280",
              "16:9",
              "9:16"
            ],
            "example": "16:9"
          },
          "duration": {
            "type": "integer",
            "description": "Videodauer (Sekunden), Standardwert `4`\n\n**Hinweis:**\n- Unterstützt nur `4`, `8`, `12` Sekunden\n- Längere Dauer kostet mehr",
            "example": 4
          },
          "image_urls": {
            "type": "array",
            "description": "Referenzbild-URLs für Bild-zu-Video\n\n**Hinweis:**\n- Bilder mit echten Personen werden nicht unterstützt\n- Maximal 1 Bild pro Anfrage\n- Maximale Größe: 10MB\n- Formate: .jpg, .jpeg, .png, .webp\n- **Die Pixelabmessungen des Bildes müssen exakt dem gewählten aspect_ratio entsprechen** (z.B. wenn aspect_ratio `1280x720` ist, muss das hochgeladene Bild exakt 1280x720 Pixel haben)\n- Bild-URL muss vom Server direkt zugänglich sein oder beim Zugriff einen Download auslösen (typischerweise URLs, die mit Bilderweiterungen wie .png, .jpg enden)",
            "items": {
              "type": "string",
              "format": "uri"
            },
            "maxItems": 1,
            "example": [
              "http://example.com/image1.jpg"
            ]
          },
          "callback_url": {
            "type": "string",
            "description": "HTTPS-Callback-URL bei Aufgabenabschluss\n\n**Callback-Zeitpunkt:**\n- Wird ausgelöst, wenn die Aufgabe abgeschlossen, fehlgeschlagen oder abgebrochen wurde\n- Wird nach Abrechnungsbestätigung gesendet\n\n**Sicherheitsbeschränkungen:**\n- Nur HTTPS-Protokoll\n- Private IP-Adressen nicht erlaubt (127.0.0.1, 10.x.x.x, 172.16-31.x.x, 192.168.x.x, usw.)\n- URL-Länge maximal 2048 Zeichen\n\n**Callback-Mechanismus:**\n- Timeout: 10 Sekunden\n- Maximal 3 Wiederholungsversuche bei Fehlschlag (in Intervallen von 1s/2s/4s)\n- Antwortformat entspricht der Aufgabenabfrage-API\n- 2xx-Statuscode = Erfolg, andere Codes lösen Wiederholung aus",
            "format": "uri",
            "example": "https://your-domain.com/webhooks/video-task-completed"
          }
        }
      },
      "VideoGenerationResponse": {
        "type": "object",
        "properties": {
          "created": {
            "type": "integer",
            "description": "Zeitstempel der Aufgabenerstellung",
            "example": 1757169743
          },
          "id": {
            "type": "string",
            "description": "Aufgaben-ID",
            "example": "task-unified-1757169743-7cvnl5zw"
          },
          "model": {
            "type": "string",
            "description": "Verwendeter Modellname",
            "example": "sora-2-preview"
          },
          "object": {
            "type": "string",
            "enum": [
              "video.generation.task"
            ],
            "description": "Aufgabentyp"
          },
          "progress": {
            "type": "integer",
            "description": "Aufgabenfortschritt (0-100)",
            "minimum": 0,
            "maximum": 100,
            "example": 0
          },
          "status": {
            "type": "string",
            "description": "Aufgabenstatus",
            "enum": [
              "pending",
              "processing",
              "completed",
              "failed"
            ],
            "example": "pending"
          },
          "task_info": {
            "$ref": "#/components/schemas/VideoTaskInfo"
          },
          "type": {
            "type": "string",
            "enum": [
              "text",
              "image",
              "audio",
              "video"
            ],
            "description": "Ausgabetyp",
            "example": "video"
          },
          "usage": {
            "$ref": "#/components/schemas/VideoUsage"
          }
        }
      },
      "VideoTaskInfo": {
        "type": "object",
        "properties": {
          "can_cancel": {
            "type": "boolean",
            "description": "Ob die Aufgabe abgebrochen werden kann",
            "example": true
          },
          "estimated_time": {
            "type": "integer",
            "description": "Geschätzte Abschlusszeit (Sekunden)",
            "minimum": 0,
            "example": 300
          },
          "video_duration": {
            "type": "integer",
            "description": "Videodauer (Sekunden)",
            "example": 9
          }
        }
      },
      "VideoUsage": {
        "type": "object",
        "properties": {
          "billing_rule": {
            "type": "string",
            "description": "Abrechnungsregel",
            "enum": [
              "per_call",
              "per_token",
              "per_second"
            ],
            "example": "per_call"
          },
          "credits_reserved": {
            "type": "number",
            "description": "Geschätzte Credits",
            "minimum": 0,
            "example": 7
          },
          "user_group": {
            "type": "string",
            "description": "Benutzergruppenkategorie",
            "example": "default"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "object",
            "properties": {
              "code": {
                "type": "string",
                "description": "Fehlercode-Bezeichner"
              },
              "message": {
                "type": "string",
                "description": "Fehlerbeschreibung"
              },
              "type": {
                "type": "string",
                "description": "Fehlertyp"
              }
            }
          }
        }
      }
    },
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "##Alle APIs erfordern Bearer-Token-Authentifizierung##\n\n**API-Schlüssel erhalten:**\n\nBesuchen Sie die [API-Schlüsselverwaltungsseite](https://evolink.ai/dashboard/keys), um Ihren API-Schlüssel zu erhalten\n\n**Zum Anfrage-Header hinzufügen:**\n```\nAuthorization: Bearer YOUR_API_KEY\n```"
      }
    }
  }
}
