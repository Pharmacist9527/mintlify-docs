                  "error": {
                    "code": 502,
                    "message": "Bad gateway",
                    "type": "bad_gateway_error"
                  }
                }
              }
            }
          },
          "503": {
            "description": "Dienst vorübergehend nicht verfügbar",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "error": {
                    "code": 503,
                    "message": "Service temporarily unavailable",
                    "type": "service_unavailable_error"
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "ChatCompletionRequest": {
        "type": "object",
        "required": [
          "model",
          "messages"
        ],
        "properties": {
          "model": {
            "type": "string",
            "description": "Name des Chat-Modells",
            "enum": [
              "MiniMax-M3"
            ],
            "example": "MiniMax-M3"
          },
          "messages": {
            "type": "array",
            "description": "Liste der Konversationsnachrichten, unterstützt Mehrrundendialog\n\nNachrichten mit unterschiedlichen Rollen haben unterschiedliche Feldstrukturen; wählen Sie die entsprechende Rolle zur Ansicht aus",
            "items": {
              "oneOf": [
                {
                  "$ref": "#/components/schemas/SystemMessage"
                },
                {
                  "$ref": "#/components/schemas/UserMessage"
                },
                {
                  "$ref": "#/components/schemas/AssistantRequestMessage"
                },
                {
                  "$ref": "#/components/schemas/ToolMessage"
                }
              ],
              "discriminator": {
                "propertyName": "role",
                "mapping": {
                  "system": "#/components/schemas/SystemMessage",
                  "user": "#/components/schemas/UserMessage",
                  "assistant": "#/components/schemas/AssistantRequestMessage",
                  "tool": "#/components/schemas/ToolMessage"
                }
              }
            },
            "minItems": 1
          },
          "thinking": {
            "type": "object",
            "description": "Steuert tiefes Nachdenken\n\n**Hinweise**:\n- **Standardwert `adaptive`**: Das Modell entscheidet adaptiv anhand der Schwierigkeit des Problems, ob tiefes Nachdenken eingesetzt wird\n- Standardmäßig wird der Denkinhalt inline in das Antwort-`content` eingebettet (umschlossen von `<think>...</think>`-Tags); um ihn in ein eigenes Feld auszulagern, verwenden Sie `reasoning_split`",
            "properties": {
              "type": {
                "type": "string",
                "description": "Modus für tiefes Nachdenken\n\n- `adaptive`: Das Modell entscheidet selbstständig, ob Nachdenken erforderlich ist (empfohlener Standardwert)\n- `disabled`: Nachdenken deaktivieren, direkt antworten",
                "enum": [
                  "disabled",
                  "adaptive"
                ],
                "default": "adaptive"
              }
            }
          },
          "reasoning_split": {
            "type": "boolean",
            "description": "Ob der Denkinhalt in ein separates Feld ausgelagert wird\n\n- `false` (Standard): Der Denkinhalt wird inline in `content` eingebettet, umschlossen von `<think>...</think>`-Tags\n- `true`: Der Denkinhalt wird in `choices[].message.reasoning_content` und `reasoning_details` ausgelagert"
          },
          "temperature": {
            "type": "number",
            "description": "Sampling-Temperatur, steuert die Zufälligkeit der Ausgabe\n\n**Hinweise**:\n- Niedrigere Werte (z. B. 0,2): Deterministischere, fokussiertere Ausgabe\n- Höhere Werte (z. B. 1,5): Zufälligere, kreativere Ausgabe\n- Bereich: `[0, 2]`, Standard 1",
            "minimum": 0,
            "maximum": 2,
            "default": 1,
            "example": 1
          },
          "top_p": {
            "type": "number",
            "description": "Nucleus-Sampling-Parameter\n\n**Hinweise**:\n- Steuert das Sampling aus Tokens mit kumulativer Wahrscheinlichkeit\n- z. B. 0,95 bedeutet die Auswahl aus Tokens, die 95 % kumulative Wahrscheinlichkeit erreichen\n- Bereich: `[0, 1]`, MiniMax-M3 Standard 0,95\n\n**Empfehlung**: Passen Sie temperature und top_p nicht gleichzeitig an",
            "minimum": 0,
            "maximum": 1,
            "default": 0.95,
            "example": 0.95
          },
          "max_completion_tokens": {
            "type": "integer",
            "description": "Obergrenze für die Länge des generierten Inhalts (in Tokens)\n\n**Hinweise**:\n- MiniMax-M3 empfohlen **131.072** (128K), maximal **524.288** (512K)\n- Vom Nachdenken erzeugte Tokens zählen ebenfalls zu dieser Grenze\n- Wenn die Generierung aufgrund von `length` unterbrochen wird, versuchen Sie, diesen Wert zu erhöhen",
            "minimum": 1,
            "maximum": 524288,
            "example": 131072
          },
          "stream": {
            "type": "boolean",
            "description": "Ob die Antwort im Streaming-Modus zurückgegeben wird\n\n- `true`: Streaming-Antwort, gibt Inhalte in Echtzeit-Chunks über SSE (Server-Sent Events) zurück\n- `false`: Wartet auf die vollständige Antwort, bevor sie zurückgegeben wird (Standard)",
            "default": false,
            "example": false
          },
          "stream_options": {
            "type": "object",
            "description": "Optionen für die Streaming-Antwort\n\nNur wirksam, wenn `stream=true`",
            "properties": {
              "include_usage": {
                "type": "boolean",
                "description": "Gibt am Ende des Streams einen zusätzlichen Chunk zurück, der nur `usage`-Statistiken enthält"
              }
            }
          },
          "tools": {
            "type": "array",
            "description": "Liste der Werkzeugdefinitionen für Function Calling\n\nJedes Werkzeug benötigt einen Namen, eine Beschreibung und ein Parameterschema",
            "items": {
              "$ref": "#/components/schemas/Tool"
            }
          },
          "max_tokens": {
            "type": "integer",
            "description": "Veralteter Parameter zur Begrenzung der Generierungslänge\n\n**Hinweis**: Veraltet, bitte verwenden Sie stattdessen `max_completion_tokens`",
            "deprecated": true,
            "minimum": 1
          }
        }
      },
      "SystemMessage": {
        "title": "System Message",
        "type": "object",
        "required": [
          "role",
          "content"
        ],
        "properties": {
          "role": {
            "type": "string",
            "enum": [
              "system"
            ],
            "description": "Rollenkennung, fest auf `system` gesetzt"
          },
          "content": {
            "type": "string",
            "description": "Inhalt des System-Prompts, dient zum Festlegen der Rolle und des Verhaltens der KI"
          },
          "name": {
            "type": "string",
            "description": "Name des Teilnehmers, dient zur Unterscheidung verschiedener Quellen von System-Prompts"
          }
        }
      },
      "UserMessage": {
        "title": "User Message",
        "type": "object",
        "required": [
          "role",
          "content"
        ],
        "properties": {
          "role": {
            "type": "string",
            "enum": [
              "user"
            ],
            "description": "Rollenkennung, fest auf `user` gesetzt"
          },
          "content": {
            "description": "Inhalt der Benutzernachricht\n\n**Hinweise**:\n- Für reinen Text übergeben Sie direkt eine Zeichenkette\n- Für Multimodalität übergeben Sie ein Content-Part-Array, das `text` / `image_url` (Bilder, Video) unterstützt",
            "oneOf": [
              {
                "type": "string"
              },
              {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/ContentPart"
                }
              }
            ]
          },
          "name": {
            "type": "string",
            "description": "Name des Teilnehmers, dient zur Unterscheidung verschiedener Benutzer"
          }
        }
      },
      "ContentPart": {
        "type": "object",
        "description": "Multimodaler Content-Part. Deklarieren Sie den Typ über `type` und füllen Sie nur die zu diesem Typ passenden Felder aus",
        "properties": {
          "type": {
            "type": "string",
            "enum": [
              "text",
              "image_url",
              "video_url"
            ],
            "description": "Inhaltstyp\n\n- `text`: Textblock\n- `image_url`: Bildeingabe\n- `video_url`: Videoeingabe"
          },
          "text": {
            "type": "string",
            "description": "Textinhalt, wenn `type=text`"
          },
          "image_url": {
            "type": "object",
            "description": "Bildeingabe (wenn `type=image_url`). Maximal 10 MB pro Bild, unterstützt JPEG / PNG / GIF / WEBP",
            "required": [
              "url"
            ],
            "properties": {
              "url": {
                "type": "string",
                "description": "Bild-URL oder eine base64-Daten-URL, die mit `data:` beginnt"
              },
              "detail": {
                "type": "string",
                "description": "Steuert die Auflösung der Bildanalyse\n\n- `low`: Niedrige Präzision, verbraucht weniger Tokens\n- `default`: Standardpräzision\n- `high`: Hohe Präzision, erkennt mehr Details, verbraucht aber mehr Tokens",
                "enum": [
                  "low",
                  "default",
                  "high"
                ],
                "default": "default"
              },
              "max_long_side_pixel": {
                "type": "integer",
                "description": "Maximale Pixelgrenze für die längste Seite des Bildes",
                "minimum": 1
              }
            }
          },
          "video_url": {
            "type": "object",
            "description": "Videoeingabe (wenn `type=video_url`). Maximal 50 MB für URL- / Base64-Video, unterstützt MP4 / AVI / MOV / MKV",
            "required": [
              "url"
            ],
            "properties": {
              "url": {
                "type": "string",
                "description": "Video-URL, eine base64-Daten-URL, die mit `data:` beginnt, oder eine Dateireferenz im Format `mm_file://{file_id}`"
              },
              "detail": {
                "type": "string",
                "description": "Steuert die Auflösung der Video-Frame-Extraktion",
                "enum": [
                  "low",
                  "default",
                  "high"
                ],
                "default": "default"
              },
              "fps": {
                "type": "number",
                "description": "Frame-Extraktionsrate des Videos, Standard 1, Bereich [0.2, 5]\n\n- Höhere Werte: Empfindlicher gegenüber visuellen Änderungen, höhere Token-Kosten und langsamer\n- Niedrigere Werte: Geringere Token-Kosten und schneller, aber weniger empfindlich gegenüber visuellen Änderungen",
                "minimum": 0.2,
                "maximum": 5,
                "default": 1
              },
              "max_long_side_pixel": {
                "type": "integer",
                "description": "Maximale Pixelgrenze für die längste Seite von Video-Frames",
                "minimum": 1
              }
            }
          }
        }
      },
      "AssistantRequestMessage": {
        "title": "Assistant Message",
        "type": "object",
        "required": [
          "role"
        ],
        "properties": {
          "role": {
            "type": "string",
            "enum": [
              "assistant"
            ],
            "description": "Rollenkennung, fest auf `assistant` gesetzt"
          },
          "content": {
            "type": [
              "string",
              "null"
            ],
            "description": "Inhalt der Assistentennachricht\n\n**Hinweise**:\n- Dient zum Übergeben historischer Assistentenantworten in Mehrrundengesprächen\n- Kann `null` sein, wenn `tool_calls` vorhanden ist"
          },
          "name": {
            "type": "string",
            "description": "Name des Teilnehmers"
          },
          "tool_calls": {
            "type": "array",
            "description": "Liste der Werkzeugaufrufe\n\nDient zum Übergeben historischer Werkzeugaufruf-Informationen in Mehrrundengesprächen",
            "items": {
