{
  "openapi": "3.1.0",
  "info": {
    "title": "krea-2-turbo Schnittstelle",
    "description": "Bildaufgaben mit KI-Modellen erstellen, mit Unterstützung für mehrere Modelle und Parameterkonfigurationen",
    "license": {
      "name": "MIT"
    },
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://api.evolink.ai",
      "description": "Produktionsumgebung"
    }
  ],
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "paths": {
    "/v1/images/generations": {
      "post": {
        "summary": "krea-2-turbo Schnittstelle",
        "description": "- Krea 2 Turbo ist ein ultraschnelles Text-zu-Bild-Generierungsmodell, das detailgetreue Bilder mit filmischer Anmutung erzeugt\n- Unterstützt ausschließlich Text-zu-Bild-Generierung, keine Referenzbilder\n- Asynchroner Verarbeitungsmodus, verwenden Sie die zurückgegebene Aufgaben-ID zur [Abfrage](/de/api-manual/task-management/get-task-detail)\n- Generierte Bildlinks sind 24 Stunden gültig, bitte speichern Sie diese umgehend",
        "operationId": "createImageGeneration",
        "tags": [
          "Bildgenerierung"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ImageGenerationRequest"
              },
              "examples": {
                "text_to_image": {
                  "summary": "Text zu Bild",
                  "value": {
                    "model": "krea-2-turbo",
                    "prompt": "A cinematic product poster, silver headphones floating against a deep matte-black backdrop with soft rim lighting",
                    "size": "16:9",
                    "quality": "1K"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Bildgenerierungsaufgabe erfolgreich erstellt",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ImageGenerationResponse"
                }
              }
            }
          },
          "400": {
            "description": "Ungültige Anfrageparameter",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "error": {
                    "code": "invalid_request",
                    "message": "Invalid request parameters",
                    "type": "invalid_request_error"
                  }
                }
              }
            }
          },
          "401": {
            "description": "Nicht autorisiert, ungültiges oder abgelaufenes Token",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "error": {
                    "code": "unauthorized",
                    "message": "Invalid or expired token",
                    "type": "authentication_error"
                  }
                }
              }
            }
          },
          "402": {
            "description": "Unzureichendes Kontingent, Aufladung erforderlich",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "error": {
                    "code": "insufficient_quota",
                    "message": "Insufficient quota. Please top up your account.",
                    "type": "insufficient_quota"
                  }
                }
              }
            }
          },
          "403": {
            "description": "Zugriff verweigert",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "error": {
                    "code": "model_access_denied",
                    "message": "Token does not have access to model: krea-2-turbo",
                    "type": "invalid_request_error"
                  }
                }
              }
            }
          },
          "429": {
            "description": "Ratenlimit überschritten",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "error": {
                    "code": "rate_limit_exceeded",
                    "message": "Too many requests, please try again later",
                    "type": "rate_limit_error"
                  }
                }
              }
            }
          },
          "500": {
            "description": "Interner Serverfehler",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "error": {
                    "code": "internal_error",
                    "message": "Internal server error",
                    "type": "api_error"
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "ImageGenerationRequest": {
        "type": "object",
        "required": [
          "model",
          "prompt"
        ],
        "properties": {
          "model": {
            "type": "string",
            "description": "Modellname für Bildgenerierung",
            "enum": [
              "krea-2-turbo"
            ],
            "default": "krea-2-turbo",
            "example": "krea-2-turbo"
          },
          "prompt": {
            "type": "string",
            "description": "Prompt, der das zu generierende Bild beschreibt. Englische Eingaben liefern die besten Ergebnisse; maximale Länge `640` Tokens",
            "example": "A cinematic product poster, silver headphones floating against a deep matte-black backdrop with soft rim lighting"
          },
          "size": {
            "type": "string",
            "description": "Seitenverhältnis des generierten Bildes, Standard `1:1`, wenn nicht angegeben. Die tatsächliche Ausgabeauflösung wird gemeinsam durch `size` und `quality` bestimmt.\n\n**Unterstützte Verhältnisse (insgesamt 11):** `1:1`, `4:3`, `3:4`, `5:4`, `4:5`, `2:3`, `3:2`, `9:16`, `16:9`, `1:2`, `2:1`\n\n**Übersicht der Ausgabeauflösung (`size` × `quality`):**\n\n| Verhältnis | `1K` | `2K` |\n|---|---|---|\n| `1:1` | 1024×1024 | 2048×2048 |\n| `4:3` | 1152×896 | 2304×1728 |\n| `3:4` | 896×1152 | 1728×2304 |\n| `5:4` | 1152×896 | 2240×1792 |\n| `4:5` | 896×1152 | 1792×2240 |\n| `2:3` | 832×1280 | 1664×2496 |\n| `3:2` | 1280×832 | 2496×1664 |\n| `9:16` | 768×1344 | 1472×2688 |\n| `16:9` | 1344×768 | 2688×1472 |\n| `1:2` | 704×1472 | 1408×2816 |\n| `2:1` | 1472×704 | 2816×1408 |",
            "enum": [
              "1:1",
              "4:3",
              "3:4",
              "5:4",
              "4:5",
              "2:3",
              "3:2",
              "9:16",
              "16:9",
              "1:2",
              "2:1"
            ],
            "default": "1:1",
            "example": "16:9"
          },
          "quality": {
            "type": "string",
            "description": "Auflösungsstufe der Ausgabe `1K` / `2K`, Standard `1K`, wenn nicht angegeben. `2K` erzeugt Bilder mit höherer Auflösung als `1K`. Unterschiedliche Stufen werden unterschiedlich abgerechnet, siehe Preisseite",
            "enum": [
              "1K",
              "2K"
            ],
            "default": "1K",
            "example": "1K"
          },
          "seed": {
            "type": "integer",
            "description": "Zufalls-Seed zur Erzeugung ähnlicher Kompositionen\n\n**Hinweis:**\n- Bereich: `0` bis `1048576`\n- `0` oder leer lassen für einen zufälligen Seed\n- Gleicher Seed mit gleichem Prompt kann dieselbe Komposition reproduzieren",
            "minimum": 0,
            "maximum": 1048576,
            "example": 12345
          },
          "nsfw_check": {
            "type": "boolean",
            "description": "Zusätzliche NSFW-Inhaltsmoderation aktivieren\n\n**Hinweis:**\n- Standard: `false` (deaktiviert)\n- Grundlegende Inhaltsmoderation ist auch bei Deaktivierung immer aktiv\n- Aktivieren für strengere Inhaltsfilterung",
            "default": false,
            "example": false
          },
          "callback_url": {
            "type": "string",
            "description": "HTTPS-Callback-Adresse nach Aufgabenabschluss\n\n**Callback-Zeitpunkt:**\n- Wird ausgelöst, wenn die Aufgabe abgeschlossen, fehlgeschlagen oder abgebrochen wurde\n- Wird nach Abschluss der Abrechnungsbestätigung gesendet\n\n**Sicherheitsbeschränkungen:**\n- Nur HTTPS-Protokoll wird unterstützt\n- Callback an interne IP-Adressen ist verboten (127.0.0.1, 10.x.x.x, 172.16-31.x.x, 192.168.x.x, usw.)\n- URL-Länge darf `2048` Zeichen nicht überschreiten\n\n**Callback-Mechanismus:**\n- Timeout: `10` Sekunden\n- Maximal `3` Wiederholungsversuche bei Fehler (Wiederholung nach `1` Sekunde/`2` Sekunden/`4` Sekunden)\n- Das Format des Callback-Antwortkörpers entspricht dem Antwortformat der Aufgabenabfrage-API\n- Ein 2xx-Statuscode der Callback-Adresse gilt als erfolgreich, andere Statuscodes lösen eine Wiederholung aus",
            "format": "uri",
            "example": "https://your-domain.com/webhooks/image-task-completed"
          }
        }
      },
      "ImageGenerationResponse": {
        "type": "object",
        "properties": {
          "created": {
            "type": "integer",
            "description": "Zeitstempel der Aufgabenerstellung",
            "example": 1751280000
          },
          "id": {
            "type": "string",
            "description": "Aufgaben-ID",
            "example": "task-unified-1751280000-k2t9x8a3"
          },
          "model": {
            "type": "string",
            "description": "Tatsächlich verwendeter Modellname",
            "example": "krea-2-turbo"
          },
          "object": {
            "type": "string",
            "enum": [
              "image.generation.task"
            ],
            "description": "Spezifischer Typ der Aufgabe"
          },
          "progress": {
            "type": "integer",
            "description": "Aufgabenfortschritt in Prozent (0-100)",
            "minimum": 0,
            "maximum": 100,
            "example": 0
          },
          "status": {
            "type": "string",
            "description": "Aufgabenstatus",
            "enum": [
              "pending",
              "processing",
              "completed",
              "failed"
            ],
            "example": "pending"
          },
          "task_info": {
            "$ref": "#/components/schemas/TaskInfo",
            "description": "Asynchrone Aufgabeninformationen"
          },
          "type": {
            "type": "string",
            "enum": [
              "text",
              "image",
              "audio",
              "video"
            ],
            "description": "Ausgabetyp der Aufgabe",
            "example": "image"
          },
          "usage": {
            "$ref": "#/components/schemas/Usage",
            "description": "Nutzungs- und Abrechnungsinformationen"
          }
        }
      },
      "TaskInfo": {
        "type": "object",
        "properties": {
          "can_cancel": {
            "type": "boolean",
            "description": "Ob die Aufgabe abgebrochen werden kann, bei krea-2-turbo immer `false`",
            "example": false
          },
          "estimated_time": {
            "type": "integer",
            "description": "Geschätzte Abschlusszeit (Sekunden)",
            "minimum": 0,
            "example": 45
          }
        }
      },
      "Usage": {
        "type": "object",
        "description": "Nutzungs- und Abrechnungsinformationen",
        "properties": {
          "billing_rule": {
            "type": "string",
            "description": "Abrechnungsregel",
            "enum": [
              "per_call",
              "per_token",
              "per_second"
            ],
            "example": "per_call"
          },
          "credits_reserved": {
            "type": "number",
            "description": "Geschätzter Guthabenverbrauch",
            "minimum": 0,
            "example": 0.05
          },
          "user_group": {
            "type": "string",
            "description": "Benutzergruppenkategorie",
            "example": "default"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "object",
            "properties": {
              "code": {
                "type": "string",
                "description": "Fehlercode-Bezeichner"
              },
              "message": {
                "type": "string",
                "description": "Fehlerbeschreibung"
              },
              "type": {
                "type": "string",
                "description": "Fehlertyp"
              }
            }
          }
        }
      }
    },
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "##Alle APIs erfordern Bearer-Token-Authentifizierung##\n\n**API-Schlüssel erhalten:**\n\nBesuchen Sie die [API-Schlüsselverwaltungsseite](https://evolink.ai/dashboard/keys), um Ihren API-Schlüssel zu erhalten\n\n**Zum Anfrage-Header hinzufügen:**\n```\nAuthorization: Bearer YOUR_API_KEY\n```"
      }
    }
  },
  "tags": [
    {
      "name": "Bildgenerierung",
      "description": "APIs zur KI-Bildgenerierung"
    }
  ]
}
