{
  "openapi": "3.1.0",
  "info": {
    "title": "Midjourney V7 Bildgenerierung Schnittstelle",
    "description": "Bildgenerierungsaufgaben mit dem Midjourney V7 Modell erstellen",
    "license": {
      "name": "MIT"
    },
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://api.evolink.ai",
      "description": "Produktionsumgebung"
    }
  ],
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "paths": {
    "/v1/images/generations": {
      "post": {
        "summary": "Midjourney V7 Bildgenerierung Schnittstelle",
        "description": "- Das Midjourney V7 Modell generiert hochwertige Bilder per natuerlichsprachigem Prompt, 4 Bilder pro Generierung\n- Unterstuetzt Text-zu-Bild und Bild-zu-Bild (Bild-URLs im Prompt referenzieren)\n- Unterstuetzt alle nativen V7-Parameter (z.B. --ar, --s, --c), siehe [Prompt-Parameter-Handbuch](/de/api-manual/image-series/midjourney/midjourney-v7-prompt-guide)\n- Asynchroner Verarbeitungsmodus, verwenden Sie die zurueckgegebene Aufgaben-ID zum [Abfragen](/de/api-manual/task-management/get-task-detail)\n- Generierte Bildlinks sind 24 Stunden gueltig, bitte zeitnah speichern\n- Timeout: ca. 20 Minuten\n- Systemschutz: `--v`/`--version` auf V7 gesperrt, `--niji` nicht unterstützt, `--fast`/`--turbo`/`--draft` muss über `model_params.speed` gesteuert werden (diese Parameter im Prompt werden automatisch entfernt)",
        "operationId": "createMjV7ImageGeneration",
        "tags": [
          "Bildgenerierung"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ImageGenerationRequest"
              },
              "examples": {
                "text_to_image": {
                  "summary": "Text zu Bild",
                  "value": {
                    "model": "mj-v7",
                    "prompt": "A cinematic shot of a Maine Coon cat on a neon-lit balcony --ar 16:9 --s 500",
                    "model_params": {
                      "speed": "fast"
                    }
                  }
                },
                "image_to_image": {
                  "summary": "Bild zu Bild",
                  "value": {
                    "model": "mj-v7",
                    "prompt": "https://example.com/ref.jpg A sunset landscape in watercolor style --iw 1.5 --ar 16:9",
                    "model_params": {
                      "speed": "fast"
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Aufgabe erfolgreich erstellt",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ImageGenerationResponse"
                }
              }
            }
          },
          "400": {
            "description": "Ungueltige Anfrageparameter",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "error": {
                    "code": "invalid_request",
                    "message": "Invalid request parameters",
                    "type": "invalid_request_error"
                  }
                }
              }
            }
          },
          "401": {
            "description": "Nicht authentifiziert, ungueltiges oder abgelaufenes Token",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "error": {
                    "code": "unauthorized",
                    "message": "Invalid or expired token",
                    "type": "authentication_error"
                  }
                }
              }
            }
          },
          "402": {
            "description": "Unzureichendes Guthaben, bitte aufladen",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "error": {
                    "code": "insufficient_quota",
                    "message": "Insufficient quota. Please top up your account.",
                    "type": "insufficient_quota"
                  }
                }
              }
            }
          },
          "403": {
            "description": "Zugriff verweigert",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "error": {
                    "code": "model_access_denied",
                    "message": "Token does not have access to model: mj-v7",
                    "type": "invalid_request_error"
                  }
                }
              }
            }
          },
          "429": {
            "description": "Ratenlimit ueberschritten",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "error": {
                    "code": "rate_limit_exceeded",
                    "message": "Too many requests, please try again later",
                    "type": "rate_limit_error"
                  }
                }
              }
            }
          },
          "500": {
            "description": "Interner Serverfehler",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "error": {
                    "code": "internal_error",
                    "message": "Internal server error",
                    "type": "api_error"
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "## Alle Endpunkte erfordern Bearer Token Authentifizierung ##\n\n**API Key erhalten:**\n\nBesuchen Sie die [API Key Verwaltungsseite](https://evolink.ai/dashboard/keys) um Ihren API Key zu erhalten\n\n**Zum Request-Header hinzufuegen:**\n```\nAuthorization: Bearer YOUR_API_KEY\n```"
      }
    },
    "schemas": {
      "ImageGenerationRequest": {
        "type": "object",
        "required": [
          "model",
          "prompt"
        ],
        "properties": {
          "model": {
            "type": "string",
            "enum": [
              "mj-v7"
            ],
            "default": "mj-v7",
            "description": "Modellname"
          },
          "prompt": {
            "type": "string",
            "description": "Prompt, unterstuetzt alle nativen Midjourney V7-Parameter (z.B. --ar 16:9 --s 500).\n\n**Bild-zu-Bild:** Platzieren Sie Bild-URLs am Anfang des Prompts. Unterstuetzte Formate: .png, .gif, .webp, .jpg, .jpeg\n\n**Bild-zu-Bild-Regeln:**\n- 1 Bild + kein Text = **ungueltig** (gibt Fehler zurueck)\n- 1 Bild + Textbeschreibung = gueltig\n- 2+ Bilder + kein Text = gueltig\n- 2+ Bilder + Textbeschreibung = gueltig",
            "maxLength": 8192,
            "example": "A cinematic shot of a Maine Coon cat on a neon-lit balcony --ar 16:9 --s 500"
          },
          "model_params": {
            "type": "object",
            "description": "Modellparameter",
            "properties": {
              "speed": {
                "type": "string",
                "enum": [
                  "draft",
                  "fast",
                  "turbo"
                ],
                "default": "fast",
                "description": "Geschwindigkeitsmodus\n\n- `draft`: Skizzenmodus, 10x schneller, guenstiger, spaeter mit mj-v7-enhance verbesserbar\n- `fast`: Standardmodus (Standard)\n- `turbo`: Ultra-Schnellmodus, hoehere Kosten\n\n**Preishinweis:** Draft am guenstigsten, Turbo am teuersten (ca. 2x Fast)"
              }
            }
          },
          "callback_url": {
            "type": "string",
            "description": "HTTPS-Callback-URL fuer Aufgabenabschluss\n\n**Callback-Zeitpunkt:**\n- Ausgeloest bei Abschluss, Fehler oder Abbruch der Aufgabe\n- Nach Abrechnungsbestaetigung gesendet\n\n**Sicherheitsbeschraenkungen:**\n- Nur HTTPS-Protokoll\n- Callbacks an private IPs verboten (127.0.0.1, 10.x.x.x, 172.16-31.x.x, 192.168.x.x usw.)\n- URL-Laenge max `2048` Zeichen\n\n**Callback-Mechanismus:**\n- Timeout: `10` Sekunden\n- Bis zu `3` Wiederholungen (nach `1`s/`2`s/`4`s)\n- Antwortformat entspricht der Aufgabenabfrage\n- 2xx-Statuscode = erfolgreich; andere loesen Wiederholungen aus",
            "format": "uri",
            "example": "https://your-domain.com/webhooks/image-task-completed"
          }
        }
      },
      "ImageGenerationResponse": {
        "type": "object",
        "properties": {
          "created": {
            "type": "integer",
            "description": "Zeitstempel der Aufgabenerstellung",
            "example": 1757165031
          },
          "id": {
            "type": "string",
            "description": "Aufgaben-ID",
            "example": "task-unified-1757165031-mjv7"
          },
          "model": {
            "type": "string",
            "description": "Tatsaechlich verwendeter Modellname",
            "example": "mj-v7"
          },
          "object": {
            "type": "string",
            "enum": [
              "image.generation.task"
            ],
            "description": "Aufgabenobjekttyp"
          },
          "progress": {
            "type": "integer",
            "description": "Aufgabenfortschritt in Prozent (0-100)",
            "minimum": 0,
            "maximum": 100,
            "example": 0
          },
          "status": {
            "type": "string",
            "description": "Aufgabenstatus",
            "enum": [
              "pending",
              "processing",
              "completed",
              "failed"
            ],
            "example": "pending"
          },
          "task_info": {
            "$ref": "#/components/schemas/TaskInfo",
            "description": "Asynchrone Aufgabeninformation"
          },
          "type": {
            "type": "string",
            "enum": [
              "text",
              "image",
              "audio",
              "video"
            ],
            "description": "Aufgabenausgabetyp",
            "example": "image"
          },
          "usage": {
            "$ref": "#/components/schemas/Usage",
            "description": "Nutzungs- und Abrechnungsinformationen"
          }
        }
      },
      "TaskInfo": {
        "type": "object",
        "properties": {
          "can_cancel": {
            "type": "boolean",
            "description": "Ob die Aufgabe abgebrochen werden kann",
            "example": true
          },
          "estimated_time": {
            "type": "integer",
            "description": "Geschaetzte Fertigstellungszeit (Sekunden)",
            "minimum": 0,
            "example": 45
          }
        }
      },
      "Usage": {
        "type": "object",
        "description": "Nutzungs- und Abrechnungsinformationen",
        "properties": {
          "billing_rule": {
            "type": "string",
            "description": "Abrechnungsregel",
            "enum": [
              "per_call",
              "per_token",
              "per_second"
            ],
            "example": "per_call"
          },
          "credits_reserved": {
            "type": "number",
            "description": "Geschaetzte verbrauchte Credits",
            "minimum": 0,
            "example": 1.8
          },
          "user_group": {
            "type": "string",
            "description": "Benutzergruppe",
            "example": "default"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "object",
            "properties": {
              "code": {
                "type": "string",
                "description": "Fehlercode-Bezeichner"
              },
              "message": {
                "type": "string",
                "description": "Fehlerbeschreibung"
              },
              "type": {
                "type": "string",
                "description": "Fehlertyp"
              }
            }
          }
        }
      }
    }
  }
}