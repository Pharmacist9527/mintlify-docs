{
  "openapi": "3.1.0",
  "info": {
    "title": "mj-v7-inpaint Schnittstelle",
    "version": "1.0.0",
    "description": "- Bestimmte Bereiche im Bild neu generieren, der Rest bleibt unveraendert\n- Zwei Maskenmethoden: Polygonkoordinaten oder Schwarz-Weiss-Maskenbilder\n- Asynchroner Verarbeitungsmodus, verwenden Sie die zurueckgegebene Aufgaben-ID zum [Abfragen](/de/api-manual/task-management/get-task-detail)"
  },
  "servers": [
    {
      "url": "https://api.evolink.ai"
    }
  ],
  "paths": {
    "/v1/images/generations": {
      "post": {
        "operationId": "mjV7Inpaint",
        "summary": "Midjourney V7 Inpaint",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/MjV7InpaintRequest"
              },
              "examples": {
                "polygon_mask": {
                  "summary": "Polygonkoordinaten Inpaint",
                  "value": {
                    "model": "mj-v7-inpaint",
                    "prompt": "Einen Kirschbaum hinzufuegen",
                    "model_params": {
                      "task_id": "task-unified-xxx",
                      "image_number": 0,
                      "mask": {
                        "areas": [
                          {
                            "width": 200,
                            "height": 200,
                            "points": [
                              50,
                              50,
                              50,
                              250,
                              250,
                              250,
                              250,
                              50
                            ]
                          }
                        ]
                      }
                    }
                  }
                },
                "image_mask": {
                  "summary": "Maskenbild Inpaint",
                  "value": {
                    "model": "mj-v7-inpaint",
                    "model_params": {
                      "task_id": "task-unified-xxx",
                      "image_number": 0,
                      "mask": {
                        "url": "https://example.com/mask.png"
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Aufgabe erfolgreich erstellt",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ImageGenerationResponse"
                }
              }
            }
          },
          "400": {
            "description": "Ungueltige Anfrageparameter",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Nicht authentifiziert",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "402": {
            "description": "Unzureichendes Guthaben",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "403": {
            "description": "Zugriff verweigert",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "429": {
            "description": "Ratenlimit ueberschritten",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "500": {
            "description": "Interner Serverfehler",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "## Alle Endpunkte erfordern Bearer Token Authentifizierung ##\n\n**API Key erhalten:**\n\nBesuchen Sie die [API Key Verwaltungsseite](https://evolink.ai/dashboard/keys) um Ihren API Key zu erhalten\n\n**Zum Request-Header hinzufuegen:**\n```\nAuthorization: Bearer YOUR_API_KEY\n```"
      }
    },
    "schemas": {
      "MjV7InpaintRequest": {
        "type": "object",
        "required": [
          "model",
          "model_params"
        ],
        "properties": {
          "model": {
            "type": "string",
            "enum": [
              "mj-v7-inpaint"
            ],
            "default": "mj-v7-inpaint",
            "description": "Modellname"
          },
          "prompt": {
            "type": "string",
            "description": "Gewuenschten Inhalt fuer den Inpaint-Bereich beschreiben",
            "example": "Einen Kirschbaum hinzufuegen"
          },
          "model_params": {
            "type": "object",
            "required": [
              "task_id",
              "mask"
            ],
            "description": "Modellparameter",
            "properties": {
              "task_id": {
                "type": "string",
                "description": "Quellaufgaben-ID",
                "example": "task-unified-xxx"
              },
              "image_number": {
                "type": "integer",
                "enum": [
                  0,
                  1,
                  2,
                  3
                ],
                "default": 0,
                "description": "Bild auswaehlen (0-3)"
              },
              "mask": {
                "type": "object",
                "description": "Inpaint-Bereichsdefinition, zwei Methoden",
                "oneOf": [
                  {
                    "type": "object",
                    "description": "Polygonkoordinaten-Methode",
                    "required": [
                      "areas"
                    ],
                    "properties": {
                      "areas": {
                        "type": "array",
                        "description": "Polygonkoordinaten-Methode, mehrere Inpaint-Bereiche",
                        "items": {
                          "type": "object",
                          "properties": {
                            "width": {
                              "type": "integer",
                              "description": "Polygon-Begrenzungsrahmen Breite"
                            },
                            "height": {
                              "type": "integer",
                              "description": "Polygon-Begrenzungsrahmen Hoehe"
                            },
                            "points": {
                              "type": "array",
                              "items": {
                                "type": "integer"
                              },
                              "description": "Abgeflachte Koordinatenpaare [x1,y1,x2,y2,...] als geschlossenes Polygon"
                            }
                          }
                        }
                      }
                    }
                  },
                  {
                    "type": "object",
                    "description": "Schwarz-Weiss-Maskenbild-URL, weiss = Inpaint, schwarz = erhalten",
                    "required": [
                      "url"
                    ],
                    "properties": {
                      "url": {
                        "type": "string",
                        "format": "uri",
                        "description": "Schwarz-Weiss-Maskenbild-URL, weiss = Inpaint, schwarz = erhalten"
                      }
                    }
                  }
                ]
              },
              "speed": {
                "type": "string",
                "enum": [
                  "fast",
                  "turbo"
                ],
                "default": "fast",
                "description": "Geschwindigkeitsmodus (nur wirksam wenn Prompt angegeben)\n\n**Preishinweis:** Turbo-Modus kostet mehr"
              }
            }
          },
          "callback_url": {
            "type": "string",
            "format": "uri",
            "description": "Callback-URL fuer Aufgabenabschluss"
          }
        }
      },
      "ImageGenerationResponse": {
        "type": "object",
        "properties": {
          "created": {
            "type": "integer",
            "description": "Zeitstempel der Aufgabenerstellung",
            "example": 1757165031
          },
          "id": {
            "type": "string",
            "description": "Aufgaben-ID",
            "example": "task-unified-1757165031-mjv7"
          },
          "model": {
            "type": "string",
            "description": "Tatsaechlich verwendeter Modellname"
          },
          "object": {
            "type": "string",
            "enum": [
              "image.generation.task"
            ],
            "description": "Aufgabenobjekttyp"
          },
          "progress": {
            "type": "integer",
            "description": "Aufgabenfortschritt in Prozent (0-100)",
            "minimum": 0,
            "maximum": 100,
            "example": 0
          },
          "status": {
            "type": "string",
            "description": "Aufgabenstatus",
            "enum": [
              "pending",
              "processing",
              "completed",
              "failed"
            ],
            "example": "pending"
          },
          "task_info": {
            "$ref": "#/components/schemas/TaskInfo"
          },
          "type": {
            "type": "string",
            "enum": [
              "text",
              "image",
              "audio",
              "video"
            ],
            "example": "image"
          },
          "usage": {
            "$ref": "#/components/schemas/Usage"
          }
        }
      },
      "TaskInfo": {
        "type": "object",
        "properties": {
          "can_cancel": {
            "type": "boolean",
            "description": "Ob die Aufgabe abgebrochen werden kann",
            "example": true
          },
          "estimated_time": {
            "type": "integer",
            "description": "Geschaetzte Fertigstellungszeit (Sekunden)",
            "minimum": 0,
            "example": 45
          }
        }
      },
      "Usage": {
        "type": "object",
        "properties": {
          "billing_rule": {
            "type": "string",
            "enum": [
              "per_call",
              "per_token",
              "per_second"
            ],
            "example": "per_call"
          },
          "credits_reserved": {
            "type": "number",
            "description": "Geschaetzte verbrauchte Credits",
            "minimum": 0,
            "example": 1.8
          },
          "user_group": {
            "type": "string",
            "example": "default"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "object",
            "properties": {
              "code": {
                "type": "string"
              },
              "message": {
                "type": "string"
              },
              "type": {
                "type": "string"
              }
            }
          }
        }
      }
    }
  }
}